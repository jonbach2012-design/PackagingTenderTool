    {
        SidebarBridge.ImportStatus = _importStatus;
        SidebarBridge.ImportInProgress = _isImporting;
        SidebarBridge.NotifyChanged();
    }

    private static void NormalizePricePerThousand(List<LabelLineItem> items)
    {
        foreach (var it in items)
        {
            if (it.PricePerThousand is > 0)
                continue;

            if (it.Price is not > 0)
                continue;

            if (!TryParsePcsPerRoll(it.ReelDiameterOrPcsPerRoll, out var pcsPerRoll) || pcsPerRoll <= 0m)
                continue;

            it.PricePerThousand = decimal.Round((it.Price.Value / pcsPerRoll) * 1000m, 2, MidpointRounding.AwayFromZero);
        }
    }

    private static void NormalizeMaterialWeights(List<LabelLineItem> items)
    {
        // Kronfågel fallback ratios: 60% front, 5% adhesive, 35% backing (when only total is provided).
        const decimal frontR = 0.60m;
        const decimal adhR = 0.05m;
        const decimal backR = 0.35m;

        foreach (var it in items)
        {
            if (it.LabelWeightGrams is not > 0m)
                continue;

            if (it.FrontWeightGrams is > 0m && it.AdhesiveWeightGrams is > 0m && it.BackingWeightGrams is > 0m)
                continue;

            var total = it.LabelWeightGrams.Value;
            it.FrontWeightGrams ??= decimal.Round(total * frontR, 4, MidpointRounding.AwayFromZero);
            it.AdhesiveWeightGrams ??= decimal.Round(total * adhR, 4, MidpointRounding.AwayFromZero);
            it.BackingWeightGrams ??= decimal.Round(total * backR, 4, MidpointRounding.AwayFromZero);
        }
    }

    private void BuildImportFlags(List<LabelLineItem> items)
    {
        var byItem = items
            .Where(i => !string.IsNullOrWhiteSpace(i.ItemNo) && i.PricePerThousand is > 0)
            .GroupBy(i => i.ItemNo!.Trim(), StringComparer.OrdinalIgnoreCase);

        foreach (var g in byItem)
        {
            var avg = g.Average(i => i.PricePerThousand!.Value);
            if (avg <= 0.0001m)
                continue;

            foreach (var it in g)
            {
                var ratio = it.PricePerThousand!.Value / avg;
                if (ratio > 1.5m || ratio < 0.5m)
                {
                    var supplier = it.SupplierName?.Trim() ?? "Unknown supplier";
                    var site = it.Site?.Trim() ?? "Unknown site";
                    var key = $"import|{g.Key}|{supplier}|{site}";

                    _importFlags.Add(new ImportUnitMismatchFlag(
                        key,
                        supplier,
                        g.Key,
                        site,
                        "Potential unit mismatch (>50% deviation from item average)."));

                    _anomalies.TryAdd(key, new AnomalyState(AnomalyStatus.Pending, note: string.Empty));
                }
            }
        }
    }

    private static bool TryParsePcsPerRoll(string? raw, out decimal pcsPerRoll)
    {
        pcsPerRoll = 0m;
        if (string.IsNullOrWhiteSpace(raw))
            return false;

        var span = raw.AsSpan();
        var buf = new char[span.Length];
        var bi = 0;
        var inNum = false;
        for (var i = 0; i < span.Length; i++)
        {
            var ch = span[i];
            if (char.IsDigit(ch) || ch is '.' or ',')
            {
                inNum = true;
                buf[bi++] = ch == ',' ? '.' : ch;
            }
            else if (inNum)
            {
                break;
            }
        }

        if (bi == 0)
            return false;

        return decimal.TryParse(new string(buf, 0, bi), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out pcsPerRoll);
    }

    private static List<SupplierModel> BuildSuppliersFromImportedLines(List<LabelLineItem> items)
    {
        string Slug(string s) => new string(s.ToLowerInvariant().Where(ch => char.IsLetterOrDigit(ch)).ToArray());

        return items
            .Where(i => !string.IsNullOrWhiteSpace(i.SupplierName))
            .GroupBy(i => i.SupplierName!.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(g =>
            {
                var qty = g.Sum(x => x.Quantity ?? 0m);
                var unit = g.Where(x => x.PricePerThousand is > 0).Select(x => x.PricePerThousand!.Value / 1000m).DefaultIfEmpty(0m).Average();
                var sites = g.Select(x => x.Site).Where(s => !string.IsNullOrWhiteSpace(s)).Select(s => s!.Trim()).Distinct(StringComparer.OrdinalIgnoreCase).ToArray();
                var derived = sites.Length > 0 ? DeriveCountryFromSiteName(sites[0]) : string.Empty;
                var country = string.IsNullOrWhiteSpace(derived) ? "Unknown" : derived;
                if (string.IsNullOrWhiteSpace(country))
                    country = "DK";
                var weight = g.Select(x =>
                        (x.FrontWeightGrams ?? 0m) + (x.AdhesiveWeightGrams ?? 0m) + (x.BackingWeightGrams ?? 0m))
                    .DefaultIfEmpty(0m)
                    .Average();
                if (weight <= 0m)
                    weight = g.Select(x => x.LabelWeightGrams ?? 0m).DefaultIfEmpty(0m).Average();

                return new SupplierModel
                {
                    SupplierId = Slug(g.Key),
                    SupplierName = g.Key,
                    Sites = sites,
                    Country = country,
                    QuantityLabels = qty,
                    Price = unit,
                    LabelWeightGramsPerUnit = weight,
                    Material = g.Select(x => x.Material).FirstOrDefault(m => !string.IsNullOrWhiteSpace(m))?.Trim() ?? string.Empty,
                    LabelType = "Imported",
                    Adhesive = string.Empty,
                    PriceAt1k = unit,
                    PriceAt5k = unit,
                    PriceAt10k = unit,
                    SupplierComments = g.Select(x => x.Comment).FirstOrDefault(c => !string.IsNullOrWhiteSpace(c))?.Trim() ?? string.Empty,
                    LogisticsConstraints = string.Empty,
                    CommercialScore = 70m,
                    TechnicalScore = decimal.Round(g.Average(x => x.TechnicalRating ?? 0m), 0, MidpointRounding.AwayFromZero),
                    RegulatoryScore = 70m
                };
            })
            .ToList();
    }

    private static string DeriveCountryFromSiteName(string site)
    {
        if (string.IsNullOrWhiteSpace(site))
            return string.Empty;

        var s = site.Trim();
        // DSH-style known site names -> ISO-ish codes used in this app.
        if (s.Contains("Stokke", StringComparison.OrdinalIgnoreCase))
            return "NO";
        if (s.Contains("Jæren", StringComparison.OrdinalIgnoreCase))
            return "NO";
        if (s.Contains("Jaeren", StringComparison.OrdinalIgnoreCase))
            return "NO";
        if (s.Contains("Norway", StringComparison.OrdinalIgnoreCase) || s.Contains("Norge", StringComparison.OrdinalIgnoreCase))
            return "NO";
        if (s.Contains("Denmark", StringComparison.OrdinalIgnoreCase) || s.Contains("Danmark", StringComparison.OrdinalIgnoreCase))
            return "DK";
        if (s.Contains("Sweden", StringComparison.OrdinalIgnoreCase) || s.Contains("Sverige", StringComparison.OrdinalIgnoreCase))
            return "SE";
        if (s.Contains("Finland", StringComparison.OrdinalIgnoreCase))
            return "FI";

        return string.Empty;
    }

    private decimal GetSkuCountForScope()
    {
        // Scope-driven SKU count for base switching costs.
        if (_importedLineItems.Count == 0)
            return 3m;

        IEnumerable<LabelLineItem> q = _importedLineItems;

        if (!string.IsNullOrWhiteSpace(_filterSite))
            q = q.Where(i => string.Equals(i.Site, _filterSite, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(_filterMaterial))
        {
            q = q.Where(i =>
                TcoEngine.NormalizeTenderDimension(i.Material).Equals(
                    _filterMaterial.Trim(),
                    StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_filterCountry))
        {
            q = q.Where(i =>
            {
                var code = GetCountryFromSite(i.Site ?? string.Empty);
                if (!string.IsNullOrEmpty(code))
                    return code.Equals(_filterCountry.Trim(), StringComparison.OrdinalIgnoreCase);
                return TcoEngine.UnknownDimensionValue.Equals(_filterCountry.Trim(), StringComparison.OrdinalIgnoreCase);
            });
        }

        // Adhesive is not a first-class column in the current import, so we cannot filter by it here yet.
        // Keep SKU count robust and deterministic.

        return Math.Max(1m, q
            .Select(i => i.ItemNo?.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count());
    }

    private bool LineItemMatchesActiveDimensionFilters(LabelLineItem i)
    {
        if (_activeSites.Count > 0 &&
            !_activeSites.Contains(i.Site?.Trim() ?? string.Empty))
            return false;

        if (_activeCountries.Count > 0 &&
            !_activeCountries.Contains(DeriveCountryFromSiteName(i.Site ?? string.Empty)))
            return false;
        if (_activeMaterials.Count > 0 &&
            !_activeMaterials.Contains(i.Material?.Trim() ?? string.Empty))
            return false;
        if (_activeLabelSizes.Count > 0 &&
            !_activeLabelSizes.Contains(i.LabelSize?.Trim() ?? string.Empty))
            return false;
        if (_activeWindings.Count > 0 &&
            !_activeWindings.Contains(i.WindingDirection?.Trim() ?? string.Empty))
            return false;
        if (_activeColors.Count > 0)
        {
            var colorToken = (i.OriginalColorsValue ?? i.NumberOfColors?.ToString() ?? string.Empty).Trim();
            if (!_activeColors.Contains(colorToken))
                return false;
        }

        if (!string.IsNullOrWhiteSpace(_filterMaterial) &&
            !string.Equals(i.Material?.Trim(), _filterMaterial,
                StringComparison.OrdinalIgnoreCase))
            return false;

        if (!string.IsNullOrWhiteSpace(_filterLabelSize))
        {
            var label = i.LabelSize?.Trim();
            if (!string.Equals(label, _filterLabelSize.Trim(), StringComparison.OrdinalIgnoreCase))
                return false;
        }

        if (!string.IsNullOrWhiteSpace(_filterWinding))
        {
            var wind = i.WindingDirection?.Trim();
            if (!string.Equals(wind, _filterWinding.Trim(), StringComparison.OrdinalIgnoreCase))
                return false;
        }

        if (!string.IsNullOrWhiteSpace(_filterColors))
        {
            var colorToken = (i.OriginalColorsValue ?? i.NumberOfColors?.ToString())?.Trim();
            if (!string.Equals(colorToken, _filterColors.Trim(), StringComparison.OrdinalIgnoreCase))
                return false;
        }

        return true;
    }

    /// <summary>Aligns selected/active supplier ids with the current tender supplier list (import vs demo, stale ids).</summary>
    private void ReconcileSessionWithTenderSuppliers()
    {
        var ids = _suppliersAll
            .Select(s => s.SupplierId)
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        if (ids.Length == 0)
        {
            Session.SetActiveSupplier(string.Empty);
            return;
        }

        var selected = Session.SelectedSuppliers.ToArray();
        var validSelected = selected.Where(id => ids.Contains(id, StringComparer.OrdinalIgnoreCase)).ToArray();

        if (validSelected.Length == 0)
            Session.ReplaceSelectedSuppliers(ids);
        else if (validSelected.Length != selected.Length)
            Session.ReplaceSelectedSuppliers(validSelected);

        var current = Session.SelectedSuppliers.ToArray();
        var fallbackActive = current.Length > 0
            ? current.OrderBy(x => x, StringComparer.OrdinalIgnoreCase).First()
            : ids.OrderBy(x => x, StringComparer.OrdinalIgnoreCase).First();

        var active = Session.ActiveSupplierId;
        var activeInSelection = !string.IsNullOrWhiteSpace(active) && Session.SelectedSuppliers.Contains(active);
        if (string.IsNullOrWhiteSpace(active)
            || !ids.Contains(active, StringComparer.OrdinalIgnoreCase)
            || !activeInSelection)
            Session.SetActiveSupplier(fallbackActive);
    }

    private void RefreshData()
    {
        if (_isCalculating)
            return;

        _isCalculating = true;
        try
        {
            if (Session.SelectedProfile != PackagingProfileSession.ProfileLabels)
            {
                _suppliersAll = [];
                _suppliersSelected = [];
                _pillarRows = [];
                _tableRows = [];
                _tcoResults.Clear();
                _decisionInsight = null;
                return;
            }

            // No import yet — return early and show empty state.
            if (_importedLineItems.Count == 0)
                return;

            _bestBidBaseline = ComputeBestBidBaseline(_importedLineItems);
            _currentContractBaseline = ComputeCurrentContractBaseline(_importedLineItems);
            _imputedSpend = ComputeImputedSpend(
                _importedLineItems,
                _currentContractBaseline,
                _bestBidBaseline);

            var anyDimensionFilterActive = !string.IsNullOrWhiteSpace(_filterLabelSize)
                || !string.IsNullOrWhiteSpace(_filterWinding)
                || !string.IsNullOrWhiteSpace(_filterColors)
                || !string.IsNullOrWhiteSpace(_filterMaterial)
                || _activeCountries.Count > 0
                || _activeSites.Count > 0
                || _activeMaterials.Count > 0
                || _activeLabelSizes.Count > 0
                || _activeWindings.Count > 0
                || _activeColors.Count > 0;
            var itemsForSupplierBuild = anyDimensionFilterActive
                ? _importedLineItems.Where(LineItemMatchesActiveDimensionFilters).ToList()
                : _importedLineItems;
            _suppliersAll = BuildSuppliersFromImportedLines(itemsForSupplierBuild);

            ReconcileSessionWithTenderSuppliers();

            var filterOpts = TcoEngine.GetTenderFilterOptions(_suppliersAll, _filterCountry);
            if (!string.IsNullOrWhiteSpace(_filterCountry)
                && !filterOpts.Countries.Any(c => c.Equals(_filterCountry, StringComparison.OrdinalIgnoreCase)))
            {
                _filterCountry = string.Empty;
                filterOpts = TcoEngine.GetTenderFilterOptions(_suppliersAll, _filterCountry);
            }

            _filterCountries = filterOpts.Countries.ToArray();
            _filterSitesForCountry = filterOpts.Sites.ToArray();
            var itemsInScope = _importedLineItems
                .Where(i =>
                    (string.IsNullOrEmpty(_filterCountry) ||
                     string.Equals(DeriveCountryFromSiteName(i.Site ?? string.Empty),
                         _filterCountry, StringComparison.OrdinalIgnoreCase)) &&
                    (string.IsNullOrEmpty(_filterSite) ||
                     string.Equals(i.Site?.Trim(), _filterSite,
                         StringComparison.OrdinalIgnoreCase)))
                .ToList();

            _filterMaterials = itemsInScope
                .Select(i => i.Material?.Trim())
                .Where(m => !string.IsNullOrWhiteSpace(m))
                .Select(m => m!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(m => m, StringComparer.OrdinalIgnoreCase)
                .ToArray();
            _filterLabelSizes = itemsInScope
                .Select(i => i.LabelSize?.Trim())
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Select(s => s!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
                .ToArray();
            _filterWindings = itemsInScope
                .Select(i => i.WindingDirection?.Trim())
                .Where(w => !string.IsNullOrWhiteSpace(w))
                .Select(w => w!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(w => w, StringComparer.OrdinalIgnoreCase)
                .ToArray();
            _filterColorValues = itemsInScope
                .Select(i => i.OriginalColorsValue ?? i.NumberOfColors?.ToString())
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Select(c => c!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(c => c, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            if (!string.IsNullOrWhiteSpace(_filterSite) && !_filterSitesForCountry.Contains(_filterSite, StringComparer.OrdinalIgnoreCase))
                _filterSite = string.Empty;

            if (!string.IsNullOrWhiteSpace(_filterMaterial) && !_filterMaterials.Contains(_filterMaterial, StringComparer.OrdinalIgnoreCase))
                _filterMaterial = string.Empty;

            if (!string.IsNullOrWhiteSpace(_filterLabelSize) && !_filterLabelSizes.Contains(_filterLabelSize, StringComparer.OrdinalIgnoreCase))
                _filterLabelSize = string.Empty;

            if (!string.IsNullOrWhiteSpace(_filterWinding) && !_filterWindings.Contains(_filterWinding, StringComparer.OrdinalIgnoreCase))
                _filterWinding = string.Empty;

            if (!string.IsNullOrWhiteSpace(_filterColors) && !_filterColorValues.Contains(_filterColors, StringComparer.OrdinalIgnoreCase))
                _filterColors = string.Empty;

            var suppliersFiltered = _suppliersAll
                .Where(s => TcoEngine.SupplierMatchesTenderFilters(
                    s,
                    _filterCountry,
                    _filterSite,
                    _filterMaterial,
                    string.Empty))
                .ToList();

            // Seed supplier settings defaults (archetype values come from demo SupplierModel).
            foreach (var s in suppliersFiltered)
            {
                Session.SeedSupplierDefaults(
                    supplierId: s.SupplierId,
                    grade: s.RecyclingGrade ?? RecyclingGrade.C,
                    startupCost: s.StartupCost,
                    monthlySupportCost: s.MonthlySupportCost,
                    moqPenaltyPct: s.MoqPenaltyPct);
            }

            _outliers = SupplierOutlierDetection.Detect(suppliersFiltered);

            // Defensive: prune stale keys before generating new in-memory state.
            PruneAuditMaps();

            // CRITICAL: Clear + TryAdd only when repopulating anomalies.
            RebuildAnomalies();

            Session.SetPendingClarificationsCount(_anomalies.Values.Count(a => a.Status is AnomalyStatus.Pending or AnomalyStatus.Clarification));

            _tableSites = suppliersFiltered
                .SelectMany(s => s.Sites ?? [])
                .Select(s => TcoEngine.NormalizeTenderDimension(s))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
                .ToArray();
            _tableMaterials = suppliersFiltered
                .Select(s => TcoEngine.NormalizeTenderDimension(s.Material))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(m => m, StringComparer.OrdinalIgnoreCase)
                .ToArray();
            _tableSupplierOptions = suppliersFiltered
                .Where(s => !string.IsNullOrWhiteSpace(s.SupplierId))
                .GroupBy(s => s.SupplierId, StringComparer.OrdinalIgnoreCase)
                .Select(g => g.First())
                .Select(s => new SupplierOption(s.SupplierId, s.SupplierName))
                .OrderBy(s => s.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            var selected = Session.SelectedSuppliers;
            _suppliersSelected = selected.Count == 0
                ? []
                : suppliersFiltered.Where(s => selected.Contains(s.SupplierId)).ToList();

            _pillarRows = SupplierPillarAnalysis.BuildOrdered(
                    _suppliersSelected,
                    Session.Commercial,
                    Session.Technical,
                    Session.Regulatory)
                .ToList();

            _tableRows = SupplierPillarAnalysis.BuildOrdered(
                    suppliersFiltered,
                    Session.Commercial,
                    Session.Technical,
                    Session.Regulatory)
                .ToList();

            _tcoResults.Clear();
            _tcoResults.AddRange(TcoEngine.GetResults(Session, _suppliersSelected));
            _decisionInsight = TcoEngine.GetDecisionInsight(Session, _tcoResults, _suppliersSelected);
            SyncSidebarBridge();
        }
        finally
        {
            _isCalculating = false;
        }
    }

