    private void OnActivePanelChanged(int v)
    {
        _activePanelIndex = v;
        var tab = v switch
        {
            0 => "dashboard",
            1 => "matrix",
            2 => "evidence",
            3 => "audit",
            _ => "dashboard"
        };

        Nav.NavigateTo($"/labeltender?tab={tab}", replace: true);
