    private bool RowNeedsManualReview(SupplierPillarAnalysisRow row)
    {
        var dto = GetTcoDto(row.Supplier.SupplierId);
        if (dto is null)
            return true;

        if (!dto.IsCompliant)
            return true;

        if (dto.FinalCtrScore < 45m)
            return true;

        if (IsOutlier(row.Supplier.SupplierId, OutlierFieldPrice)
            || IsOutlier(row.Supplier.SupplierId, OutlierFieldQuantity))
            return true;

        return IsExtremePrice(row.Supplier.SupplierId);
    }

    private bool ShowConditionalChip(SupplierPillarAnalysisRow row, LabelTenderDashboardDto dto)
    {
        if (IsRecommendedSupplier(row.Supplier.SupplierId))
            return false;

        if (RowNeedsManualReview(row))
            return false;

        return dto.IsCompliant && dto.FinalCtrScore >= 48m && dto.FinalCtrScore < 68m;
    }

    private int RiskReviewRowCount => TableItems.Count(RowNeedsManualReview);

    private static IReadOnlyDictionary<string, decimal> ComputeBestBidBaseline(
        IReadOnlyList<LabelLineItem> items)
    {
        // Best bid baseline = sum of (lowest price × quantity) per ItemNo
        // across all suppliers. Uses PricePerThousand/1000 × Quantity.
        var lowestPricePerItem = new Dictionary<string, decimal>(
            StringComparer.OrdinalIgnoreCase);

        foreach (var item in items)
        {
            var itemNo = item.ItemNo?.Trim();
            if (string.IsNullOrWhiteSpace(itemNo))
                continue;

            var unitPrice = item.PricePerThousand is > 0m
                ? item.PricePerThousand.Value / 1000m
                : item.Price is > 0m
                    ? item.Price.Value
                    : 0m;

            if (unitPrice <= 0m)
                continue;

            if (!lowestPricePerItem.TryGetValue(itemNo, out var existing)
                || unitPrice < existing)
            {
                lowestPricePerItem[itemNo] = unitPrice;
            }
        }

        // Now multiply lowest unit price × quantity per ItemNo
        // Use first available quantity for each ItemNo
        var quantityPerItem = items
            .Where(i => !string.IsNullOrWhiteSpace(i.ItemNo)
                && i.Quantity is > 0m)
            .GroupBy(i => i.ItemNo!.Trim(), StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                g => g.Key,
                g => g.First().Quantity!.Value,
                StringComparer.OrdinalIgnoreCase);

        var result = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
        foreach (var (itemNo, unitPrice) in lowestPricePerItem)
        {
            if (!quantityPerItem.TryGetValue(itemNo, out var qty) || qty <= 0m)
                continue;

            result[itemNo] = decimal.Round(
                unitPrice * qty, 0, MidpointRounding.AwayFromZero);
        }

        return result;
    }

    private static IReadOnlyDictionary<string, decimal> ComputeCurrentContractBaseline(
        IReadOnlyList<LabelLineItem> items)
    {
        // current_price is a unit price — multiply by quantity to get line total.
        // Use first available current_price and quantity per ItemNo.
        var result = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);

        var byItemNo = items
            .Where(i => !string.IsNullOrWhiteSpace(i.ItemNo))
            .GroupBy(i => i.ItemNo!.Trim(), StringComparer.OrdinalIgnoreCase);

        foreach (var group in byItemNo)
        {
            var contractPrice = group
                .Select(i => i.CurrentContractPrice)
                .FirstOrDefault(p => p is > 0m);

            if (contractPrice is null or <= 0m)
                continue;

            var qty = group
                .Select(i => i.Quantity)
                .FirstOrDefault(q => q is > 0m);

            if (qty is null or <= 0m)
                continue;

            result[group.Key] = decimal.Round(
                (contractPrice.Value / 1000m) * qty.Value,
                0,
                MidpointRounding.AwayFromZero);
        }

        return result;
    }

    private static IReadOnlyDictionary<string, ImputedSupplierSpend> ComputeImputedSpend(
        IReadOnlyList<LabelLineItem> allItems,
        IReadOnlyDictionary<string, decimal> currentContractBaseline,
        IReadOnlyDictionary<string, decimal> bestBidBaseline)
    {
        // Full package = all distinct ItemNos across all suppliers
        var fullPackage = allItems
            .Select(i => i.ItemNo?.Trim())
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Select(n => n!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var totalLineCount = fullPackage.Count;

        // Group actual bids per supplier
        var bidsBySupplier = allItems
            .Where(i => !string.IsNullOrWhiteSpace(i.SupplierName)
                && !string.IsNullOrWhiteSpace(i.ItemNo))
            .GroupBy(i => i.SupplierName!.Trim(), StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                g => g.Key,
                g => g.ToDictionary(
                    i => i.ItemNo!.Trim(),
                    i => i,
                    StringComparer.OrdinalIgnoreCase),
                StringComparer.OrdinalIgnoreCase);

        var result = new Dictionary<string, ImputedSupplierSpend>(
            StringComparer.OrdinalIgnoreCase);

        foreach (var (supplierName, bids) in bidsBySupplier)
        {
            var totalSpend = 0m;
            var bidLineCount = 0;

            foreach (var itemNo in fullPackage)
            {
                if (bids.TryGetValue(itemNo, out var line))
                {
                    // Supplier has bid on this line
                    var unitPrice = line.PricePerThousand is > 0m
                        ? line.PricePerThousand.Value / 1000m
                        : line.Price is > 0m
                            ? line.Price.Value
                            : 0m;
                    var qty = line.Quantity ?? 0m;

                    // Count as bid if supplier has submitted any price — qty may be absent
                    var hasBid = unitPrice > 0m || line.Spend is > 0m;
                    if (hasBid)
                        bidLineCount++;

                    if (unitPrice > 0m && qty > 0m)
                    {
                        totalSpend += unitPrice * qty;
                    }
                    else if (line.Spend is > 0m)
                    {
                        totalSpend += line.Spend.Value;
                    }
                }
                else
                {
                    // Supplier has not bid — impute with CurrentContractPrice,
                    // fall back to BestBidBaseline if CurrentContractPrice is absent.
                    var hasContract = currentContractBaseline.TryGetValue(itemNo, out var contractPrice)
                        && contractPrice > 0m;
                    var hasBestBid = bestBidBaseline.TryGetValue(itemNo, out var bestBidLineTotal)
                        && bestBidLineTotal > 0m;

                    if (hasContract)
                    {
                        // contractPrice is already (unit price × qty) — add directly
                        totalSpend += contractPrice;
                    }
                    else if (hasBestBid)
                    {
                        // bestBidLineTotal is already (unit price × qty) — add directly
                        totalSpend += bestBidLineTotal;
                    }
                    // else: no price available — exclude line silently
                }
            }

            result[supplierName] = new ImputedSupplierSpend(
                TotalSpend: decimal.Round(totalSpend, 0, MidpointRounding.AwayFromZero),
                BidLineCount: bidLineCount,
                TotalLineCount: totalLineCount,
                IsIncompleteBid: bidLineCount < totalLineCount);
        }

        return result;
    }
}    