    private static string GetCountryFromSite(string site)
    {
        if (string.IsNullOrWhiteSpace(site))
            return string.Empty;

        var dash = site.IndexOf('-');
        return dash > 0 ? site[..dash].ToUpperInvariant() : site.Length >= 2 ? site[..2].ToUpperInvariant() : site.ToUpperInvariant();
    }

