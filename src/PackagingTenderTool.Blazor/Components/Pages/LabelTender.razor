@page "/labeltender"
@implements IDisposable

@using System.Globalization
@using System.Collections.Concurrent
@using PackagingTenderTool.Core.Models
@using PackagingTenderTool.Core.Services.LabelTenderScoring
@using PackagingTenderTool.Core.Import
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Logging
@using MudBlazor
@using PackagingTenderTool.Blazor.Components.LabelTender
@using PackagingTenderTool.Blazor.Models.LabelTender
@using PackagingTenderTool.Blazor.Services

@inject PackagingProfileSession Session
@inject NavigationManager Nav
@inject LabelsExcelImportService Importer
@inject PackagingTenderTool.Blazor.Services.ITcoEngineService TcoEngine
@inject PackagingTenderTool.Blazor.Services.LabelTenderSidebarBridge SidebarBridge
@inject ISnackbar Snackbar
@inject ILogger<LabelTender> Logger

@if (Session.SelectedProfile is null)
{
    <div class="profile-landing">
        <MudText Typo="Typo.h3" Class="profile-landing-title mb-10">
            Select Packaging Profile
        </MudText>

        <MudGrid Class="label-tender-profile-grid label-tender-profile-grid--landing" Spacing="4">
            @foreach (var name in _profiles)
            {
                var isLabels = name == PackagingProfileSession.ProfileLabels;
                <MudItem xs="12">
                    @if (isLabels)
                    {
                        <MudCard Elevation="0"
                                 Outlined="true"
                                 Class="label-tender-card label-tender-card--labels pa-6"
                                 @onclick="SelectLabels">
                            <MudCardContent Class="pa-0 d-flex align-center justify-center" Style="min-height: 5rem;">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">@name</MudText>
                            </MudCardContent>
                        </MudCard>
                    }
                    else
                    {
                        <MudCard Elevation="0" Outlined="true" Class="label-tender-card label-tender-card--faded pa-6">
                            <MudCardContent Class="pa-0 d-flex align-center justify-center" Style="min-height: 5rem;">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">@name</MudText>
                            </MudCardContent>
                        </MudCard>
                    }
                </MudItem>
            }
        </MudGrid>
    </div>
}
else
{
    <MudStack Spacing="6" Class="cockpit-main-stack cockpit-page-main">
                <div>
                    <MudText Typo="Typo.h4" Class="cockpit-page-title mb-1">Packaging Tender Decision Cockpit</MudText>
                </div>

                <MudGrid Spacing="4" Class="decision-kpi-grid">
                    <MudItem xs="12" sm="6" lg="3">
                        <MudPaper Elevation="6" Class="decision-kpi-card pt-kpi-card--recommended pa-5">
                            <MudText Typo="Typo.overline" Class="cockpit-muted">Recommended</MudText>
                            <MudText Typo="Typo.h4" Class="decision-kpi-name decision-kpi-name--hero mt-1">
                                @(_decisionInsight?.RecommendedSupplierName ?? "—")
                            </MudText>
                            @if (!string.IsNullOrWhiteSpace(_decisionInsight?.RecommendedSupplierId) && _decisionInsight!.IsSensitiveDecision)
                            {
                                <MudStack Row="true" Spacing="1" Class="mt-2 flex-wrap align-center">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Class="ma-0">Sensitive decision</MudChip>
                                </MudStack>
                            }
                            <MudStack Row="true" AlignItems="AlignItems.Baseline" Spacing="2" Class="mt-2">
                                <MudText Typo="Typo.h4" Class="decision-kpi-metric ma-0">
                                    @(string.IsNullOrWhiteSpace(_decisionInsight?.RecommendedSupplierId)
                                        ? "–"
                                        : _decisionInsight!.RecommendedWeightedScore.ToString("0.0", Da))
                                </MudText>
                                <MudText Typo="Typo.caption" Class="cockpit-muted">weighted CTR</MudText>
                            </MudStack>
                            <div class="decision-pillar-bar mt-3" title="Weighted contribution to CTR">
                                <div class="decision-pillar-bar__comm" style="width: @($"{(_decisionInsight?.WeightedShareCommercial ?? 0m):0.#}%")"></div>
                                <div class="decision-pillar-bar__tech" style="width: @($"{(_decisionInsight?.WeightedShareTechnical ?? 0m):0.#}%")"></div>
                                <div class="decision-pillar-bar__reg" style="width: @($"{(_decisionInsight?.WeightedShareRegulatory ?? 0m):0.#}%")"></div>
                            </div>
                            <MudStack Row="true" Spacing="2" Class="mt-2 flex-wrap">
                                <MudText Typo="Typo.caption" Class="cockpit-muted">Comm @((_decisionInsight?.WeightedShareCommercial ?? 0m).ToString("0"))%</MudText>
                                <MudText Typo="Typo.caption" Class="cockpit-muted">Tech @((_decisionInsight?.WeightedShareTechnical ?? 0m).ToString("0"))%</MudText>
                                <MudText Typo="Typo.caption" Class="cockpit-muted">Reg @((_decisionInsight?.WeightedShareRegulatory ?? 0m).ToString("0"))%</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2" Class="decision-kpi-narrative mt-3">
                                @(_decisionInsight?.Narrative ?? "Import suppliers or widen selection to generate insight.")
                            </MudText>
                            <MudText Typo="Typo.caption" Class="cockpit-muted mt-2">
                                Value driver: @(_decisionInsight?.PrimaryValueDriver ?? "—")
                            </MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" lg="3">
                        <MudPaper Elevation="6" Class="decision-kpi-card pa-5">
                            <MudText Typo="Typo.overline" Class="cockpit-muted">Lowest commercial anchor</MudText>
                            <MudText Typo="Typo.h6" Class="mt-2">@(_decisionInsight?.LowestPriceSupplierName ?? "—")</MudText>
                            <MudText Typo="Typo.h5" Class="decision-kpi-metric mt-2">
                                @((_decisionInsight?.LowestCommercialSpend ?? 0m).ToString("N0", Da)) kr
                            </MudText>
                            <MudText Typo="Typo.caption" Class="cockpit-muted mt-2">Total commercial spend (volume × price)</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" lg="3">
                        <MudPaper Elevation="6" Class="decision-kpi-card pa-5">
                            <MudText Typo="Typo.overline" Class="cockpit-muted">Best TCO</MudText>
                            <MudText Typo="Typo.h6" Class="mt-2">@(_decisionInsight?.BestTcoSupplierName ?? "—")</MudText>
                            <MudText Typo="Typo.h5" Class="decision-kpi-metric mt-2">
                                @((_decisionInsight?.BestTcoTotal ?? 0m).ToString("N0", Da)) kr
                            </MudText>
                            <MudText Typo="Typo.caption" Class="cockpit-muted mt-2">Lowest full TCO (incl. EPR, switching, MOQ)</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" lg="3">
                        <MudPaper Elevation="6" Class="decision-kpi-card decision-kpi-card--risk pa-5">
                            <MudText Typo="Typo.overline" Class="cockpit-muted">Risk exposure</MudText>
                            <MudText Typo="Typo.h3" Class="decision-kpi-metric mt-2">@RiskReviewRowCount</MudText>
                            <MudText Typo="Typo.body2" Class="cockpit-muted mt-2">
                                Evidence rows flagged for review (compliance, outliers, or weak CTR).
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @if (!string.IsNullOrWhiteSpace(_weightWarning))
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                        @_weightWarning
                    </MudAlert>
                }

                <MudTabs Rounded="true" Class="cockpit-tabs" ActivePanelIndex="@_activePanelIndex" ActivePanelIndexChanged="OnActivePanelChanged">
                <MudTabPanel Text="Dashboard">
                    <MudPaper Elevation="0" Class="cockpit-chart-shell pa-6 mt-4">
                        <MudText Typo="Typo.h6" Class="cockpit-section-title mb-1">Spend overview</MudText>
                        <MudText Typo="Typo.body2" Class="cockpit-muted mb-4">Commercial vs regulatory cost by supplier.</MudText>

                        <div class="cockpit-spend-wrap">
                            @{
                                var results = _tcoResults;
                                var svgH = (results.Count * 50) + 40;
                            }

                            <svg width="720"
                                 height="@svgH"
                                 viewBox="0 0 720 @svgH"
                                 class="cockpit-spend-svg">
                                @if (results.Count == 0)
                                {
                                    <svg:text x="360" y="160" text-anchor="middle" fill="rgba(45,52,54,0.65)">No suppliers selected</svg:text>
                                }
                                else
                                {
                                    @for (var idx = 0; idx < results.Count; idx++)
                                    {
                                        var r = results[idx];
                                        var yPos = (idx * 50) + 10;
                                        var x0 = 150.0;
                                        var barH = 30.0;
                                        var trackW = 600.0;
                                        var alpha = Math.Max(0.25, (double)r.FinalCtrScore / 100.0);

                                        <g opacity="@FmtSvg(alpha)">
                                            <title>@r.CalculationBreakdown</title>
                                            <rect x="@FmtSvg(x0)" y="@FmtSvg(yPos)" width="@FmtSvg(trackW)" height="@FmtSvg(barH)" fill="#f5f5f5" rx="4" />

                                            <rect x="@FmtSvg(x0)" y="@FmtSvg(yPos)" width="@FmtSvg(r.CommercialWidth)" height="@FmtSvg(barH)" fill="#91a363" rx="4" />
                                            <rect x="@FmtSvg(x0 + r.CommercialWidth)" y="@FmtSvg(yPos)" width="@FmtSvg(r.RegulatoryWidth)" height="@FmtSvg(barH)" fill="#FFB300" rx="4" />
                                            <rect x="@FmtSvg(x0 + r.CommercialWidth + r.RegulatoryWidth)" y="@FmtSvg(yPos)" width="@FmtSvg(r.SwitchingWidth)" height="@FmtSvg(barH)" fill="#D3D3D3" rx="4" />
                                            <rect x="@FmtSvg(x0 + r.CommercialWidth + r.RegulatoryWidth + r.SwitchingWidth)" y="@FmtSvg(yPos)" width="@FmtSvg(r.MoqWidth)" height="@FmtSvg(barH)" fill="#4682B4" rx="4" />

                                            <!-- Score badge -->
                                            <circle cx="@FmtSvg(12)" cy="@FmtSvg(yPos + 15)" r="@FmtSvg(10)" fill="rgba(45,52,54,0.10)" />
                                            <svg:text x="@FmtSvg(12)" y="@FmtSvg(yPos + 19)" text-anchor="middle" font-size="10" fill="#333" font-weight="700" font-family="monospace">
                                                @r.FinalCtrScore.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)
                                            </svg:text>

                                            <svg:text x="@FmtSvg(28)" y="@FmtSvg(yPos + 20)" font-size="12" fill="#333" font-weight="bold">@r.SupplierName</svg:text>

                                            <svg:text x="@FmtSvg(x0 + r.TotalWidth + 10)" y="@FmtSvg(yPos + 20)" font-size="12" font-family="monospace">
                                                @r.Total.ToString("N0", Da) kr.
                                            </svg:text>
                                        </g>
                                    }
                                }
                            </svg>
                        </div>

                        <div style="margin-top: 12px; display:flex; flex-wrap:wrap; gap: 14px; align-items:center;">
                            <div style="display:flex; align-items:center; gap: 8px;">
                                <span style="width:14px;height:14px;border-radius:3px;background:#91a363;display:inline-block;"></span>
                                <span>Aftalt pris (Indkøb)</span>
                            </div>
                            <div style="display:flex; align-items:center; gap: 8px;">
                                <span style="width:14px;height:14px;border-radius:3px;background:#4682B4;display:inline-block;"></span>
                                <span>Skjulte omkostninger (TCO-tillæg)</span>
                            </div>
                            <div style="color: rgba(45, 52, 54, 0.65);">
                                Gennemsigtighed indikerer strategisk CTR-match (Solid = Højt match, Transparent = Lavt match).
                            </div>
                        </div>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Price Matrix">
                    <PriceMatrix />
                </MudTabPanel>

                <MudTabPanel Text="Evidence table">
                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-slicer-bar pa-4 mt-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="cockpit-slicer-stack">
                            <MudTextField @bind-Value="_tableSearch"
                                          dense="true"
                                          Variant="Variant.Outlined"
                                          Placeholder="Search supplier / spec / sites"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Outlined.Search"
                                          Class="cockpit-slicer-search" />

                            <MudSelect T="string"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Label="Site"
                                       MultiSelection="true"
                                       SelectedValues="@_tableSitesSelected"
                                       SelectedValuesChanged="OnSitesSelectedChanged">
                                @foreach (var s in _tableSites)
                                {
                                    <MudSelectItem @key="s" Value="@s">@s</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="string"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Label="Material type"
                                       MultiSelection="true"
                                       SelectedValues="@_tableMaterialsSelected"
                                       SelectedValuesChanged="OnMaterialsSelectedChanged">
                                @foreach (var m in _tableMaterials)
                                {
                                    <MudSelectItem @key="m" Value="@m">@m</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="string"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Label="Supplier"
                                       MultiSelection="true"
                                       SelectedValues="@_tableSuppliersSelected"
                                       SelectedValuesChanged="OnSuppliersSelectedChanged">
                                @foreach (var s in _tableSupplierOptions)
                                {
                                    <MudSelectItem @key="s.Id" Value="@s.Id">@s.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudStack Spacing="0" Class="cockpit-slicer-range">
                                <MudText Typo="Typo.caption" Class="cockpit-muted">Weighted score</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudSlider T="int" Min="0" Max="100" Step="1" Value="@_scoreMin" ValueChanged="@(v => _scoreMin = Math.Min(v, _scoreMax))" Class="label-tender-slider-accent" valueLabelDisplay="ValueLabelDisplay.OnHover" />
                                    <MudText Typo="Typo.caption" Class="cockpit-num cockpit-num-muted">@_scoreMin</MudText>
                                    <MudText Typo="Typo.caption" Class="cockpit-muted">–</MudText>
                                    <MudText Typo="Typo.caption" Class="cockpit-num cockpit-num-muted">@_scoreMax</MudText>
                                    <MudSlider T="int" Min="0" Max="100" Step="1" Value="@_scoreMax" ValueChanged="@(v => _scoreMax = Math.Max(v, _scoreMin))" Class="label-tender-slider-accent" valueLabelDisplay="ValueLabelDisplay.OnHover" />
                                </MudStack>
                            </MudStack>
                        </MudStack>

                        @if (ActiveFilterChips.Count > 0)
                        {
                            <MudStack Row="true" Spacing="1" Class="mt-2 flex-wrap">
                                @foreach (var chip in ActiveFilterChips)
                                {
                                    <MudChip T="string" @key="chip" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@chip</MudChip>
                                }
                            </MudStack>
                        }
                    </MudPaper>

                    <MudStack Spacing="1" Class="mb-2 px-2">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;">Evidence table</MudText>
                    </MudStack>

                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-grid-shell pa-0 mt-2">
                        <MudDataGrid T="SupplierPillarAnalysisRow"
                                     Items="@TableItems"
                                     Dense="true"
                                     Hover="true"
                                     Filterable="true"
                                     FilterMode="DataGridFilterMode.ColumnFilterRow"
                                     selectionMode="DataGridSelectionMode.Single"
                                     SelectedItem="@_tableSelectedRow"
                                     SelectedItemChanged="OnTableSelectedRowChanged"
                                     Class="cockpit-supplier-grid cockpit-supplier-grid--filter decision-evidence-grid">
                            <Columns>
                                <HierarchyColumn T="SupplierPillarAnalysisRow" />

                                <TemplateColumn Title="Status" Sortable="false">
                                    <CellTemplate>
                                        @{
                                            var id = context.Item.Supplier.SupplierId;
                                            var dto = GetTcoDto(id);
                                        }
                                        <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                                            @if (IsRecommendedSupplier(id))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Recommended</MudChip>
                                            }
                                            @if (IsLowestCommercialAnchor(id))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Lowest commercial</MudChip>
                                            }
                                            @if (IsBestTcoAnchor(id))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Best TCO</MudChip>
                                            }
                                            @if (dto is not null && !dto.IsCompliant)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Regulatory risk</MudChip>
                                            }
                                            @if (RowNeedsManualReview(context.Item))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">Review</MudChip>
                                            }
                                            else if (dto is not null && ShowConditionalChip(context.Item, dto))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Conditional</MudChip>
                                            }
                                        </MudStack>
                                    </CellTemplate>
                                </TemplateColumn>

                                <PropertyColumn Property="x => x.Supplier.SupplierName" Title="Supplier" />
                                <PropertyColumn Property="x => x.Supplier.Material" Title="Material" />

                                <TemplateColumn Title="Price index" Sortable="false">
                                    <CellTemplate>
                                        @{
                                            var dto = GetTcoDto(context.Item.Supplier.SupplierId);
                                        }
                                        <MudText Typo="Typo.body2" Style="font-weight:700;">
                                            @(dto?.PriceScore.ToString("0.0", Da) ?? "–")
                                        </MudText>
                                    </CellTemplate>
                                </TemplateColumn>

                                <TemplateColumn Title="Weighted CTR" Sortable="false">
                                    <CellTemplate>
                                        @{
                                            var dto = GetTcoDto(context.Item.Supplier.SupplierId);
                                        }
                                        <MudText Typo="Typo.body2" Style="font-weight:700;">
                                            @(dto?.FinalCtrScore.ToString("0.0", Da) ?? "–")
                                        </MudText>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>

                            <ChildRowContent>
                                <MudStack Spacing="4">
                                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-3">Economics &amp; sites</MudText>
                                        <MudGrid Spacing="3">
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Label type</MudText>
                                                <MudText Typo="Typo.body2">@context.Item.Supplier.LabelType</MudText>
                                            </MudItem>
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Adhesive</MudText>
                                                <MudText Typo="Typo.body2">@context.Item.Supplier.Adhesive</MudText>
                                            </MudItem>
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Sites</MudText>
                                                <MudText Typo="Typo.body2">@string.Join(", ", context.Item.Supplier.Sites)</MudText>
                                            </MudItem>
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Quantity (labels)</MudText>
                                                @{
                                                    var isQtyOutlier = IsOutlier(context.Item.Supplier.SupplierId, OutlierFieldQuantity);
                                                    var qtyKey = AnomalyKey(context.Item.Supplier.SupplierId, OutlierFieldQuantity);
                                                }
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.body2" Class="@(isQtyOutlier ? "cockpit-outlier-cell" : null)">
                                                        @context.Item.Supplier.QuantityLabels.ToString("N0", Da)
                                                    </MudText>
                                                    @if (isQtyOutlier)
                                                    {
                                                        <MudMenu Dense="true" Icon="@Icons.Material.Outlined.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(qtyKey, AnomalyStatus.Accepted))">Accept</MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(qtyKey, AnomalyStatus.Excluded))">Exclude</MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(qtyKey, AnomalyStatus.Clarification))">Clarify</MudMenuItem>
                                                        </MudMenu>
                                                    }
                                                </MudStack>
                                            </MudItem>
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Unit price</MudText>
                                                @{
                                                    var isPriceOutlier = IsOutlier(context.Item.Supplier.SupplierId, OutlierFieldPrice) || IsExtremePrice(context.Item.Supplier.SupplierId);
                                                    var priceKey = AnomalyKey(context.Item.Supplier.SupplierId, OutlierFieldPrice);
                                                }
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.body2" Class="@(isPriceOutlier ? "cockpit-outlier-cell" : null)">
                                                        @context.Item.Supplier.Price.ToString("N2", Da)
                                                    </MudText>
                                                    @if (isPriceOutlier)
                                                    {
                                                        <MudMenu Dense="true" Icon="@Icons.Material.Outlined.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(priceKey, AnomalyStatus.Accepted))">Accept</MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(priceKey, AnomalyStatus.Excluded))">Exclude</MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(priceKey, AnomalyStatus.Clarification))">Clarify</MudMenuItem>
                                                        </MudMenu>
                                                    }
                                                </MudStack>
                                            </MudItem>
                                        </MudGrid>
                                    </MudPaper>

                                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">Raw pillar scores (supplier)</MudText>
                                        <MudSimpleTable Dense="true" Class="decision-raw-table">
                                            <tbody>
                                                <tr>
                                                    <td>Commercial</td>
                                                    <td class="text-end cockpit-num">@context.Item.Supplier.CommercialScore.ToString("0.0", Da)</td>
                                                </tr>
                                                <tr>
                                                    <td>Technical</td>
                                                    <td class="text-end cockpit-num">@context.Item.Supplier.TechnicalScore.ToString("0.0", Da)</td>
                                                </tr>
                                                <tr>
                                                    <td>Regulatory</td>
                                                    <td class="text-end cockpit-num">@context.Item.Supplier.RegulatoryScore.ToString("0.0", Da)</td>
                                                </tr>
                                            </tbody>
                                        </MudSimpleTable>
                                    </MudPaper>

                                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">Pillar blend (scoring model)</MudText>
                                        <MudStack Spacing="0" Class="w-100">
                                            <MudProgressLinear Value="@((double)context.Item.TotalScore)"
                                                               Max="100"
                                                               Rounded="true"
                                                               Color="Color.Default"
                                                               Class="cockpit-weighted-bar" />
                                            <MudText Typo="Typo.caption" Class="text-end cockpit-weighted-caption cockpit-num cockpit-num-muted mt-1">
                                                @FormatScore(context.Item.TotalScore)
                                            </MudText>
                                        </MudStack>
                                    </MudPaper>

                                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">TCO engine &amp; breakdown</MudText>
                                        @{
                                            var tco = GetTcoDto(context.Item.Supplier.SupplierId);
