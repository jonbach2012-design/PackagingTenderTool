    private static bool IsPivotFormat(Stream stream)
    {
        try
        {
            stream.Position = 0;
            using var wb = new ClosedXML.Excel.XLWorkbook(stream);
            return wb.Worksheets.Any(ws =>
                ws.Name.Equals("All labels DSH",
                StringComparison.OrdinalIgnoreCase));
        }
        catch
        {
            return false;
        }
    }

    private static bool IsTenderPriceAnalyzeFormat(Stream stream)
    {
        return PackagingTenderTool.Core.Import.TenderPriceAnalyzeImportService
            .IsTenderPriceAnalyzeFormat(stream);
    }

    private async Task OnExcelSelected(string fileName, byte[] fileBytes)
    {
        var snapshot = CaptureImportSnapshot();
        _isImporting = true;
        _importStatus = "Importing…";
        SidebarBridge.LastImportedFileName = fileName;
        SidebarBridge.LastImportValidationReport = null;
        PushImportUiToBridge();

        try
        {
            LabelTenderExcelImportGuard.EnsureXlsxExtension(fileName);

            using var ms = new MemoryStream(fileBytes);

            LabelsTenderImportResult result;
            try
            {
                ms.Position = 0;
                var isTenderPriceAnalyze = IsTenderPriceAnalyzeFormat(ms);
                ms.Position = 0;
                var isPivotFormat = !isTenderPriceAnalyze && IsPivotFormat(ms);
                ms.Position = 0;

                result = isTenderPriceAnalyze
                    ? PriceAnalyzeImporter.ImportTenderWithReport(
                        ms,
                        SidebarBridge.LastImportedFileName,
                        new PackagingTenderTool.Core.Models.TenderSettings
                        {
                            TargetCurrency = "NOK"
                        })
                    : isPivotFormat
                        ? PivotImporter.ImportTenderWithReport(ms, SidebarBridge.LastImportedFileName)
                        : Importer.ImportTenderWithReport(ms);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Label tender Excel import failed while reading the workbook.");
                RestoreTenderState(snapshot);
                SidebarBridge.LastImportValidationReport = null;
                _importStatus = LabelTenderImportFailureMessage.Format(ex);
                Snackbar.Add(_importStatus, Severity.Error);
                RefreshData();
                return;
            }

            if (!result.ImportCommitted)
            {
                RestoreTenderState(snapshot);
                SidebarBridge.LastImportValidationReport = result.ValidationReport;
                var blocking = result.ValidationReport?.Issues.Count(i => i.BlocksImport) ?? 0;
                _importStatus = blocking > 0
                    ? $"Import blocked: {blocking} blocking row issue(s). Fix the workbook (see validation list) and try again."
                    : "Import blocked: validation failed. See validation list in the sidebar.";
                Snackbar.Add(_importStatus, Severity.Error);
                RefreshData();
                return;
            }

            var newLines = result.Tender.LabelLineItems.ToList();
            NormalizePricePerThousand(newLines);
            NormalizeMaterialWeights(newLines);

            if (newLines.Count == 0)
            {
                RestoreTenderState(snapshot);
                SidebarBridge.LastImportValidationReport = null;
                _importStatus = "Import failed: No tender data rows were found. Check that item rows exist below the header.";
                Snackbar.Add(_importStatus, Severity.Warning);
                RefreshData();
                return;
            }

            _importFlags.Clear();
            BuildImportFlags(newLines);

            _importedLineItems = newLines;
            _suppliersAll = BuildSuppliersFromImportedLines(_importedLineItems);

            var importedIds = _suppliersAll
                .Select(s => s.SupplierId)
                .Where(id => !string.IsNullOrWhiteSpace(id))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();

            Session.ReplaceSelectedSuppliers(importedIds);
            if (importedIds.Length > 0)
                Session.SetActiveSupplier(importedIds[0]);

            var actionable = result.ValidationReport?.Issues
                .Where(i => i.Severity != ImportValidationSeverity.Info)
                .ToList() ?? [];
            SidebarBridge.LastImportValidationReport = actionable.Count > 0 ? result.ValidationReport : null;

            var rowErr = actionable.Count(i => i.Severity == ImportValidationSeverity.Error && !i.BlocksImport);
            var warns = actionable.Count(i => i.Severity == ImportValidationSeverity.Warning);
            if (rowErr > 0 || warns > 0)
            {
                _importStatus =
                    $"Imported {_importedLineItems.Count} rows • {_suppliersAll.Count} suppliers • Review: {rowErr} data issue(s), {warns} warning(s). See sidebar for the validation list.";
            }
            else
            {
                _importStatus = $"Imported {_importedLineItems.Count} rows • {_suppliersAll.Count} suppliers • Flags: {_importFlags.Count}";
            }

            RefreshData();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Label tender Excel import failed.");
            RestoreTenderState(snapshot);
            SidebarBridge.LastImportValidationReport = null;
            _importStatus = LabelTenderImportFailureMessage.Format(ex);
            Snackbar.Add(_importStatus, Severity.Error);
            RefreshData();
        }
        finally
        {
            _isImporting = false;
            PushImportUiToBridge();
            await InvokeAsync(StateHasChanged);
        }
    }

    private sealed record TenderImportSnapshot(
        List<LabelLineItem> ImportedLines,
        List<SupplierModel> SuppliersAll,
        List<ImportUnitMismatchFlag> Flags,
        string[] SelectedSupplierIds,
        string ActiveSupplierId);

    private TenderImportSnapshot CaptureImportSnapshot() =>
        new(
            _importedLineItems.ToList(),
            _suppliersAll.ToList(),
            _importFlags.ToList(),
            Session.SelectedSuppliers.ToArray(),
            Session.ActiveSupplierId);

    private void RestoreTenderState(TenderImportSnapshot snap)
    {
        _suppressSessionChanged = true;
        try
        {
            _importedLineItems = [.. snap.ImportedLines];
            _suppliersAll = [.. snap.SuppliersAll];
            _importFlags.Clear();
            _importFlags.AddRange(snap.Flags);
            Session.ReplaceSelectedSuppliers(snap.SelectedSupplierIds);
            Session.SetActiveSupplier(snap.ActiveSupplierId);
        }
        finally
        {
            _suppressSessionChanged = false;
        }
    }

