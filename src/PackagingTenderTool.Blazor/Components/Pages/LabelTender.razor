        _tableSitesSelected = v is null ? new HashSet<string>(StringComparer.OrdinalIgnoreCase) : new HashSet<string>(v, StringComparer.OrdinalIgnoreCase);

    private void OnMaterialsSelectedChanged(IEnumerable<string> v) =>
        _tableMaterialsSelected = v is null ? new HashSet<string>(StringComparer.OrdinalIgnoreCase) : new HashSet<string>(v, StringComparer.OrdinalIgnoreCase);

    private void OnSuppliersSelectedChanged(IEnumerable<string> v) =>
        _tableSuppliersSelected = v is null ? new HashSet<string>(StringComparer.OrdinalIgnoreCase) : new HashSet<string>(v, StringComparer.OrdinalIgnoreCase);

    private bool IsOutlier(string supplierId, string field) =>
        _outliers.BySupplierId.TryGetValue(supplierId, out var flags) && flags.Any(f => string.Equals(f.Field, field, StringComparison.OrdinalIgnoreCase));

    private bool IsExtremePrice(string supplierId)
    {
        var me = _suppliersAll.FirstOrDefault(s => string.Equals(s.SupplierId, supplierId, StringComparison.OrdinalIgnoreCase));
        if (me is null)
            return false;

        var others = _suppliersAll.Where(s => !string.Equals(s.SupplierId, supplierId, StringComparison.OrdinalIgnoreCase)).Select(s => s.Price).Where(v => v > 0m).ToArray();
        if (others.Length == 0)
            return false;

        var avg = others.Average();
        if (avg <= 0.0000001m)
            return false;

        return me.Price > avg * 5m;
    }

    private string GetPriceTooltip(string supplierId)
    {
        if (IsExtremePrice(supplierId))
            return "Check units (price is > 5× average of other suppliers)";

        return GetOutlierTooltip(supplierId, OutlierFieldPrice);
    }

    private string GetOutlierTooltip(string supplierId, string field)
    {
        if (!_outliers.BySupplierId.TryGetValue(supplierId, out var flags))
        {
            return string.Empty;
        }

        var msg = flags.FirstOrDefault(f => string.Equals(f.Field, field, StringComparison.OrdinalIgnoreCase))?.Message;
        return msg ?? string.Empty;
    }

    private bool DataIntegrityHasIssues => _outliers.HasFlags;

    private bool HasClarifications => _anomalies.Values.Any(a => a.Status == AnomalyStatus.Clarification);

    private string DataIntegrityHeadline => _outliers.SupplierCountWithFlags == 1
        ? "Warning: unit mismatch detected in 1 line"
        : $"Warning: unit mismatch detected in {_outliers.SupplierCountWithFlags} lines";

    private string DataIntegrityHint => _outliers.HasFlags
        ? "One or more values look like a potential unit error (2σ / 10× check)."
        : "No unit-mismatch signals detected.";

    private void RebuildAnomalies()
    {
        _anomalies.Clear();

        foreach (var kvp in _outliers.BySupplierId)
        {
            foreach (var f in kvp.Value)
            {
                var key = AnomalyKey(kvp.Key, f.Field);
                _anomalies.TryAdd(key, new AnomalyState(AnomalyStatus.Pending, note: string.Empty));
            }
        }
    }

    private void PruneAuditMaps()
    {
        // Prevent "stacking" of old keys in-memory across recalculations.
        // Keeps only keys that still exist in current outlier set.
        var validKeys = new HashSet<string>(
            _outliers.BySupplierId.SelectMany(kvp => kvp.Value.Select(f => $"{kvp.Key}|{f.Field}")),
            StringComparer.OrdinalIgnoreCase);

        var notesToRemove = _auditNotes.Keys.Where(k => !validKeys.Contains(k)).ToList();
        foreach (var k in notesToRemove)
            _auditNotes.TryRemove(k, out _);

        var reasoningToRemove = _auditReasoning.Keys.Where(k => !validKeys.Contains(k)).ToList();
        foreach (var k in reasoningToRemove)
            _auditReasoning.TryRemove(k, out _);

        var decisionsToRemove = _auditDecisions.Keys.Where(k => !validKeys.Contains(k)).ToList();
        foreach (var k in decisionsToRemove)
            _auditDecisions.TryRemove(k, out _);

        var anomaliesToRemove = _anomalies.Keys.Where(k => !validKeys.Contains(k)).ToList();
        foreach (var k in anomaliesToRemove)
            _anomalies.TryRemove(k, out _);
    }

    private string GetAuditReasoning(string key) => _auditReasoning.TryGetValue(key, out var v) ? v : string.Empty;

    private void SetAuditReasoning(string key, string v) => _auditReasoning[key] = v ?? string.Empty;

    private static string DefaultReasoning(string supplierName, string field, string message)
    {
        _ = supplierName;
        _ = message;
        return field.Equals(OutlierFieldQuantity, StringComparison.OrdinalIgnoreCase)
            ? "Likely unit mismatch: quantity looks inconsistent vs peer average."
            : "Likely unit mismatch: value deviates materially from peer average.";
    }

    private static string AnomalyKey(string supplierId, string field) => $"{supplierId}|{field}";

    private void SetAnomalyStatus(string key, AnomalyStatus status)
    {
        if (_isCalculating)
            return;

        if (_anomalies.TryGetValue(key, out var state))
            _anomalies[key] = state with { Status = status };
        else
            _anomalies[key] = new AnomalyState(status, note: string.Empty);

        _history.Insert(0, new HistoryEntry(DateTimeOffset.Now, $"Anomaly decision — {key} => {status}"));
        Session.SetPendingClarificationsCount(_anomalies.Values.Count(a => a.Status is AnomalyStatus.Pending or AnomalyStatus.Clarification));
        StateHasChanged();
    }

    private string GetAuditNote(string key) => _auditNotes.TryGetValue(key, out var v) ? v : string.Empty;

    private void SetAuditNote(string key, string v)
    {
        _auditNotes[key] = v ?? string.Empty;
    }

    private sealed record AnomalyState(AnomalyStatus Status, string note);

    private enum AnomalyStatus
    {
        Pending = 0,
        Clarification = 1,
        Accepted = 2,
        Excluded = 3
    }

    private SupplierPillarAnalysisRow? BestRow => _pillarRows.Count > 0 ? _pillarRows[0] : null;

    private decimal AvgTotalScore =>
        _pillarRows.Count == 0 ? 0m : _pillarRows.Average(r => r.TotalScore);

    private string AvgTotalScoreFormatted => _pillarRows.Count == 0 ? "–" : AvgTotalScore.ToString("0.0", Da);

    private string TenderValueWeightedFormatted
    {
        get
        {
            var tenderValue = TcoEngine.ComputeTenderValueWeighted(_pillarRows, TenderVolumeUnits);
            return tenderValue <= 0m ? "–" : tenderValue.ToString("N0", Da) + " kr.";
        }
    }

    private int SelectedCount => _suppliersSelected.Count;

    private int CompliancePassed =>
        TcoEngine.CountCompliancePassed(_suppliersSelected, Session.MaxCo2Impact, Session.MaxLeadTimeDays);

    private string CompliancePctFormatted =>
        SelectedCount == 0 ? "–" : ((decimal)CompliancePassed / SelectedCount).ToString("P0", CultureInfo.InvariantCulture);

    private bool HasCriticalRisk =>
        SelectedCount > 0 && CompliancePassed < SelectedCount;

    private string RiskAssessmentText => SelectedCount == 0 ? "–" : (HasCriticalRisk ? "Critical" : "Non-critical");

    private string RiskAssessmentHint =>
        SelectedCount == 0
            ? "No suppliers selected"
            : (HasCriticalRisk ? "One or more selected suppliers fail constraints" : "All selected suppliers meet constraints");

