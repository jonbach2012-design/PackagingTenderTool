@page "/labeltender"
@implements IDisposable

@using System.Globalization
@using System.Collections.Concurrent
@using PackagingTenderTool.Core.Models
@using PackagingTenderTool.Core.Services.LabelTenderScoring
@using PackagingTenderTool.Core.Import
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using PackagingTenderTool.Blazor.Components.LabelTender

@inject PackagingProfileSession Session
@inject NavigationManager Nav
@inject LabelsExcelImportService Importer
@inject PackagingTenderTool.Blazor.Services.ITcoEngineService TcoEngine

@if (Session.SelectedProfile is null)
{
    <div class="profile-landing">
        <MudText Typo="Typo.h3" Class="profile-landing-title mb-10">
            Select Packaging Profile
        </MudText>

        <MudGrid Class="label-tender-profile-grid label-tender-profile-grid--landing" Spacing="4">
            @foreach (var name in _profiles)
            {
                var isLabels = name == PackagingProfileSession.ProfileLabels;
                <MudItem xs="12">
                    @if (isLabels)
                    {
                        <MudCard Elevation="0"
                                 Outlined="true"
                                 Class="label-tender-card label-tender-card--labels pa-6"
                                 @onclick="SelectLabels">
                            <MudCardContent Class="pa-0 d-flex align-center justify-center" Style="min-height: 5rem;">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">@name</MudText>
                            </MudCardContent>
                        </MudCard>
                    }
                    else
                    {
                        <MudCard Elevation="0" Outlined="true" Class="label-tender-card label-tender-card--faded pa-6">
                            <MudCardContent Class="pa-0 d-flex align-center justify-center" Style="min-height: 5rem;">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">@name</MudText>
                            </MudCardContent>
                        </MudCard>
                    }
                </MudItem>
            }
        </MudGrid>
    </div>
}
else
{
    <div class="cockpit-root">
        <MudStack Spacing="8">
            <MudText Typo="Typo.h4" Class="cockpit-page-title">Tender Overview</MudText>

            <MudPaper Elevation="0" Class="cockpit-global-slicers pa-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudSelect T="string"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Dense="true"
                               Label="Country"
                               Value="@_filterCountry"
                               ValueChanged="OnCountryChanged"
                               Class="cockpit-global-slicer">
                        <MudSelectItem Value="@string.Empty">All</MudSelectItem>
                        @foreach (var c in _filterCountries)
                        {
                            <MudSelectItem @key="c" Value="@c">@c</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="string"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Dense="true"
                               Label="Site"
                               Value="@_filterSite"
                               ValueChanged="OnSiteChanged"
                               Disabled="@(_filterSitesForCountry.Length == 0)"
                               Class="cockpit-global-slicer">
                        <MudSelectItem Value="@string.Empty">All</MudSelectItem>
                        @foreach (var s in _filterSitesForCountry)
                        {
                            <MudSelectItem @key="s" Value="@s">@s</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="string"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Dense="true"
                               Label="Material"
                               Value="@_filterMaterial"
                               ValueChanged="OnMaterialChanged"
                               Class="cockpit-global-slicer">
                        <MudSelectItem Value="@string.Empty">All</MudSelectItem>
                        @foreach (var m in _filterMaterials)
                        {
                            <MudSelectItem @key="m" Value="@m">@m</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="string"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Dense="true"
                               Label="Adhesive"
                               Value="@_filterAdhesive"
                               ValueChanged="OnAdhesiveChanged"
                               Class="cockpit-global-slicer">
                        <MudSelectItem Value="@string.Empty">All</MudSelectItem>
                        @foreach (var a in _filterAdhesives)
                        {
                            <MudSelectItem @key="a" Value="@a">@a</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSwitch T="bool"
                               dense="true"
                               Color="Color.Primary"
                               Value="@_synergyToggle"
                               ValueChanged="OnSynergyChanged">
                        Supplier synergy
                    </MudSwitch>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                <MudText Typo="Typo.subtitle2" Style="font-weight:700;">Strategic weights (sum 100%)</MudText>
                <MudText Typo="Typo.body2" Class="cockpit-muted">
                    Commercial @Session.Commercial% • Technical @Session.Technical% • Regulatory @Session.Regulatory%
                </MudText>

                @if (!string.IsNullOrWhiteSpace(_weightWarning))
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-2">
                        @_weightWarning
                    </MudAlert>
                }

                <MudStack Spacing="2" Class="mt-3" Style="max-width: 520px;">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Class="cockpit-muted">Commercial</MudText>
                        <MudSlider T="int"
                                   Min="0" Max="100" Step="1"
                                   Value="@Session.Commercial"
                                   ValueChanged="@(v => HandleWeightChange(Pillar.Commercial, v))"
                                   Immediate="true"
                                   valueLabelDisplay="ValueLabelDisplay.OnHover" />
                    </MudStack>

                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Class="cockpit-muted">Technical</MudText>
                        <MudSlider T="int"
                                   Min="0" Max="100" Step="1"
                                   Value="@Session.Technical"
                                   ValueChanged="@(v => HandleWeightChange(Pillar.Technical, v))"
                                   Immediate="true"
                                   valueLabelDisplay="ValueLabelDisplay.OnHover" />
                    </MudStack>

                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Class="cockpit-muted">Regulatory</MudText>
                        <MudSlider T="int"
                                   Min="0" Max="100" Step="1"
                                   Value="@Session.Regulatory"
                                   ValueChanged="@(v => HandleWeightChange(Pillar.Regulatory, v))"
                                   Immediate="true"
                                   valueLabelDisplay="ValueLabelDisplay.OnHover" />
                    </MudStack>
                </MudStack>
            </MudPaper>

            <MudTabs Rounded="true" Class="cockpit-tabs" ActivePanelIndex="@_activePanelIndex" ActivePanelIndexChanged="OnActivePanelChanged">
                <MudTabPanel Text="Dashboard">
                    <MudPaper Elevation="0" Class="cockpit-chart-shell pa-6 mt-4">
                        <MudText Typo="Typo.h6" Class="cockpit-section-title mb-1">Spend overview</MudText>
                        <MudText Typo="Typo.body2" Class="cockpit-muted mb-4">Commercial vs regulatory cost by supplier.</MudText>

                        <div class="cockpit-spend-wrap">
                            @{
                                var results = _tcoResults;
                                var svgH = (results.Count * 50) + 40;
                            }

                            <svg width="720"
                                 height="@svgH"
                                 viewBox="0 0 720 @svgH"
                                 class="cockpit-spend-svg">
                                @if (results.Count == 0)
                                {
                                    <svg:text x="360" y="160" text-anchor="middle" fill="rgba(45,52,54,0.65)">No suppliers selected</svg:text>
                                }
                                else
                                {
                                    @for (var idx = 0; idx < results.Count; idx++)
                                    {
                                        var r = results[idx];
                                        var yPos = (idx * 50) + 10;
                                        var x0 = 150.0;
                                        var barH = 30.0;
                                        var trackW = 600.0;
                                        var alpha = Math.Max(0.25, (double)r.FinalCtrScore / 100.0);

                                        <g opacity="@FmtSvg(alpha)">
                                            <title>@r.CalculationBreakdown</title>
                                            <rect x="@FmtSvg(x0)" y="@FmtSvg(yPos)" width="@FmtSvg(trackW)" height="@FmtSvg(barH)" fill="#f5f5f5" rx="4" />

                                            <rect x="@FmtSvg(x0)" y="@FmtSvg(yPos)" width="@FmtSvg(r.CommercialWidth)" height="@FmtSvg(barH)" fill="#91a363" rx="4" />
                                            <rect x="@FmtSvg(x0 + r.CommercialWidth)" y="@FmtSvg(yPos)" width="@FmtSvg(r.RegulatoryWidth)" height="@FmtSvg(barH)" fill="#FFB300" rx="4" />
                                            <rect x="@FmtSvg(x0 + r.CommercialWidth + r.RegulatoryWidth)" y="@FmtSvg(yPos)" width="@FmtSvg(r.SwitchingWidth)" height="@FmtSvg(barH)" fill="#D3D3D3" rx="4" />
                                            <rect x="@FmtSvg(x0 + r.CommercialWidth + r.RegulatoryWidth + r.SwitchingWidth)" y="@FmtSvg(yPos)" width="@FmtSvg(r.MoqWidth)" height="@FmtSvg(barH)" fill="#4682B4" rx="4" />

                                            <!-- Score badge -->
                                            <circle cx="@FmtSvg(12)" cy="@FmtSvg(yPos + 15)" r="@FmtSvg(10)" fill="rgba(45,52,54,0.10)" />
                                            <svg:text x="@FmtSvg(12)" y="@FmtSvg(yPos + 19)" text-anchor="middle" font-size="10" fill="#333" font-weight="700" font-family="monospace">
                                                @r.FinalCtrScore.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)
                                            </svg:text>

                                            <svg:text x="@FmtSvg(28)" y="@FmtSvg(yPos + 20)" font-size="12" fill="#333" font-weight="bold">@r.SupplierName</svg:text>

                                            <svg:text x="@FmtSvg(x0 + r.TotalWidth + 10)" y="@FmtSvg(yPos + 20)" font-size="12" font-family="monospace">
                                                @r.Total.ToString("N0", Da) kr.
                                            </svg:text>
                                        </g>
                                    }
                                }
                            </svg>
                        </div>

                        <div style="margin-top: 12px; display:flex; flex-wrap:wrap; gap: 14px; align-items:center;">
                            <div style="display:flex; align-items:center; gap: 8px;">
                                <span style="width:14px;height:14px;border-radius:3px;background:#91a363;display:inline-block;"></span>
                                <span>Aftalt pris (Indkøb)</span>
                            </div>
                            <div style="display:flex; align-items:center; gap: 8px;">
                                <span style="width:14px;height:14px;border-radius:3px;background:#4682B4;display:inline-block;"></span>
                                <span>Skjulte omkostninger (TCO-tillæg)</span>
                            </div>
                            <div style="color: rgba(45, 52, 54, 0.65);">
                                Gennemsigtighed indikerer strategisk CTR-match (Solid = Højt match, Transparent = Lavt match).
                            </div>
                        </div>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Price Matrix">
                    <PriceMatrix />
                </MudTabPanel>

                <MudTabPanel Text="Full Table">
                    <MudPaper Elevation="0" Class="cockpit-import-shell pa-3 mt-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.subtitle2" Style="font-weight:700;">Import Excel</MudText>
                            <InputFile OnChange="OnExcelSelected" accept=".xlsx" />
                            @if (!string.IsNullOrWhiteSpace(_importStatus))
                            {
                                <MudText Typo="Typo.caption" Class="cockpit-muted">@_importStatus</MudText>
                            }
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-slicer-bar pa-3 mt-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="cockpit-slicer-stack">
                            <MudTextField @bind-Value="_tableSearch"
                                          dense="true"
                                          Variant="Variant.Outlined"
                                          Placeholder="Search supplier / spec / sites"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Outlined.Search"
                                          Class="cockpit-slicer-search" />

                            <MudSelect T="string"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Label="Site"
                                       MultiSelection="true"
                                       SelectedValues="@_tableSitesSelected"
                                       SelectedValuesChanged="OnSitesSelectedChanged">
                                @foreach (var s in _tableSites)
                                {
                                    <MudSelectItem @key="s" Value="@s">@s</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="string"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Label="Material type"
                                       MultiSelection="true"
                                       SelectedValues="@_tableMaterialsSelected"
                                       SelectedValuesChanged="OnMaterialsSelectedChanged">
                                @foreach (var m in _tableMaterials)
                                {
                                    <MudSelectItem @key="m" Value="@m">@m</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="string"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Label="Supplier"
                                       MultiSelection="true"
                                       SelectedValues="@_tableSuppliersSelected"
                                       SelectedValuesChanged="OnSuppliersSelectedChanged">
                                @foreach (var s in _tableSupplierOptions)
                                {
                                    <MudSelectItem @key="s.Id" Value="@s.Id">@s.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudStack Spacing="0" Class="cockpit-slicer-range">
                                <MudText Typo="Typo.caption" Class="cockpit-muted">Weighted score</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudSlider T="int" Min="0" Max="100" Step="1" Value="@_scoreMin" ValueChanged="@(v => _scoreMin = Math.Min(v, _scoreMax))" Class="label-tender-slider-accent" valueLabelDisplay="ValueLabelDisplay.OnHover" />
                                    <MudText Typo="Typo.caption" Class="cockpit-num cockpit-num-muted">@_scoreMin</MudText>
                                    <MudText Typo="Typo.caption" Class="cockpit-muted">–</MudText>
                                    <MudText Typo="Typo.caption" Class="cockpit-num cockpit-num-muted">@_scoreMax</MudText>
                                    <MudSlider T="int" Min="0" Max="100" Step="1" Value="@_scoreMax" ValueChanged="@(v => _scoreMax = Math.Max(v, _scoreMin))" Class="label-tender-slider-accent" valueLabelDisplay="ValueLabelDisplay.OnHover" />
                                </MudStack>
                            </MudStack>
                        </MudStack>

                        @if (ActiveFilterChips.Count > 0)
                        {
                            <MudStack Row="true" Spacing="1" Class="mt-2 flex-wrap">
                                @foreach (var chip in ActiveFilterChips)
                                {
                                    <MudChip T="string" @key="chip" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@chip</MudChip>
                                }
                            </MudStack>
                        }
                    </MudPaper>

                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-grid-shell pa-0 mt-4">
                        <MudDataGrid T="SupplierPillarAnalysisRow"
                                     Items="@TableItems"
                                     Dense="true"
                                     Hover="true"
                                     Filterable="true"
                                     FilterMode="DataGridFilterMode.ColumnFilterRow"
                                     selectionMode="DataGridSelectionMode.Single"
                                     SelectedItem="@_tableSelectedRow"
                                     SelectedItemChanged="OnTableSelectedRowChanged"
                                     Class="cockpit-supplier-grid cockpit-supplier-grid--filter">
                            <Columns>
                                <HierarchyColumn T="SupplierPillarAnalysisRow" />

                                <PropertyColumn Property="x => x.Supplier.SupplierName" Title="Supplier" />
                                <PropertyColumn Property="x => x.Supplier.LabelType" Title="Type" />
                                <PropertyColumn Property="x => x.Supplier.Material" Title="Material" />
                                <PropertyColumn Property="x => x.Supplier.Adhesive" Title="Adhesive" />
                                <TemplateColumn Title="Sites / Locations" SortBy="@(x => string.Join(", ", x.Supplier.Sites))">
                                    <CellTemplate>
                                        <MudText Typo="Typo.body2" Class="d-block">@string.Join(", ", context.Item.Supplier.Sites)</MudText>
                                    </CellTemplate>
                                </TemplateColumn>

                                <TemplateColumn Title="Quantity (labels)">
                                    <CellTemplate>
                                        @{
                                            var isOutlier = IsOutlier(context.Item.Supplier.SupplierId, OutlierFieldQuantity);
                                            var cls = isOutlier ? "text-end d-block cockpit-outlier-cell" : "text-end d-block";
                                            var key = AnomalyKey(context.Item.Supplier.SupplierId, OutlierFieldQuantity);
                                        }
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1">
                                            <MudTooltip Text="@GetOutlierTooltip(context.Item.Supplier.SupplierId, OutlierFieldQuantity)" Disabled="@(!isOutlier)">
                                                <MudText Typo="Typo.body2" Class="@($"{cls} cockpit-num")">@context.Item.Supplier.QuantityLabels.ToString("N0", Da)</MudText>
                                            </MudTooltip>
                                            @if (isOutlier)
                                            {
                                                <MudMenu Dense="true" Icon="@Icons.Material.Outlined.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                                    <MudMenuItem OnClick="@(() => SetAnomalyStatus(key, AnomalyStatus.Accepted))">Accept</MudMenuItem>
                                                    <MudMenuItem OnClick="@(() => SetAnomalyStatus(key, AnomalyStatus.Excluded))">Exclude</MudMenuItem>
                                                    <MudMenuItem OnClick="@(() => SetAnomalyStatus(key, AnomalyStatus.Clarification))">Clarify</MudMenuItem>
                                                </MudMenu>
                                            }
                                        </MudStack>
                                    </CellTemplate>
                                </TemplateColumn>

                                <TemplateColumn Title="Price">
                                    <CellTemplate>
                                        @{
                                            var isOutlier = IsOutlier(context.Item.Supplier.SupplierId, OutlierFieldPrice) || IsExtremePrice(context.Item.Supplier.SupplierId);
                                            var cls = isOutlier ? "text-end d-block cockpit-outlier-cell" : "text-end d-block";
                                            var key = AnomalyKey(context.Item.Supplier.SupplierId, OutlierFieldPrice);
                                        }
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1">
                                            <MudTooltip Text="@GetPriceTooltip(context.Item.Supplier.SupplierId)" Disabled="@(!isOutlier)">
                                                <MudText Typo="Typo.body2" Class="@($"{cls} cockpit-num")">@context.Item.Supplier.Price.ToString("N2", Da)</MudText>
                                            </MudTooltip>
                                            @if (isOutlier)
                                            {
                                                <MudMenu Dense="true" Icon="@Icons.Material.Outlined.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                                    <MudMenuItem OnClick="@(() => SetAnomalyStatus(key, AnomalyStatus.Accepted))">Accept</MudMenuItem>
                                                    <MudMenuItem OnClick="@(() => SetAnomalyStatus(key, AnomalyStatus.Excluded))">Exclude</MudMenuItem>
                                                    <MudMenuItem OnClick="@(() => SetAnomalyStatus(key, AnomalyStatus.Clarification))">Clarify</MudMenuItem>
                                                </MudMenu>
                                            }
                                        </MudStack>
                                    </CellTemplate>
                                </TemplateColumn>

                                <PropertyColumn Property="x => x.Supplier.CommercialScore" Title="Commercial" />
                                <PropertyColumn Property="x => x.Supplier.TechnicalScore" Title="Technical" />
                                <PropertyColumn Property="x => x.Supplier.RegulatoryScore" Title="Regulatory" />

                                <TemplateColumn Title="Weighted score">
                                    <CellTemplate>
                                        <MudStack Spacing="0" Class="w-100">
                                            <MudProgressLinear Value="@((double)context.Item.TotalScore)"
                                                               Max="100"
                                                               Rounded="true"
                                                               Color="Color.Primary"
                                                               Class="cockpit-weighted-bar" />
                                            <MudText Typo="Typo.caption" Class="text-end cockpit-weighted-caption cockpit-num cockpit-num-muted">@FormatScore(context.Item.TotalScore)</MudText>
                                        </MudStack>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>

                            <ChildRowContent>
                                <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                    <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">Technical insight</MudText>

                                    <MudGrid Spacing="3">
                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.caption" Class="cockpit-muted">Quantity breakpoints</MudText>
                                            <MudSimpleTable Dense="true">
                                                <tbody>
                                                    <tr><td>1k</td><td class="text-end cockpit-num">@context.Item.Supplier.PriceAt1k.ToString("N2", Da)</td></tr>
                                                    <tr><td>5k</td><td class="text-end cockpit-num">@context.Item.Supplier.PriceAt5k.ToString("N2", Da)</td></tr>
                                                    <tr><td>10k</td><td class="text-end cockpit-num">@context.Item.Supplier.PriceAt10k.ToString("N2", Da)</td></tr>
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.caption" Class="cockpit-muted">AI summary (technical deviations)</MudText>
                                            @{
                                                var r = _tcoResults.FirstOrDefault(x =>
                                                    x.SupplierId.Equals(context.Item.Supplier.SupplierId, StringComparison.OrdinalIgnoreCase));
                                                var technicalSummary = r is null
                                                    ? "No technical deviations reported."
                                                    : r.TechnicalSummary;
                                            }
                                            <MudText Typo="Typo.body2" Class="cockpit-muted mt-1">@technicalSummary</MudText>
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.caption" Class="cockpit-muted">Logistics info</MudText>
                                            <MudText Typo="Typo.body2" Class="cockpit-muted mt-1">@context.Item.Supplier.LogisticsConstraints</MudText>
                                        </MudItem>
                                    </MudGrid>
                                </MudPaper>
                            </ChildRowContent>
                        </MudDataGrid>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Audit Board">
                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-audit-shell pa-5 mt-4">
                        <MudText Typo="Typo.h6" Class="cockpit-section-title mb-1">Audit Board</MudText>
                        <MudText Typo="Typo.body2" Class="cockpit-muted mb-4">Active clarifications flagged by the Digital Auditor.</MudText>

                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">Negotiation summary</MudText>
                        @if (!NegotiationSummary.Any())
                        {
                            <MudText Typo="Typo.body2" Class="cockpit-muted mb-4">No clarifications pending.</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="1" Class="mb-4">
                                @foreach (var group in NegotiationSummary)
                                {
                                    <MudPaper @key="group.SupplierName" Elevation="0" Outlined="true" Class="pa-3 cockpit-negotiation-card">
                                        <MudText Typo="Typo.body1" Style="font-weight:700;">@group.SupplierName</MudText>
                                        <MudList T="string" Dense="true">
                                            @foreach (var item in group.Items)
                                            {
                                                <MudListItem @key="item.Field" T="string">
                                                    <MudText Typo="Typo.body2">@item.Field — @item.Message</MudText>
                                                </MudListItem>
                                            }
                                        </MudList>
                                    </MudPaper>
                                }
                            </MudStack>
                        }

                        <MudTable T="AuditItem" Dense="true" Hover="true" Items="@AuditItems" Class="cockpit-audit-table">
                            <HeaderContent>
                                <MudTh>Supplier</MudTh>
                                <MudTh>Field</MudTh>
                                <MudTh>Flag</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>AI reasoning</MudTh>
                                <MudTh>Note</MudTh>
                                <MudTh class="text-end">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Supplier">@context.SupplierName</MudTd>
                                <MudTd DataLabel="Field">@context.Field</MudTd>
                                <MudTd DataLabel="Flag">
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Potential Unit Error</MudChip>
                                </MudTd>
                                <MudTd DataLabel="Status">
                                    <MudChip T="string"
                                             Color="@(context.Status is AnomalyStatus.Clarification ? Color.Warning : Color.Default)"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @context.Status.ToString()
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="AI reasoning" Style="min-width: 20rem;">
                                    <MudTextField T="string"
                                                  Value="@GetAuditReasoning(context.Key)"
                                                  ValueChanged="@( (string v) => SetAuditReasoning(context.Key, v) )"
                                                  Variant="Variant.Outlined"
