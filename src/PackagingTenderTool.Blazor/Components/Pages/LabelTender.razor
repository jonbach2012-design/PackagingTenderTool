    private static string GetCountryFromSite(string site)
    {
        if (string.IsNullOrWhiteSpace(site))
            return string.Empty;

        var dash = site.IndexOf('-');
        return dash > 0 ? site[..dash].ToUpperInvariant() : site.Length >= 2 ? site[..2].ToUpperInvariant() : site.ToUpperInvariant();
    }

    private void OnTableSelectedRowChanged(SupplierPillarAnalysisRow? v) => _tableSelectedRow = v;

    private async Task OnExcelSelected(InputFileChangeEventArgs e)
    {
        try
        {
            _importStatus = "Importing…";
            _importFlags.Clear();

            await using var fileStream = e.File.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024);
            await using var ms = new MemoryStream();
            await fileStream.CopyToAsync(ms);
            ms.Position = 0;

            // Importer expects a seekable stream. MemoryStream avoids "synchronous reads" crashes.
            var result = Importer.ImportTenderWithReport(ms);
            _importedLineItems = result.Tender.LabelLineItems.ToList();

            NormalizePricePerThousand(_importedLineItems);
            NormalizeMaterialWeights(_importedLineItems);
            BuildImportFlags(_importedLineItems);

            if (_importedLineItems.Count > 0)
            {
                _suppliersAll = BuildSuppliersFromImportedLines(_importedLineItems);

                // Keep "all suppliers selected" behavior when importing.
                if (Session.SelectedSuppliers.Count == 0)
                    Session.ReplaceSelectedSuppliers(_suppliersAll.Select(s => s.SupplierId).ToArray());

                RefreshData();
            }

            _importStatus = $"Imported {_importedLineItems.Count} rows • Flags: {_importFlags.Count}";
        }
        catch (Exception ex)
        {
            _importStatus = $"Import failed: {ex.Message}";
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private static void NormalizePricePerThousand(List<LabelLineItem> items)
    {
        foreach (var it in items)
        {
            if (it.PricePerThousand is > 0)
                continue;

            if (it.Price is not > 0)
                continue;

            if (!TryParsePcsPerRoll(it.ReelDiameterOrPcsPerRoll, out var pcsPerRoll) || pcsPerRoll <= 0m)
                continue;

            it.PricePerThousand = decimal.Round((it.Price.Value / pcsPerRoll) * 1000m, 2, MidpointRounding.AwayFromZero);
        }
    }

    private static void NormalizeMaterialWeights(List<LabelLineItem> items)
    {
        // Kronfågel fallback ratios: 60% front, 5% adhesive, 35% backing (when only total is provided).
        const decimal frontR = 0.60m;
        const decimal adhR = 0.05m;
        const decimal backR = 0.35m;

        foreach (var it in items)
        {
            if (it.LabelWeightGrams is not > 0m)
                continue;

            if (it.FrontWeightGrams is > 0m && it.AdhesiveWeightGrams is > 0m && it.BackingWeightGrams is > 0m)
                continue;

            var total = it.LabelWeightGrams.Value;
            it.FrontWeightGrams ??= decimal.Round(total * frontR, 4, MidpointRounding.AwayFromZero);
            it.AdhesiveWeightGrams ??= decimal.Round(total * adhR, 4, MidpointRounding.AwayFromZero);
            it.BackingWeightGrams ??= decimal.Round(total * backR, 4, MidpointRounding.AwayFromZero);
        }
    }

    private void BuildImportFlags(List<LabelLineItem> items)
    {
        var byItem = items
            .Where(i => !string.IsNullOrWhiteSpace(i.ItemNo) && i.PricePerThousand is > 0)
            .GroupBy(i => i.ItemNo!.Trim(), StringComparer.OrdinalIgnoreCase);

        foreach (var g in byItem)
        {
            var avg = g.Average(i => i.PricePerThousand!.Value);
            if (avg <= 0.0001m)
                continue;

            foreach (var it in g)
            {
                var ratio = it.PricePerThousand!.Value / avg;
                if (ratio > 1.5m || ratio < 0.5m)
                {
                    var supplier = it.SupplierName?.Trim() ?? "Unknown supplier";
                    var site = it.Site?.Trim() ?? "Unknown site";
                    var key = $"import|{g.Key}|{supplier}|{site}";

                    _importFlags.Add(new ImportUnitMismatchFlag(
                        key,
                        supplier,
                        g.Key,
                        site,
                        "Potential unit mismatch (>50% deviation from item average)."));

                    _anomalies.TryAdd(key, new AnomalyState(AnomalyStatus.Pending, note: string.Empty));
                }
            }
        }
    }

    private static bool TryParsePcsPerRoll(string? raw, out decimal pcsPerRoll)
    {
        pcsPerRoll = 0m;
        if (string.IsNullOrWhiteSpace(raw))
            return false;

        var span = raw.AsSpan();
        var buf = new char[span.Length];
        var bi = 0;
        var inNum = false;
        for (var i = 0; i < span.Length; i++)
        {
            var ch = span[i];
            if (char.IsDigit(ch) || ch is '.' or ',')
            {
                inNum = true;
                buf[bi++] = ch == ',' ? '.' : ch;
            }
            else if (inNum)
            {
                break;
            }
        }

        if (bi == 0)
            return false;

        return decimal.TryParse(new string(buf, 0, bi), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out pcsPerRoll);
    }

    private static List<SupplierModel> BuildSuppliersFromImportedLines(List<LabelLineItem> items)
    {
        string Slug(string s) => new string(s.ToLowerInvariant().Where(ch => char.IsLetterOrDigit(ch)).ToArray());

        return items
            .Where(i => !string.IsNullOrWhiteSpace(i.SupplierName))
            .GroupBy(i => i.SupplierName!.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(g =>
            {
                var qty = g.Sum(x => x.Quantity ?? 0m);
                var unit = g.Where(x => x.PricePerThousand is > 0).Select(x => x.PricePerThousand!.Value / 1000m).DefaultIfEmpty(0m).Average();
                var sites = g.Select(x => x.Site).Where(s => !string.IsNullOrWhiteSpace(s)).Select(s => s!.Trim()).Distinct(StringComparer.OrdinalIgnoreCase).ToArray();
                var country = sites.Length > 0 ? (GetCountryFromSite(sites[0]) is { Length: > 0 } c ? c : DeriveCountryFromSiteName(sites[0])) : "DK";
                if (string.IsNullOrWhiteSpace(country))
                    country = "DK";
                var weight = g.Select(x =>
                        (x.FrontWeightGrams ?? 0m) + (x.AdhesiveWeightGrams ?? 0m) + (x.BackingWeightGrams ?? 0m))
                    .DefaultIfEmpty(0m)
                    .Average();
                if (weight <= 0m)
                    weight = g.Select(x => x.LabelWeightGrams ?? 0m).DefaultIfEmpty(0m).Average();

                return new SupplierModel
                {
                    SupplierId = Slug(g.Key),
                    SupplierName = g.Key,
                    Sites = sites,
                    Country = country,
                    QuantityLabels = qty,
                    Price = unit,
                    LabelWeightGramsPerUnit = weight,
                    Material = g.Select(x => x.Material).FirstOrDefault(m => !string.IsNullOrWhiteSpace(m))?.Trim() ?? string.Empty,
                    LabelType = "Imported",
                    Adhesive = string.Empty,
                    PriceAt1k = unit,
                    PriceAt5k = unit,
                    PriceAt10k = unit,
                    SupplierComments = g.Select(x => x.Comment).FirstOrDefault(c => !string.IsNullOrWhiteSpace(c))?.Trim() ?? string.Empty,
                    LogisticsConstraints = string.Empty,
                    CommercialScore = 70m,
                    TechnicalScore = decimal.Round(g.Average(x => x.TechnicalRating ?? 0m), 0, MidpointRounding.AwayFromZero),
                    RegulatoryScore = 70m
                };
            })
            .ToList();
    }

    private static string DeriveCountryFromSiteName(string site)
    {
        if (string.IsNullOrWhiteSpace(site))
            return string.Empty;

        var s = site.Trim();
        // DSH-style known site names -> ISO-ish codes used in this app.
        if (s.Contains("Jæren", StringComparison.OrdinalIgnoreCase))
            return "NO";
        if (s.Contains("Jaeren", StringComparison.OrdinalIgnoreCase))
            return "NO";
        if (s.Contains("Norway", StringComparison.OrdinalIgnoreCase) || s.Contains("Norge", StringComparison.OrdinalIgnoreCase))
            return "NO";
        if (s.Contains("Denmark", StringComparison.OrdinalIgnoreCase) || s.Contains("Danmark", StringComparison.OrdinalIgnoreCase))
            return "DK";
        if (s.Contains("Sweden", StringComparison.OrdinalIgnoreCase) || s.Contains("Sverige", StringComparison.OrdinalIgnoreCase))
            return "SE";
        if (s.Contains("Finland", StringComparison.OrdinalIgnoreCase))
            return "FI";

        return string.Empty;
    }

    private decimal GetSkuCountForScope()
    {
        // Scope-driven SKU count for base switching costs.
        if (_importedLineItems.Count == 0)
            return 3m;

        IEnumerable<LabelLineItem> q = _importedLineItems;

        if (!string.IsNullOrWhiteSpace(_filterSite))
            q = q.Where(i => string.Equals(i.Site, _filterSite, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(_filterMaterial))
            q = q.Where(i => string.Equals(i.Material, _filterMaterial, StringComparison.OrdinalIgnoreCase));

        // Adhesive is not a first-class column in the current import, so we cannot filter by it here yet.
        // Keep SKU count robust and deterministic.

        return Math.Max(1m, q
            .Select(i => i.ItemNo?.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count());
    }

    private void RefreshData()
    {
        if (_isCalculating)
            return;

        _isCalculating = true;
        try
        {
            if (Session.SelectedProfile != PackagingProfileSession.ProfileLabels)
            {
                _suppliersAll = [];
                _suppliersSelected = [];
                _pillarRows = [];
                _tableRows = [];
                return;
            }

            // If an import has occurred, keep the imported supplier view; otherwise use demo suppliers.
            if (_suppliersAll.Count == 0 || _importedLineItems.Count == 0)
            {
                _suppliersAll = LabelTenderDemoSupplierData.Create().ToList();
            }

            _filterCountries = _suppliersAll
                .SelectMany(s => s.Sites)
                .Select(GetCountryFromSite)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(c => c, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            if (!string.IsNullOrWhiteSpace(_filterCountry) && !_filterCountries.Contains(_filterCountry, StringComparer.OrdinalIgnoreCase))
                _filterCountry = string.Empty;

            _filterSitesForCountry = _suppliersAll
                .SelectMany(s => s.Sites)
                .Where(site => string.IsNullOrWhiteSpace(_filterCountry) || string.Equals(GetCountryFromSite(site), _filterCountry, StringComparison.OrdinalIgnoreCase))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            if (!string.IsNullOrWhiteSpace(_filterSite) && !_filterSitesForCountry.Contains(_filterSite, StringComparer.OrdinalIgnoreCase))
                _filterSite = string.Empty;

            _filterMaterials = _suppliersAll
                .Select(s => s.Material)
                .Where(m => !string.IsNullOrWhiteSpace(m))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(m => m, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            if (!string.IsNullOrWhiteSpace(_filterMaterial) && !_filterMaterials.Contains(_filterMaterial, StringComparer.OrdinalIgnoreCase))
                _filterMaterial = string.Empty;

            _filterAdhesives = _suppliersAll
                .Select(s => s.Adhesive)
                .Where(a => !string.IsNullOrWhiteSpace(a))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(a => a, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            if (!string.IsNullOrWhiteSpace(_filterAdhesive) && !_filterAdhesives.Contains(_filterAdhesive, StringComparer.OrdinalIgnoreCase))
                _filterAdhesive = string.Empty;

            var suppliersFiltered = _suppliersAll
                .Where(s =>
                    (string.IsNullOrWhiteSpace(_filterCountry) || s.Sites.Any(site => string.Equals(GetCountryFromSite(site), _filterCountry, StringComparison.OrdinalIgnoreCase)))
                    && (string.IsNullOrWhiteSpace(_filterSite) || s.Sites.Any(site => string.Equals(site, _filterSite, StringComparison.OrdinalIgnoreCase)))
                    && (string.IsNullOrWhiteSpace(_filterMaterial) || string.Equals(s.Material, _filterMaterial, StringComparison.OrdinalIgnoreCase))
                    && (string.IsNullOrWhiteSpace(_filterAdhesive) || string.Equals(s.Adhesive, _filterAdhesive, StringComparison.OrdinalIgnoreCase)))
                .ToList();

            // Seed supplier settings defaults (archetype values come from demo SupplierModel).
            foreach (var s in suppliersFiltered)
            {
                Session.SeedSupplierDefaults(
                    supplierId: s.SupplierId,
                    grade: s.RecyclingGrade ?? RecyclingGrade.C,
                    startupCost: s.StartupCost,
                    monthlySupportCost: s.MonthlySupportCost,
                    moqPenaltyPct: s.MoqPenaltyPct);
            }

            _outliers = SupplierOutlierDetection.Detect(suppliersFiltered);

            // Defensive: prune stale keys before generating new in-memory state.
            PruneAuditMaps();

            // CRITICAL: Clear + TryAdd only when repopulating anomalies.
            RebuildAnomalies();

            Session.SetPendingClarificationsCount(_anomalies.Values.Count(a => a.Status is AnomalyStatus.Pending or AnomalyStatus.Clarification));

            _tableSites = suppliersFiltered.SelectMany(s => s.Sites).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s, StringComparer.OrdinalIgnoreCase).ToArray();
            _tableMaterials = suppliersFiltered.Select(s => s.Material).Where(m => !string.IsNullOrWhiteSpace(m)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(m => m, StringComparer.OrdinalIgnoreCase).ToArray();
            _tableSupplierOptions = suppliersFiltered
                .Where(s => !string.IsNullOrWhiteSpace(s.SupplierId))
                .GroupBy(s => s.SupplierId, StringComparer.OrdinalIgnoreCase)
                .Select(g => g.First())
                .Select(s => new SupplierOption(s.SupplierId, s.SupplierName))
                .OrderBy(s => s.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            var selected = Session.SelectedSuppliers;
            _suppliersSelected = selected.Count == 0
                ? []
                : suppliersFiltered.Where(s => selected.Contains(s.SupplierId)).ToList();

            _pillarRows = SupplierPillarAnalysis.BuildOrdered(
                    _suppliersSelected,
                    Session.Commercial,
                    Session.Technical,
                    Session.Regulatory)
                .ToList();

            _tableRows = SupplierPillarAnalysis.BuildOrdered(
                    suppliersFiltered,
                    Session.Commercial,
                    Session.Technical,
                    Session.Regulatory)
                .ToList();

            _tcoResults.Clear();
            _tcoResults.AddRange(TcoEngine.GetResults(Session, _suppliersSelected));
        }
        finally
        {
            _isCalculating = false;
        }
    }

    // Spend overview: keep single source of truth for spend rows + horizontal stacked SVG.

    private static string FmtSvg(double v) =>
        v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private static string FmtSvg(int v) =>
        v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private void RecordWeightHistory()
    {
        var msg = $"Weight change — Commercial {Session.Commercial}% • Technical {Session.Technical}% • Regulatory {Session.Regulatory}%";
        if (_history.Count == 0 || !_history[0].Message.Equals(msg, StringComparison.Ordinal))
        {
            _history.Insert(0, new HistoryEntry(DateTimeOffset.Now, msg));
        }
    }

    private enum Pillar
    {
        Commercial = 0,
        Technical = 1,
        Regulatory = 2
    }

    private bool _suppressSessionChanged;
    private string _weightWarning = string.Empty;

    private void HandleWeightChange(Pillar pillar, int value)
    {
        if (_isCalculating)
            return;

        // Avoid double recompute: session setters raise Session.Changed.
        _suppressSessionChanged = true;
        try
        {
            switch (pillar)
            {
                case Pillar.Commercial:
                    Session.SetCommercial(value);
                    break;
                case Pillar.Technical:
                    Session.SetTechnical(value);
                    break;
                default:
                    Session.SetRegulatory(value);
                    break;
            }
        }
        finally
        {
            _suppressSessionChanged = false;
        }

        var sum = Session.PillarSum;
        _weightWarning = sum > 100
            ? $"Warning: weights sum to {sum}% (> 100%). Reduce one pillar."
            : sum < 100
                ? $"Warning: weights sum to {sum}% (< 100%)."
                : string.Empty;

        // Force recalculation and immediate visual update (SVG widths + opacity depend on results).
        RefreshData();
        _ = InvokeAsync(StateHasChanged);
    }

    private IEnumerable<AuditItem> AuditItems
    {
        get
        {
            foreach (var f in _importFlags)
            {
                var status = _anomalies.TryGetValue(f.Key, out var st) ? st.Status : AnomalyStatus.Pending;
                _auditReasoning.TryAdd(f.Key, "Likely unit mismatch (pcs/roll or price-per-1000 normalization).");
                _auditNotes.TryAdd(f.Key, string.Empty);
                yield return new AuditItem(f.SupplierName, $"{f.ItemNo} • {f.Site}", f.Key, status, f.Message);
            }

            foreach (var kvp in _outliers.BySupplierId)
            {
                foreach (var f in kvp.Value)
                {
                    var key = $"{kvp.Key}|{f.Field}";
                    _auditNotes.TryAdd(key, string.Empty);
                    _auditReasoning.TryAdd(key, DefaultReasoning(f.SupplierName, f.Field, f.Message));
                    var status = _anomalies.TryGetValue(key, out var st) ? st.Status : AnomalyStatus.Pending;
                    yield return new AuditItem(f.SupplierName, f.Field, key, status, f.Message);
                }
            }
        }
    }

    private void Decide(string key, string decision)
    {
        _auditDecisions[key] = decision;
        var note = _auditNotes.TryGetValue(key, out var n) ? n : string.Empty;
        var msg = string.IsNullOrWhiteSpace(note)
            ? $"Decision: {decision} — {key}"
            : $"Decision: {decision} — {key} — Note: {note}";
        _history.Insert(0, new HistoryEntry(DateTimeOffset.Now, msg));
        StateHasChanged();
    }

    private void AuditAccept(string key)
    {
        SetAnomalyStatus(key, AnomalyStatus.Accepted);
        Decide(key, "Accept");
    }

    private void AuditReject(string key)
    {
        SetAnomalyStatus(key, AnomalyStatus.Excluded);
        Decide(key, "Exclude");
    }

    private void AuditClarify(string key)
    {
        SetAnomalyStatus(key, AnomalyStatus.Clarification);
        Decide(key, "Clarify");
    }

    private IEnumerable<NegotiationGroup> NegotiationSummary =>
        _outliers.BySupplierId
            .Select(kvp => new NegotiationGroup(
                kvp.Value.FirstOrDefault()?.SupplierName ?? kvp.Key,
                kvp.Value
                    .Where(f => _anomalies.TryGetValue($"{kvp.Key}|{f.Field}", out var st) && st.Status == AnomalyStatus.Clarification)
                    .Select(f => new NegotiationItem(f.Field, f.Message))
                    .ToList()))
            .Where(g => g.Items.Count > 0)
            .OrderBy(g => g.SupplierName, StringComparer.OrdinalIgnoreCase);

    private sealed record NegotiationGroup(string SupplierName, List<NegotiationItem> Items);

    private sealed record NegotiationItem(string Field, string Message);

    private sealed record AuditItem(string SupplierName, string Field, string Key, AnomalyStatus Status, string Message);

    private sealed record ImportUnitMismatchFlag(string Key, string SupplierName, string ItemNo, string Site, string Message);

    private sealed record HistoryEntry(DateTimeOffset Timestamp, string Message);

    private IEnumerable<SupplierPillarAnalysisRow> TableItems
    {
        get
        {
            IEnumerable<SupplierPillarAnalysisRow> q = _tableRows;

            if (_tableMaterialsSelected.Count > 0)
                q = q.Where(r => _tableMaterialsSelected.Contains(r.Supplier.Material));

            if (_tableSitesSelected.Count > 0)
                q = q.Where(r => r.Supplier.Sites.Any(s => _tableSitesSelected.Contains(s)));

            if (_tableSuppliersSelected.Count > 0)
                q = q.Where(r => _tableSuppliersSelected.Contains(r.Supplier.SupplierId));

            if (!string.IsNullOrWhiteSpace(_tableSearch))
            {
                var term = _tableSearch.Trim();
                q = q.Where(r =>
                    r.Supplier.SupplierName.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || r.Supplier.LabelType.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || r.Supplier.Material.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || r.Supplier.Adhesive.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || r.Supplier.Sites.Any(s => s.Contains(term, StringComparison.OrdinalIgnoreCase)));
            }

            q = q.Where(r => r.TotalScore >= _scoreMin && r.TotalScore <= _scoreMax);

            return q;
        }
    }

    private List<string> ActiveFilterChips
    {
        get
        {
            var chips = new List<string>();
            chips.AddRange(_tableSitesSelected.OrderBy(s => s, StringComparer.OrdinalIgnoreCase).Select(s => $"Site: {s}"));
            chips.AddRange(_tableMaterialsSelected.OrderBy(s => s, StringComparer.OrdinalIgnoreCase).Select(s => $"Material: {s}"));
            chips.AddRange(_tableSuppliersSelected
                .Select(id => _tableSupplierOptions.FirstOrDefault(s => s.Id.Equals(id, StringComparison.OrdinalIgnoreCase))?.Name ?? id)
                .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
                .Select(s => $"Supplier: {s}"));
            if (_scoreMin != 0 || _scoreMax != 100)
                chips.Add($"Score: {_scoreMin}–{_scoreMax}");
            if (!string.IsNullOrWhiteSpace(_tableSearch))
                chips.Add($"Search: {_tableSearch.Trim()}");
            return chips;
        }
    }

    private sealed record SupplierOption(string Id, string Name);

