    private bool _suppressSessionChanged;
    private string _weightWarning = string.Empty;

    private void HandleWeightChange(Pillar pillar, int value)
    {
        if (_isCalculating)
            return;

        // Avoid double recompute: session setters raise Session.Changed.
        _suppressSessionChanged = true;
        try
        {
            switch (pillar)
            {
                case Pillar.Commercial:
                    Session.SetCommercial(value);
                    break;
                case Pillar.Technical:
                    Session.SetTechnical(value);
                    break;
                default:
                    Session.SetRegulatory(value);
                    break;
            }
        }
        finally
        {
            _suppressSessionChanged = false;
        }

        var sum = Session.PillarSum;
        _weightWarning = sum > 100
            ? $"Warning: weights sum to {sum}% (> 100%). Reduce one pillar."
            : sum < 100
                ? $"Warning: weights sum to {sum}% (< 100%)."
                : string.Empty;

        // Force recalculation and immediate visual update (SVG widths + opacity depend on results).
        RefreshData();
        _ = InvokeAsync(StateHasChanged);
    }

    private IEnumerable<AuditItem> AuditItems
    {
        get
        {
            foreach (var f in _importFlags)
            {
                var status = _anomalies.TryGetValue(f.Key, out var st) ? st.Status : AnomalyStatus.Pending;
                _auditReasoning.TryAdd(f.Key, "Likely unit mismatch (pcs/roll or price-per-1000 normalization).");
                _auditNotes.TryAdd(f.Key, string.Empty);
                yield return new AuditItem(f.SupplierName, $"{f.ItemNo} • {f.Site}", f.Key, status, f.Message);
            }

            foreach (var kvp in _outliers.BySupplierId)
            {
                foreach (var f in kvp.Value)
                {
                    var key = $"{kvp.Key}|{f.Field}";
                    _auditNotes.TryAdd(key, string.Empty);
                    _auditReasoning.TryAdd(key, DefaultReasoning(f.SupplierName, f.Field, f.Message));
                    var status = _anomalies.TryGetValue(key, out var st) ? st.Status : AnomalyStatus.Pending;
                    yield return new AuditItem(f.SupplierName, f.Field, key, status, f.Message);
                }
            }
        }
    }

    private void Decide(string key, string decision)
    {
        _auditDecisions[key] = decision;
        var note = _auditNotes.TryGetValue(key, out var n) ? n : string.Empty;
        var msg = string.IsNullOrWhiteSpace(note)
            ? $"Decision: {decision} — {key}"
            : $"Decision: {decision} — {key} — Note: {note}";
        _history.Insert(0, new HistoryEntry(DateTimeOffset.Now, msg));
        StateHasChanged();
    }

    private void AuditAccept(string key)
    {
        SetAnomalyStatus(key, AnomalyStatus.Accepted);
        Decide(key, "Accept");
    }

    private void AuditReject(string key)
    {
        SetAnomalyStatus(key, AnomalyStatus.Excluded);
        Decide(key, "Exclude");
    }

    private void AuditClarify(string key)
    {
        SetAnomalyStatus(key, AnomalyStatus.Clarification);
        Decide(key, "Clarify");
    }

