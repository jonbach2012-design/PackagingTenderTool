@page "/labeltender"
@implements IDisposable

@using System.Globalization
@using System.Linq
@using System.Collections.Concurrent
@using PackagingTenderTool.Core.Models
@using PackagingTenderTool.Core.Services.LabelTenderScoring
@using PackagingTenderTool.Core.Import
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Logging
@using MudBlazor
@using PackagingTenderTool.Blazor.Components.LabelTender
@using PackagingTenderTool.Blazor.Models.LabelTender
@using PackagingTenderTool.Blazor.Services
@using Radzen
@using Radzen.Blazor

@inject PackagingProfileSession Session
@inject NavigationManager Nav
@inject LabelsExcelImportService Importer
@inject PivotLabelsExcelImportService PivotImporter
@inject PackagingTenderTool.Core.Import.TenderPriceAnalyzeImportService PriceAnalyzeImporter
@inject PackagingTenderTool.Blazor.Services.ITcoEngineService TcoEngine
@inject PackagingTenderTool.Blazor.Services.LabelTenderSidebarBridge SidebarBridge
@inject ISnackbar Snackbar
@inject ILogger<LabelTender> Logger

@if (Session.SelectedProfile is null)
{
    <div class="profile-landing" style="min-height: calc(100vh - 64px); display: flex; flex-direction: column; align-items: center; justify-content: center; background: #ffffff;">
        <MudText Typo="Typo.h3" Class="profile-landing-title mb-10" Style="color: #485230; font-weight: 700;">
            Select Packaging Profile
        </MudText>

        <MudGrid Class="label-tender-profile-grid label-tender-profile-grid--landing" Spacing="4" Style="max-width: 800px; width: 100%;">
            @foreach (var name in _profiles)
            {
                var isLabels = name == PackagingProfileSession.ProfileLabels;
                <MudItem xs="12" sm="4">
                    @if (isLabels)
                    {
                        <MudCard Elevation="0"
                                 Outlined="true"
                                 Class="label-tender-card label-tender-card--labels pa-6"
                                 Style="border-color: #485230; cursor: pointer;"
                                 @onclick="SelectLabels">
                            <MudCardContent Class="pa-0 d-flex align-center justify-center" Style="min-height: 5rem;">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">@name</MudText>
                            </MudCardContent>
                        </MudCard>
                    }
                    else
                    {
                        <MudCard Elevation="0" Outlined="true" Class="label-tender-card label-tender-card--faded pa-6" Style="opacity: 0.4;">
                            <MudCardContent Class="pa-0 d-flex align-center justify-center" Style="min-height: 5rem;">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">@name</MudText>
                            </MudCardContent>
                        </MudCard>
                    }
                </MudItem>
            }
        </MudGrid>
    </div>
}
else
{
    <MudStack Spacing="6" Class="cockpit-main-stack cockpit-page-main">
                @if (_activeTab == "settings")
                {
                    <MudText Typo="Typo.h6" Class="mb-4">Scoring konfiguration</MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Kommerciel</b></MudText>
                                    <MudDivider Class="mb-3" />
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                                            <MudText Typo="Typo.body2">Vægt</MudText>
                                            <MudText Typo="Typo.body2"><b>@Session.Commercial%</b></MudText>
                                        </MudStack>
                                        <MudSlider T="int" Min="0" Max="100" Step="5"
                                                   Value="@Session.Commercial"
                                                   ValueChanged="@(v => { Session.SetCommercial(v); RefreshData(); StateHasChanged(); })"
                                                   Color="Color.Success" />
                                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Valuta</MudText><MudText Typo="Typo.body2"><b>DKK</b></MudText></MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Prisindeks</MudText><MudChip T="string" Size="Size.Small" Disabled="true">Fremtidig</MudChip></MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">MOQ justering</MudText><MudChip T="string" Size="Size.Small" Disabled="true">Fremtidig</MudChip></MudStack>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Teknisk</b></MudText>
                                    <MudDivider Class="mb-3" />
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                                            <MudText Typo="Typo.body2">Vægt</MudText>
                                            <MudText Typo="Typo.body2"><b>@Session.Technical%</b></MudText>
                                        </MudStack>
                                        <MudSlider T="int" Min="0" Max="100" Step="5"
                                                   Value="@Session.Technical"
                                                   ValueChanged="@(v => { Session.SetTechnical(v); RefreshData(); StateHasChanged(); })"
                                                   Color="Color.Success" />
                                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Profil</MudText><MudText Typo="Typo.body2"><b>Labels v1</b></MudText></MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Leverandør risiko</MudText><MudChip T="string" Size="Size.Small" Disabled="true">Fremtidig</MudChip></MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">Cirkularitet index</MudText><MudChip T="string" Size="Size.Small" Disabled="true">Fremtidig</MudChip></MudStack>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Regulatorisk</b></MudText>
                                    <MudDivider Class="mb-3" />
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                                            <MudText Typo="Typo.body2">Vægt</MudText>
                                            <MudText Typo="Typo.body2"><b>@Session.Regulatory%</b></MudText>
                                        </MudStack>
                                        <MudSlider T="int" Min="0" Max="100" Step="5"
                                                   Value="@Session.Regulatory"
                                                   ValueChanged="@(v => { Session.SetRegulatory(v); RefreshData(); StateHasChanged(); })"
                                                   Color="Color.Success" />
                                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">PPWR multiplier</MudText><MudText Typo="Typo.body2"><b>Aktiv</b></MudText></MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">EPR fee model</MudText><MudText Typo="Typo.body2"><b>Standard</b></MudText></MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.body2">PPWR Risk index</MudText><MudChip T="string" Size="Size.Small" Disabled="true">Fremtidig</MudChip></MudStack>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                        <MudItem xs="12">
                            <MudCard Elevation="1">
                                <MudCardContent>
                                    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Tender konfiguration</b></MudText>
                                    <MudDivider Class="mb-3" />
                                    <MudGrid Spacing="2">
                                        <MudItem xs="4"><MudStack Spacing="0"><MudText Typo="Typo.caption" Color="Color.Secondary">Tender navn</MudText><MudText Typo="Typo.body2"><b>@(SidebarBridge.LastImportedFileName ?? "—")</b></MudText></MudStack></MudItem>
                                        <MudItem xs="4"><MudStack Spacing="0"><MudText Typo="Typo.caption" Color="Color.Secondary">Pakkeprodukt profil</MudText><MudText Typo="Typo.body2"><b>Labels v1</b></MudText></MudStack></MudItem>
                                        <MudItem xs="4"><MudStack Spacing="0"><MudText Typo="Typo.caption" Color="Color.Secondary">Scenario analyse</MudText><MudChip T="string" Size="Size.Small" Disabled="true">Fremtidig</MudChip></MudStack></MudItem>
                                    </MudGrid>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                }
                else if (_importedLineItems.Count == 0)
                {
                    <div class="cockpit-empty-state">
                        <MudIcon Icon="@Icons.Material.Outlined.UploadFile" 
                                 Style="font-size:72px;" />
                        <MudText Typo="Typo.h5">No data imported yet</MudText>
                        <MudText Typo="Typo.body1">Use <strong>Select file</strong> on the left to import a tender</MudText>
                    </div>
                }
                else
                {

                @if (!string.IsNullOrWhiteSpace(_weightWarning))
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                        @_weightWarning
                    </MudAlert>
                }

                @if (_activeTab == "dashboard")
                {
                    var bubbleResults = _tcoResults;
                        var lineCountBySupplierB = _importedLineItems
                            .Where(i => !string.IsNullOrWhiteSpace(i.SupplierName))
                            .GroupBy(i => i.SupplierName!.Trim(), StringComparer.OrdinalIgnoreCase)
                            .ToDictionary(g => g.Key, g => g.Count(), StringComparer.OrdinalIgnoreCase);

                        var maxSpend = bubbleResults.Count > 0
                            ? (double)bubbleResults.Max(r => r.Commercial)
                            : 1.0;
                        var maxLines = lineCountBySupplierB.Count > 0
                            ? lineCountBySupplierB.Values.Max()
                            : 1;

                        const int svgW = 700;
                        const int svgH = 420;
                        const int padL = 64;
                        const int padR = 24;
                        const int padT = 24;
                        const int padB = 64;
                        int plotW = svgW - padL - padR;
                        int plotH = svgH - padT - padB;

                        double ScaleX(double spend) => padL + (maxSpend > 0 ? spend / maxSpend * plotW : 0);
                        double ScaleY(double ctr) => padT + plotH - (ctr / 100.0 * plotH);
                        double BubbleR(string name)
                        {
                            var lc = lineCountBySupplierB.TryGetValue(name, out var v) ? v : 1;
                            return 14 + (double)lc / maxLines * 28;
                        }
                        string BubbleColor(decimal ctr) => ctr >= 68 ? "#485230" : ctr >= 48 ? "#6b7c3f" : "#c0392b";
                        string FmtSpend(decimal spend) => spend >= 1_000_000m
                            ? $"{(spend / 1_000_000m).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}M kr"
                            : spend >= 1_000m
                            ? $"{(spend / 1_000m).ToString("F0", System.Globalization.CultureInfo.InvariantCulture)}K kr"
                            : $"{spend.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)} kr";
                        var yAxisMid = padT + plotH / 2.0;

                        var suppliers = bubbleResults.ToList();
                        var positions = new Dictionary<string, (double cx, double cy)>();
                        foreach (var r in suppliers)
                        {
                            var baseCx = ScaleX((double)r.Commercial);
                            var baseCy = ScaleY((double)r.FinalCtrScore);
                            var finalCx = baseCx;
                            var finalCy = baseCy;
                            int attempt = 0;
                            while (positions.Values.Any(p =>
                                Math.Abs(p.cx - finalCx) < 40 && Math.Abs(p.cy - finalCy) < 40)
                                && attempt < 8)
                            {
                                finalCx = baseCx + (attempt % 3 - 1) * 45;
                                finalCy = baseCy + (attempt / 3 - 1) * 35;
                                attempt++;
                            }
                            positions[r.SupplierName] = (finalCx, finalCy);
                        }

                    @* ROW 1 — bar chart (primary) + CTR info *@
                    <div class="cockpit-dashboard-grid"
                         style="display:grid; grid-template-columns:minmax(0,1fr) minmax(240px,300px);
                                gap:24px; padding:24px 8px 0; align-items:start;">

                        <div style="min-width:0; width:100%;">
                            <MudText Typo="Typo.h5" Class="mb-1"
                                     Style="text-align:left; color:#485230; font-weight:600;">
                                Supplier spend overview
                            </MudText>
                            <MudText Typo="Typo.body2" Class="cockpit-muted mb-3">
                                Total spend per leverandør på tværs af hele pakken.
                                Leverandører uden bud på alle linjer suppleres med nuværende kontraktpris.
                            </MudText>

                            @if (_tcoResults.Count == 0)
                            {
                                <MudPaper Elevation="0" Outlined="true" Class="pa-6"
                                          Style="text-align:center; color:rgba(45,52,54,0.45);">
                                    Import suppliers to see spend chart
                                </MudPaper>
                            }
                            else
                            {
                                var barData = _tcoResults
                                    .Select(r =>
                                    {
                                        var imputed = _imputedSpend.TryGetValue(r.SupplierName, out var s)
                                            ? s : null;
                                        var spend = r.Commercial;
                                        var bidLines = imputed?.BidLineCount ?? 0;
                                        var totalLines = imputed?.TotalLineCount ?? 0;
                                        var incomplete = imputed?.IsIncompleteBid ?? false;
                                        return new
                                        {
                                            r.SupplierName,
                                            Spend = spend,
                                            BidLines = bidLines,
                                            TotalLines = totalLines,
                                            IsIncompleteBid = incomplete,
                                            r.FinalCtrScore
                                        };
                                    })
                                    .OrderByDescending(x => x.Spend)
                                    .ToList();

                                var baselineTotal = (double)_bestBidBaseline.Values.Sum();
                                var supplierNames = barData.Select(x => x.SupplierName).ToList();
                                var baselinePoints = supplierNames
                                    .Select(name => new { SupplierName = name, Value = baselineTotal })
                                    .ToList();
                                var currentContractTotal = (double)_currentContractBaseline.Values
                                    .DefaultIfEmpty(0m).Sum();
                                var contractPoints = currentContractTotal > 0
                                    ? supplierNames
                                        .Select(name => new { SupplierName = name, Value = currentContractTotal })
                                        .ToList()
                                    : null;

                                <RadzenChart Style="height:320px; width:100%;"
                                             SeriesClick="OnBarChartSeriesClick">
                                    <RadzenColumnSeries Data="@barData"
                                                        CategoryProperty="SupplierName"
                                                        ValueProperty="Spend"
                                                        Title="Estimeret spend"
                                                        Fill="#6b7c3f"
                                                        Stroke="#485230"
                                                        StrokeWidth="1">
                                        <TooltipTemplate Context="item">
                                            <div style="padding:8px; min-width:180px;">
                                                <strong>@item.SupplierName</strong><br />
                                                <span>Spend: @item.Spend.ToString("N0", Da) kr</span><br />
                                                <span>Lines bid: @item.BidLines / @item.TotalLines</span><br />
                                                @if (item.IsIncompleteBid)
                                                {
                                                    <span style="color:#FFB300;">&#9888; Incomplete bid</span>
                                                }
                                            </div>
                                        </TooltipTemplate>
                                        <ChildContent>
                                            <RadzenSeriesDataLabels Visible="true" />
                                        </ChildContent>
                                    </RadzenColumnSeries>

                                    @if (baselineTotal > 0)
                                    {
                                        <RadzenLineSeries Data="@baselinePoints"
                                                          CategoryProperty="SupplierName"
                                                          ValueProperty="Value"
                                                          Title="Best bid baseline"
                                                          Stroke="#c0392b"
                                                          StrokeWidth="2"
                                                          LineType="LineType.Dashed">
                                            <ChildContent>
                                                <RadzenMarkers Visible="false" />
                                            </ChildContent>
                                            <TooltipTemplate Context="item">
                                                <span>Best bid baseline: @_bestBidBaseline.Values.Sum().ToString("N0", Da) kr</span>
                                            </TooltipTemplate>
                                        </RadzenLineSeries>
                                    }

                                    @if (contractPoints is not null)
                                    {
                                        <RadzenLineSeries Data="@contractPoints"
                                                          CategoryProperty="SupplierName"
                                                          ValueProperty="Value"
                                                          Title="Current contract"
                                                          Stroke="#4682B4"
                                                          StrokeWidth="2"
                                                          LineType="LineType.Dashed">
                                            <ChildContent>
                                                <RadzenMarkers Visible="false" />
                                            </ChildContent>
                                            <TooltipTemplate Context="item">
                                                <span>Current contract: @currentContractTotal.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("da-DK")) kr</span>
                                            </TooltipTemplate>
                                        </RadzenLineSeries>
                                    }
                                    <RadzenValueAxis Min="@((double)(_tcoResults.Count > 0 ? _tcoResults.Min(r => r.Commercial) * 0.75m : 0m))"
                                                     Formatter="@(v => $"{Convert.ToDouble(v)/1000000:F1}M")">
                                        <RadzenAxisTitle Text="Spend (kr)" />
                                        <RadzenGridLines Visible="true" />
                                    </RadzenValueAxis>
                                    <RadzenCategoryAxis>
                                        <RadzenAxisTitle Text="Supplier" />
                                    </RadzenCategoryAxis>
                                    <RadzenLegend Visible="true" />
                                </RadzenChart>

                                <MudStack Row="true" Spacing="1" Class="mt-2 flex-wrap">
                                    @foreach (var item in barData)
                                    {
                                        var chipColor = item.IsIncompleteBid ? Color.Warning : Color.Success;
                                        var lineLabel = item.IsIncompleteBid
                                            ? $"{item.SupplierName} — {item.BidLines}/{item.TotalLines} linjer ⚠"
                                            : $"{item.SupplierName} — {item.BidLines}/{item.TotalLines} linjer";
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@chipColor"
                                                 Variant="Variant.Outlined">
                                            @lineLabel
                                        </MudChip>
                                    }
                                </MudStack>

                                <div class="mt-4">
                                    <MudText Typo="Typo.subtitle2"
                                             Class="cockpit-muted mb-1"
                                             Style="cursor:pointer; user-select:none;"
                                             @onclick="@(() => _bubbleChartExpanded = !_bubbleChartExpanded)">
                                        @(_bubbleChartExpanded ? "▾" : "▸") Supplier positioning (CTR vs spend)
                                    </MudText>
                                    <MudCollapse Expanded="@_bubbleChartExpanded">
                                        <svg width="100%" viewBox="0 0 724 420" style="display:block; overflow:visible; max-height:65vh;">

                                    @* Grid lines Y *@
                                    @foreach (var tick in new[] { 0, 25, 50, 75, 100 })
                                    {
                                        var y = ScaleY(tick);
                                        <line x1="@FmtSvg(padL)" y1="@FmtSvg(y)" x2="@FmtSvg(svgW - padR)" y2="@FmtSvg(y)"
                                              stroke="rgba(45,52,54,0.08)" stroke-width="1" />
                                        <svg:text x="@FmtSvg(padL - 6)" y="@FmtSvg(y + 4)"
                                                  font-size="10" fill="rgba(45,52,54,0.45)" text-anchor="end">@tick</svg:text>
                                    }

                                    @foreach (var i in Enumerable.Range(0, 5))
                                    {
                                        var tickSpend = maxSpend * i / 4.0;
                                        var tickX = ScaleX(tickSpend);
                                        var tickLabel = tickSpend >= 1_000_000
                                            ? $"{(tickSpend / 1_000_000.0).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}M"
                                            : tickSpend >= 1_000
                                            ? $"{(tickSpend / 1_000.0).ToString("F0", System.Globalization.CultureInfo.InvariantCulture)}K"
                                            : tickSpend.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

                                        <svg:line x1="@FmtSvg(tickX)" y1="@FmtSvg(padT + plotH)"
                                                  x2="@FmtSvg(tickX)" y2="@FmtSvg(padT + plotH + 5)"
                                                  stroke="rgba(45,52,54,0.3)" stroke-width="1" />
                                        <svg:text x="@FmtSvg(tickX)" y="@FmtSvg(padT + plotH + 18)"
                                                  font-size="10" fill="rgba(45,52,54,0.45)"
                                                  text-anchor="middle">@tickLabel kr</svg:text>
                                    }

                                    @* Y axis label *@
                                    <svg:text x="14" y="@FmtSvg(yAxisMid)"
                                              font-size="11" fill="rgba(45,52,54,0.55)"
                                              text-anchor="middle"
                                              transform="rotate(-90 14 @FmtSvg(yAxisMid))">CTR score</svg:text>

                                    @* X axis label *@
                                    <svg:text x="@FmtSvg(padL + plotW / 2)" y="@FmtSvg(svgH - 8)"
                                              font-size="11" fill="rgba(45,52,54,0.55)" text-anchor="middle">Commercial spend (kr)</svg:text>

                                    @* Quadrant lines *@
                                    <line x1="@FmtSvg(padL + plotW / 2)" y1="@FmtSvg(padT)"
                                          x2="@FmtSvg(padL + plotW / 2)" y2="@FmtSvg(padT + plotH)"
                                          stroke="rgba(45,52,54,0.12)" stroke-width="1" stroke-dasharray="4,4" />
                                    <line x1="@FmtSvg(padL)" y1="@FmtSvg(ScaleY(50))"
                                          x2="@FmtSvg(svgW - padR)" y2="@FmtSvg(ScaleY(50))"
                                          stroke="rgba(45,52,54,0.12)" stroke-width="1" stroke-dasharray="4,4" />

                                    @* Bubbles *@
                                    @foreach (var r in bubbleResults)
                                    {
                                        var cx = positions[r.SupplierName].cx;
                                        var cy = positions[r.SupplierName].cy;
                                        var radius = BubbleR(r.SupplierName);
                                        var color = BubbleColor(r.FinalCtrScore);

                                        <circle cx="@FmtSvg(cx)" cy="@FmtSvg(cy)" r="@FmtSvg(radius)"
                                                fill="@color" fill-opacity="0.75"
                                                stroke="@color" stroke-width="1.5" />
                                        <svg:text x="@FmtSvg(cx)" y="@FmtSvg(cy - radius - 5)"
                                                  font-size="11" font-weight="600"
                                                  fill="#333" text-anchor="middle">@r.SupplierName</svg:text>
                                        <svg:text x="@FmtSvg(cx)" y="@FmtSvg(cy + 4)"
                                                  font-size="10" fill="white" text-anchor="middle"
                                                  font-weight="600">@r.FinalCtrScore.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)</svg:text>
                                        <svg:text x="@FmtSvg(cx)" y="@FmtSvg(cy + 14)"
                                                  font-size="9" fill="rgba(255,255,255,0.85)" text-anchor="middle">@FmtSpend(r.Commercial)</svg:text>
                                    }
                                </svg>
                                    </MudCollapse>
                                </div>
                            }
                        </div>

                        <div class="cockpit-ctr-box" style="background:#485230; border-radius:8px; padding:20px; color:white;">
                            <MudText Style="color:white; font-weight:600; margin-bottom:12px; font-size:15px;">
                                About CTR scoring
                            </MudText>

                            <p style="color:rgba(255,255,255,0.85); font-size:13px; margin-bottom:16px;">
                                CTR (Combined Tender Rating) is a weighted score ranking suppliers
                                across three pillars. Current weights for this tender:
                            </p>

                            @* Dynamic weights from Session *@
                            <div style="margin-bottom:16px;">
                                <div style="display:flex; justify-content:space-between; padding:6px 0;
                                            border-bottom:1px solid rgba(255,255,255,0.15);">
                                    <span style="color:rgba(255,255,255,0.7); font-size:12px;">Commercial</span>
                                    <span style="color:white; font-weight:600; font-size:13px;">@(Session.Commercial)%</span>
                                </div>
                                <div style="display:flex; justify-content:space-between; padding:6px 0;
                                            border-bottom:1px solid rgba(255,255,255,0.15);">
                                    <span style="color:rgba(255,255,255,0.7); font-size:12px;">Technical</span>
                                    <span style="color:white; font-weight:600; font-size:13px;">@(Session.Technical)%</span>
                                </div>
                                <div style="display:flex; justify-content:space-between; padding:6px 0;">
                                    <span style="color:rgba(255,255,255,0.7); font-size:12px;">Regulatory</span>
                                    <span style="color:white; font-weight:600; font-size:13px;">@(Session.Regulatory)%</span>
                                </div>
                            </div>

                            <div style="border-top:1px solid rgba(255,255,255,0.2); padding-top:12px;">
                                <p style="color:rgba(255,255,255,0.7); font-size:12px; margin-bottom:6px;">
                                    <strong style="color:white;">Commercial</strong> — Unit price × volume.
                                    Lowest total spend wins.
                                </p>
                                <p style="color:rgba(255,255,255,0.7); font-size:12px; margin-bottom:6px;">
                                    <strong style="color:white;">Technical</strong> — Delivery reliability,
                                    lead time, quality ratings. Set manually in Settings.
                                </p>
                                <p style="color:rgba(255,255,255,0.7); font-size:12px; margin-bottom:6px;">
                                    <strong style="color:white;">Regulatory</strong> — EPR fee exposure
                                    and PPWR recyclability risk.
                                </p>
                                <p style="color:rgba(255,255,255,0.7); font-size:12px; margin-bottom:0;">
                                    <strong style="color:white;">Bubble size</strong> — Number of line
                                    items for that supplier in this tender.
                                </p>

                                <div style="border-top:1px solid rgba(255,255,255,0.2); padding-top:12px; margin-top:12px;">
                                    <p style="color:rgba(255,255,255,0.7); font-size:11px; text-transform:uppercase;
                                              letter-spacing:0.5px; margin-bottom:8px;">CTR thresholds</p>
                                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
                                        <div style="width:10px;height:10px;border-radius:50%;background:#485230;
                                                    border:2px solid rgba(255,255,255,0.6);flex-shrink:0;"></div>
                                        <span style="color:rgba(255,255,255,0.85); font-size:12px;">CTR ≥ 68 — Strong</span>
                                    </div>
                                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
                                        <div style="width:10px;height:10px;border-radius:50%;background:#6b7c3f;
                                                    border:2px solid rgba(255,255,255,0.4);flex-shrink:0;"></div>
                                        <span style="color:rgba(255,255,255,0.85); font-size:12px;">CTR 48–67 — Review</span>
                                    </div>
                                    <div style="display:flex; align-items:center; gap:8px;">
                                        <div style="width:10px;height:10px;border-radius:50%;background:#c0392b;
                                                    border:2px solid rgba(255,255,255,0.4);flex-shrink:0;"></div>
                                        <span style="color:rgba(255,255,255,0.85); font-size:12px;">CTR &lt; 48 — Risk</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* ROW 2 — score table + spend *@
                    <div style="display:grid; grid-template-columns:minmax(0,1fr) minmax(240px,300px);
                                gap:24px; padding:0 24px 24px; align-items:start;">
                        <div style="min-width:0;">
                        @if (bubbleResults.Count > 0)
                        {
                            <div style="margin-bottom:24px;">
                                <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">Score breakdown</MudText>
                                <table style="width:100%; border-collapse:collapse; font-size:13px;">
                                    <thead>
                                        <tr style="border-bottom:2px solid rgba(45,52,54,0.12);">
                                            <th style="text-align:left; padding:6px 8px; color:rgba(45,52,54,0.55); font-weight:500;">Supplier</th>
                                            <th style="text-align:right; padding:6px 8px; color:rgba(45,52,54,0.55); font-weight:500;">CTR</th>
                                            <th style="text-align:right; padding:6px 8px; color:rgba(45,52,54,0.55); font-weight:500;">Comm</th>
                                            <th style="text-align:right; padding:6px 8px; color:rgba(45,52,54,0.55); font-weight:500;">Tech</th>
                                            <th style="text-align:right; padding:6px 8px; color:rgba(45,52,54,0.55); font-weight:500;">Reg</th>
                                            <th style="text-align:right; padding:6px 8px; color:rgba(45,52,54,0.55); font-weight:500;">Spend</th>
                                            <th style="text-align:right; padding:6px 8px; color:rgba(45,52,54,0.55); font-weight:500;">Lines</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var r in bubbleResults.OrderByDescending(x => x.FinalCtrScore))
                                        {
                                            var lc = lineCountBySupplierB.TryGetValue(r.SupplierName, out var v) ? v : 0;
                                            var isTop = r.FinalCtrScore == bubbleResults.Max(x => x.FinalCtrScore);
                                            <tr style="border-bottom:1px solid rgba(45,52,54,0.07); @(isTop ? "background:rgba(90,122,58,0.07);" : "")">
                                                <td style="padding:6px 8px; font-weight:@(isTop ? "600" : "400");">@r.SupplierName</td>
                                                <td style="text-align:right; padding:6px 8px; font-weight:600; color:@BubbleColor(r.FinalCtrScore);">
                                                    @r.FinalCtrScore.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)
                                                </td>
                                                <td style="text-align:right; padding:6px 8px;">@r.PriceScore.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)</td>
                                                <td style="text-align:right; padding:6px 8px;">@r.TechScore.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)</td>
                                                <td style="text-align:right; padding:6px 8px;">@r.RegScore.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)</td>
                                                <td style="text-align:right; padding:6px 8px;">@r.Commercial.ToString("N0", Da) kr</td>
                                                <td style="text-align:right; padding:6px 8px;">@lc</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        <MudText Typo="Typo.h6" Class="cockpit-section-title mb-1">Spend overview</MudText>
                        <MudText Typo="Typo.body2" Class="cockpit-muted mb-4">Commercial vs regulatory cost by supplier.</MudText>
                        <div class="cockpit-spend-wrap" style="width:100%; display:flex; flex-direction:column;">
                            @{
                                var results = _tcoResults.OrderBy(r => r.Commercial).ToList();
                            }
                            @if (results.Count == 0)
                            {
                                <svg width="100%"
                                     height="200"
                                     viewBox="0 0 900 200"
                                     class="cockpit-spend-svg">
                                    <svg:text x="450" y="100" text-anchor="middle" fill="rgba(45,52,54,0.65)">No suppliers selected</svg:text>
                                </svg>
                            }
                            else
                            {
                                var lineCountBySupplier = _importedLineItems
                                    .GroupBy(i => i.SupplierName?.Trim() ?? string.Empty,
                                             StringComparer.OrdinalIgnoreCase)
                                    .ToDictionary(g => g.Key, g => g.Count(),
                                                  StringComparer.OrdinalIgnoreCase);

                                @for (var idx = 0; idx < results.Count; idx++)
                                {
                                    var r = results[idx];
                                    var yPos = 10.0;
                                    var x0 = 150.0;
                                    var barH = 30.0;
                                    var trackW = 600.0;
                                    var alpha = Math.Max(0.25, (double)r.FinalCtrScore / 100.0);

                                    <MudTooltip Placement="Placement.Bottom">
                                        <TooltipContent>
                                            <MudText Typo="Typo.body2" Style="max-width:420px;white-space:pre-wrap;">@r.CalculationBreakdown</MudText>
                                        </TooltipContent>
                                        <ChildContent>
                                            <svg width="100%"
                                                 height="50"
                                                 viewBox="0 0 900 50"
                                                 class="cockpit-spend-svg"
                                                 style="display:block;">
                                                <g opacity="@FmtSvg(alpha)">
                                                    <rect x="@FmtSvg(x0)" y="@FmtSvg(yPos)" width="@FmtSvg(trackW)" height="@FmtSvg(barH)" fill="#f5f5f5" rx="4" />

                                                    <rect x="@FmtSvg(x0)" y="@FmtSvg(yPos)" width="@FmtSvg(r.CommercialWidth)" height="@FmtSvg(barH)" fill="#91a363" rx="4" />
                                                    <rect x="@FmtSvg(x0 + r.CommercialWidth)" y="@FmtSvg(yPos)" width="@FmtSvg(r.RegulatoryWidth)" height="@FmtSvg(barH)" fill="#FFB300" rx="4" />
                                                    <rect x="@FmtSvg(x0 + r.CommercialWidth + r.RegulatoryWidth)" y="@FmtSvg(yPos)" width="@FmtSvg(r.SwitchingWidth)" height="@FmtSvg(barH)" fill="#D3D3D3" rx="4" />
                                                    <rect x="@FmtSvg(x0 + r.CommercialWidth + r.RegulatoryWidth + r.SwitchingWidth)" y="@FmtSvg(yPos)" width="@FmtSvg(r.MoqWidth)" height="@FmtSvg(barH)" fill="#4682B4" rx="4" />

                                                    <!-- Score badge -->
                                                    <circle cx="@FmtSvg(12)" cy="@FmtSvg(yPos + 15)" r="@FmtSvg(10)" fill="rgba(45,52,54,0.10)" />
                                                    <svg:text x="@FmtSvg(12)" y="@FmtSvg(yPos + 19)" text-anchor="middle" font-size="10" fill="#333" font-weight="700" font-family="monospace">
                                                        @r.FinalCtrScore.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)
                                                    </svg:text>

                                                    <svg:text x="@FmtSvg(28)" y="@FmtSvg(yPos + 20)" font-size="12" fill="#333" font-weight="bold">@r.SupplierName</svg:text>

                                                    <svg:text x="750" y="@FmtSvg(yPos + 20)" text-anchor="end"
                                                              font-size="12" font-family="monospace">
                                                        @r.Total.ToString("N0", Da) kr.
                                                    </svg:text>
                                                    <svg:text x="850" y="@FmtSvg(yPos + 20)"
                                                              font-size="11" fill="#111" font-weight="700" font-family="monospace">
                                                        @(lineCountBySupplier.TryGetValue(r.SupplierName, out var lc) ? $"{lc} linjer" : string.Empty)
                                                    </svg:text>
                                                </g>
                                            </svg>
                                        </ChildContent>
                                    </MudTooltip>
                                }
                            }
                        </div>

                        <div style="margin-top: 12px; display:flex; flex-wrap:wrap; gap: 14px; align-items:center;">
                            <div style="display:flex; align-items:center; gap: 8px;">
                                <span style="width:14px;height:14px;border-radius:3px;background:#91a363;display:inline-block;"></span>
                                <span>Aftalt pris (Indkøb)</span>
                            </div>
                            <div style="display:flex; align-items:center; gap: 8px;">
                                <span style="width:14px;height:14px;border-radius:3px;background:#4682B4;display:inline-block;"></span>
                                <span>Skjulte omkostninger (TCO-tillæg)</span>
                            </div>
                        </div>
                        </div>
                        <div></div>
                    </div>
                }

                @if (_activeTab == "matrix")
                {
                    <PriceMatrix />
                }

                @if (_activeTab == "deep-dive")
                {
        @if (_deepDiveSupplierName is not null)
        {
            @* DETAIL VIEW — single supplier *@
            var detailSupplier = _suppliersAll.FirstOrDefault(s =>
                string.Equals(s.SupplierName, _deepDiveSupplierName,
                    StringComparison.OrdinalIgnoreCase));
            var detailDto = detailSupplier is not null
                ? GetTcoDto(detailSupplier.SupplierId)
                : null;
            var detailSpend = detailDto?.Commercial ?? 0m;
            var baselineTotal = (decimal)_bestBidBaseline.Values.Sum();
            var contractTotal = (decimal)_currentContractBaseline.Values.Sum();
            var vsBaseline = baselineTotal > 0
                ? (detailSpend - baselineTotal) / baselineTotal * 100m
                : 0m;
            var vsContract = contractTotal > 0
                ? (detailSpend - contractTotal) / contractTotal * 100m
                : 0m;

            @* Back button *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => { _deepDiveSupplierName = null; Session.ReplaceSelectedSuppliers(_suppliersAll.Select(s => s.SupplierId).Where(id => !string.IsNullOrWhiteSpace(id)).ToArray()); StateHasChanged(); })">
                    Tilbage til oversigt
                </MudButton>
                <MudText Typo="Typo.h6" Style="color:#485230; font-weight:600;">
                    @_deepDiveSupplierName
                </MudText>
            </MudStack>

            @* Section 1 — Leverandør header *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">

                @* Badges row *@
                <MudStack Row="true" Spacing="1" Class="flex-wrap mb-4">
                    @if (detailDto is not null && IsRecommendedSupplier(detailSupplier?.SupplierId ?? ""))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Recommended</MudChip>
                    }
                    @if (detailDto is not null && IsLowestCommercialAnchor(detailSupplier?.SupplierId ?? ""))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Lowest commercial</MudChip>
                    }
                    @if (detailDto is not null && !detailDto.IsCompliant)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Regulatory risk</MudChip>
                    }
                    @if (detailSupplier is not null && IsExtremePrice(detailSupplier.SupplierId))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">Pris-outlier</MudChip>
                    }
                </MudStack>

                @* KPI cards row *@
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="4">
                        <MudPaper Elevation="0" Class="pa-3"
                                  Style="background:#f5f5f0; border-radius:8px; text-align:center;">
                            <MudText Typo="Typo.caption" Class="cockpit-muted">Estimeret spend</MudText>
                            <MudText Typo="Typo.h5" Style="font-weight:600; color:#485230; margin-top:4px;">
                                @detailSpend.ToString("N0", Da) kr
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Elevation="0" Class="pa-3"
                                  Style="background:#f5f5f0; border-radius:8px; text-align:center;">
                            <MudText Typo="Typo.caption" Class="cockpit-muted">vs. best bid</MudText>
                            <MudText Typo="Typo.h5"
                                     Style="@($"font-weight:600; margin-top:4px; color:{(vsBaseline > 10 ? "#A32D2D" : vsBaseline > 0 ? "#854F0B" : "#3B6D11")}")">
                                @(vsBaseline >= 0 ? "+" : "")@vsBaseline.ToString("N1", Da)%
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudPaper Elevation="0" Class="pa-3"
                                  Style="background:#f5f5f0; border-radius:8px; text-align:center;">
                            <MudText Typo="Typo.caption" Class="cockpit-muted">vs. nuværende kontrakt</MudText>
                            @if (contractTotal > 0)
                            {
                                <MudText Typo="Typo.h5"
                                         Style="@($"font-weight:600; margin-top:4px; color:{(vsContract > 10 ? "#A32D2D" : vsContract > 0 ? "#854F0B" : "#3B6D11")}")">
                                    @(vsContract >= 0 ? "+" : "")@vsContract.ToString("N1", Da)%
                                </MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.h5"
                                         Style="font-weight:600; margin-top:4px; color:rgba(45,52,54,0.35);">
                                    —
                                </MudText>
                                <MudText Typo="Typo.caption" Class="cockpit-muted">
                                    Ingen nuværende pris
                                </MudText>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @* Section 2 — Pris-analyse placeholder (BACK-028 Part B) *@
            <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">
                    Pris-analyse per linje
                </MudText>
                <MudText Typo="Typo.body2" Class="cockpit-muted">
                    Kommer i næste trin — viser afvigelse per linje vs. best bid og nuværende kontrakt.
                </MudText>
            </MudPaper>

            @* Section 3 — TCO breakdown *@
            @if (detailDto is not null)
            {
                <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
                    <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-3">TCO breakdown</MudText>
                    <MudGrid Spacing="2">
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Class="cockpit-muted">Commercial</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight:500;">
                                @detailDto.Commercial.ToString("N0", Da) kr
                            </MudText>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Class="cockpit-muted">EPR / PPWR</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight:500;">
                                @detailDto.Epr.ToString("N0", Da) kr
                            </MudText>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Class="cockpit-muted">Switching</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight:500;">
                                @detailDto.Switching.ToString("N0", Da) kr
                            </MudText>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Class="cockpit-muted">Total TCO</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight:600; color:#485230;">
                                @detailDto.Total.ToString("N0", Da) kr
                            </MudText>
                        </MudItem>
                        @if (!string.IsNullOrWhiteSpace(detailDto.CalculationBreakdown))
                        {
                            <MudItem xs="12">
                                <MudText Typo="Typo.caption" Class="cockpit-muted">Beregningsgrundlag</MudText>
                                <MudText Typo="Typo.body2" Class="cockpit-muted mt-1">
                                    @detailDto.CalculationBreakdown
                                </MudText>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            }
        }
        else
        {
            @* OVERVIEW MODE — all suppliers *@
            <MudStack Row="true" AlignItems="AlignItems.Center"
                      Justify="Justify.SpaceBetween" Class="mb-3">
                <MudText Typo="Typo.h6" Style="color:#485230; font-weight:600;">
                    Leverandør oversigt
                </MudText>
                <MudText Typo="Typo.body2" Class="cockpit-muted">
                    Klik på en leverandør for detaljevisning
                </MudText>
            </MudStack>

            @* Supplier cards *@
            <MudGrid Spacing="3" Class="mb-4">
                @foreach (var r in _tcoResults.OrderByDescending(x => x.FinalCtrScore))
                {
                    var cardSpend = r.Commercial;
                    var cardBaseline = (decimal)_bestBidBaseline.Values.Sum();
                    var cardVsBaseline = cardBaseline > 0
                        ? (cardSpend - cardBaseline) / cardBaseline * 100m
                        : 0m;
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Elevation="1"
                                  Class="pa-4"
                                  Style="cursor:pointer; border-radius:8px; border: 1.5px solid rgba(72,82,48,0.15);"
                                  @onclick="@(() => { _deepDiveSupplierName = r.SupplierName; StateHasChanged(); })">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600; color:#485230;">
                                @r.SupplierName
                            </MudText>
                            <MudDivider Class="my-2" />
                            <MudStack Spacing="1">
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.caption" Class="cockpit-muted">CTR score</MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">
                                        @r.FinalCtrScore.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.caption" Class="cockpit-muted">Spend</MudText>
                                    <MudText Typo="Typo.body2">
                                        @cardSpend.ToString("N0", Da) kr
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.caption" Class="cockpit-muted">vs. best bid</MudText>
                                    <MudText Typo="Typo.body2"
                                             Style="@($"font-weight:500; color:{(cardVsBaseline > 10 ? "#A32D2D" : cardVsBaseline > 0 ? "#854F0B" : "#3B6D11")}")">
                                        @(cardVsBaseline >= 0 ? "+" : "")@cardVsBaseline.ToString("N1", Da)%
                                    </MudText>
                                </MudStack>
                                @if (IsRecommendedSupplier(r.SupplierId))
                                {
                                    <MudChip T="string" Size="Size.Small"
                                             Color="Color.Success"
                                             Variant="Variant.Filled"
                                             Class="mt-1">Recommended</MudChip>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>

            @* Collapsible legacy grid *@
            <MudText Typo="Typo.subtitle2"
                     Class="cockpit-muted mb-2"
                     Style="cursor:pointer;"
                     @onclick="@(() => _legacyGridExpanded = !_legacyGridExpanded)">
                @(_legacyGridExpanded ? "▾" : "▸") Detaljeret tabel (alle leverandører)
            </MudText>
            <MudCollapse Expanded="@_legacyGridExpanded">
                    @if (SidebarBridge.LastImportValidationReport?.Issues.Any(i => i.Severity == ImportValidationSeverity.Error) == true)
                    {
                        <MudPaper Elevation="0" Class="mb-4 pa-3" Style="border: 1px solid var(--mud-palette-error); border-radius: 8px;">
                            <MudText Typo="Typo.subtitle2" Color="Color.Error" Class="mb-2">
                                Import fejl (@SidebarBridge.LastImportValidationReport.Issues.Count(i => i.Severity == ImportValidationSeverity.Error))
                            </MudText>
                            <MudSimpleTable Dense="true" Striped="true" Bordered="true">
                                <thead>
                                    <tr>
                                        <th>Række</th>
                                        <th>Kolonne</th>
                                        <th>Råværdi</th>
                                        <th>Problem</th>
                                        <th>Alvorlighed</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var issue in SidebarBridge.LastImportValidationReport.Issues
                                        .Where(i => i.Severity == ImportValidationSeverity.Error)
                                        .OrderBy(i => i.RowNumber))
                                    {
                                        <tr>
                                            <td>@issue.RowNumber</td>
                                            <td>@issue.ColumnName</td>
                                            <td><code>@issue.RawValue</code></td>
                                            <td>@issue.Message</td>
                                            <td style="color: @(issue.Severity == ImportValidationSeverity.Error ? "var(--mud-palette-error)" : "var(--mud-palette-warning)")">
                                                @issue.Severity
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }
                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-slicer-bar pa-4 mt-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="cockpit-slicer-stack">
                            <MudTextField @bind-Value="_tableSearch"
                                          dense="true"
                                          Variant="Variant.Outlined"
                                          Placeholder="Search supplier / spec / sites"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Outlined.Search"
                                          Class="cockpit-slicer-search" />

                            <MudSelect T="string"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Label="Site"
                                       MultiSelection="true"
                                       SelectedValues="@_tableSitesSelected"
                                       SelectedValuesChanged="OnSitesSelectedChanged">
                                @foreach (var s in _tableSites)
                                {
                                    <MudSelectItem @key="s" Value="@s">@s</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="string"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Label="Material type"
                                       MultiSelection="true"
                                       SelectedValues="@_tableMaterialsSelected"
                                       SelectedValuesChanged="OnMaterialsSelectedChanged">
                                @foreach (var m in _tableMaterials)
                                {
                                    <MudSelectItem @key="m" Value="@m">@m</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="string"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Label="Supplier"
                                       MultiSelection="true"
                                       SelectedValues="@_tableSuppliersSelected"
                                       SelectedValuesChanged="OnSuppliersSelectedChanged">
                                @foreach (var s in _tableSupplierOptions)
                                {
                                    <MudSelectItem @key="s.Id" Value="@s.Id">@s.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudStack Spacing="0" Class="cockpit-slicer-range">
                                <MudText Typo="Typo.caption" Class="cockpit-muted">Weighted score</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudSlider T="int" Min="0" Max="100" Step="1" Value="@_scoreMin" ValueChanged="@(v => _scoreMin = Math.Min(v, _scoreMax))" Class="label-tender-slider-accent" valueLabelDisplay="ValueLabelDisplay.OnHover" />
                                    <MudText Typo="Typo.caption" Class="cockpit-num cockpit-num-muted">@_scoreMin</MudText>
                                    <MudText Typo="Typo.caption" Class="cockpit-muted">–</MudText>
                                    <MudText Typo="Typo.caption" Class="cockpit-num cockpit-num-muted">@_scoreMax</MudText>
                                    <MudSlider T="int" Min="0" Max="100" Step="1" Value="@_scoreMax" ValueChanged="@(v => _scoreMax = Math.Max(v, _scoreMin))" Class="label-tender-slider-accent" valueLabelDisplay="ValueLabelDisplay.OnHover" />
                                </MudStack>
                            </MudStack>
                        </MudStack>

                        @if (ActiveFilterChips.Count > 0)
                        {
                            <MudStack Row="true" Spacing="1" Class="mt-2 flex-wrap">
                                @foreach (var chip in ActiveFilterChips)
                                {
                                    <MudChip T="string" @key="chip" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@chip</MudChip>
                                }
                            </MudStack>
                        }
                    </MudPaper>

                    <MudStack Spacing="1" Class="mb-2 px-2">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;">Deep-dive</MudText>
                    </MudStack>

                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-grid-shell pa-0 mt-2">
                        <MudDataGrid T="SupplierPillarAnalysisRow"
                                     Items="@TableItems"
                                     Dense="true"
                                     Hover="true"
                                     Filterable="true"
                                     FilterMode="DataGridFilterMode.ColumnFilterRow"
                                     selectionMode="DataGridSelectionMode.Single"
                                     SelectedItem="@_tableSelectedRow"
                                     SelectedItemChanged="OnTableSelectedRowChanged"
                                     Class="cockpit-supplier-grid cockpit-supplier-grid--filter decision-evidence-grid">
                            <Columns>
                                <HierarchyColumn T="SupplierPillarAnalysisRow" />

                                <TemplateColumn Title="Status" Sortable="false">
                                    <CellTemplate>
                                        @{
                                            var id = context.Item.Supplier.SupplierId;
                                            var dto = GetTcoDto(id);
                                        }
                                        <MudStack Row="true" Spacing="1" Class="flex-wrap gap-1">
                                            @if (IsRecommendedSupplier(id))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Recommended</MudChip>
                                            }
                                            @if (IsLowestCommercialAnchor(id))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Lowest commercial</MudChip>
                                            }
                                            @if (IsBestTcoAnchor(id))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Best TCO</MudChip>
                                            }
                                            @if (dto is not null && !dto.IsCompliant)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Regulatory risk</MudChip>
                                            }
                                            @if (RowNeedsManualReview(context.Item))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">Review</MudChip>
                                            }
                                            else if (dto is not null && ShowConditionalChip(context.Item, dto))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Conditional</MudChip>
                                            }
                                        </MudStack>
                                    </CellTemplate>
                                </TemplateColumn>

                                <PropertyColumn Property="x => x.Supplier.SupplierName" Title="Supplier" />
                                <PropertyColumn Property="x => x.Supplier.Material" Title="Material" />

                                <TemplateColumn Title="Price index" Sortable="false">
                                    <CellTemplate>
                                        @{
                                            var dto = GetTcoDto(context.Item.Supplier.SupplierId);
                                        }
                                        <MudText Typo="Typo.body2" Style="font-weight:700;">
                                            @(dto?.PriceScore.ToString("0.0", Da) ?? "–")
                                        </MudText>
                                    </CellTemplate>
                                </TemplateColumn>

                                <TemplateColumn Title="Weighted CTR" Sortable="false">
                                    <CellTemplate>
                                        @{
                                            var dto = GetTcoDto(context.Item.Supplier.SupplierId);
                                        }
                                        <MudText Typo="Typo.body2" Style="font-weight:700;">
                                            @(dto?.FinalCtrScore.ToString("0.0", Da) ?? "–")
                                        </MudText>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>

                            <ChildRowContent>
                                <MudStack Spacing="4">
                                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-3">Economics &amp; sites</MudText>
                                        <MudGrid Spacing="3">
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Label type</MudText>
                                                <MudText Typo="Typo.body2">@context.Item.Supplier.LabelType</MudText>
                                            </MudItem>
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Adhesive</MudText>
                                                <MudText Typo="Typo.body2">@context.Item.Supplier.Adhesive</MudText>
                                            </MudItem>
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Sites</MudText>
                                                <MudText Typo="Typo.body2">@string.Join(", ", context.Item.Supplier.Sites)</MudText>
                                            </MudItem>
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Quantity (labels)</MudText>
                                                @{
                                                    var isQtyOutlier = IsOutlier(context.Item.Supplier.SupplierId, OutlierFieldQuantity);
                                                    var qtyKey = AnomalyKey(context.Item.Supplier.SupplierId, OutlierFieldQuantity);
                                                }
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.body2" Class="@(isQtyOutlier ? "cockpit-outlier-cell" : null)">
                                                        @context.Item.Supplier.QuantityLabels.ToString("N0", Da)
                                                    </MudText>
                                                    @if (isQtyOutlier)
                                                    {
                                                        <MudMenu Dense="true" Icon="@Icons.Material.Outlined.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(qtyKey, AnomalyStatus.Accepted))">Accept</MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(qtyKey, AnomalyStatus.Excluded))">Exclude</MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(qtyKey, AnomalyStatus.Clarification))">Clarify</MudMenuItem>
                                                        </MudMenu>
                                                    }
                                                </MudStack>
                                            </MudItem>
                                            <MudItem xs="12" sm="6" md="3">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Unit price</MudText>
                                                @{
                                                    var isPriceOutlier = IsOutlier(context.Item.Supplier.SupplierId, OutlierFieldPrice) || IsExtremePrice(context.Item.Supplier.SupplierId);
                                                    var priceKey = AnomalyKey(context.Item.Supplier.SupplierId, OutlierFieldPrice);
                                                }
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.body2" Class="@(isPriceOutlier ? "cockpit-outlier-cell" : null)">
                                                        @context.Item.Supplier.Price.ToString("N2", Da)
                                                    </MudText>
                                                    @if (isPriceOutlier)
                                                    {
                                                        <MudMenu Dense="true" Icon="@Icons.Material.Outlined.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(priceKey, AnomalyStatus.Accepted))">Accept</MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(priceKey, AnomalyStatus.Excluded))">Exclude</MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => SetAnomalyStatus(priceKey, AnomalyStatus.Clarification))">Clarify</MudMenuItem>
                                                        </MudMenu>
                                                    }
                                                </MudStack>
                                            </MudItem>
                                        </MudGrid>
                                    </MudPaper>

                                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">Raw pillar scores (supplier)</MudText>
                                        <MudSimpleTable Dense="true" Class="decision-raw-table">
                                            <tbody>
                                                <tr>
                                                    <td>Commercial</td>
                                                    <td class="text-end cockpit-num">@context.Item.Supplier.CommercialScore.ToString("0.0", Da)</td>
                                                </tr>
                                                <tr>
                                                    <td>Technical</td>
                                                    <td class="text-end cockpit-num">@context.Item.Supplier.TechnicalScore.ToString("0.0", Da)</td>
                                                </tr>
                                                <tr>
                                                    <td>Regulatory</td>
                                                    <td class="text-end cockpit-num">@context.Item.Supplier.RegulatoryScore.ToString("0.0", Da)</td>
                                                </tr>
                                            </tbody>
                                        </MudSimpleTable>
                                    </MudPaper>

                                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">Pillar blend (scoring model)</MudText>
                                        <MudStack Spacing="0" Class="w-100">
                                            <MudProgressLinear Value="@((double)context.Item.TotalScore)"
                                                               Max="100"
                                                               Rounded="true"
                                                               Color="Color.Default"
                                                               Class="cockpit-weighted-bar" />
                                            <MudText Typo="Typo.caption" Class="text-end cockpit-weighted-caption cockpit-num cockpit-num-muted mt-1">
                                                @FormatScore(context.Item.TotalScore)
                                            </MudText>
                                        </MudStack>
                                    </MudPaper>

                                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">TCO engine &amp; breakdown</MudText>
                                        @{
                                            var tco = GetTcoDto(context.Item.Supplier.SupplierId);
                                        }
                                        @if (tco is null)
                                        {
                                            <MudText Typo="Typo.body2" Class="cockpit-muted">No TCO row — supplier may be filtered from selection.</MudText>
                                        }
                                        else
                                        {
                                            <MudGrid Spacing="2">
                                                <MudItem xs="12" md="4">
                                                    <MudText Typo="Typo.caption" Class="cockpit-muted">Commercial spend</MudText>
                                                    <MudText Typo="Typo.body1">@tco.Commercial.ToString("N0", Da) kr</MudText>
                                                </MudItem>
                                                <MudItem xs="12" md="4">
                                                    <MudText Typo="Typo.caption" Class="cockpit-muted">Total TCO</MudText>
                                                    <MudText Typo="Typo.body1">@tco.Total.ToString("N0", Da) kr</MudText>
                                                </MudItem>
                                                <MudItem xs="12" md="4">
                                                    <MudText Typo="Typo.caption" Class="cockpit-muted">Compliance</MudText>
                                                    <MudText Typo="Typo.body2">@(tco.IsCompliant ? "OK" : "Missing weight / review")</MudText>
                                                </MudItem>
                                                <MudItem xs="12">
                                                    <MudText Typo="Typo.caption" Class="cockpit-muted">Calculation breakdown</MudText>
                                                    <MudText Typo="Typo.body2" Class="cockpit-muted">@tco.CalculationBreakdown</MudText>
                                                </MudItem>
                                            </MudGrid>
                                        }
                                    </MudPaper>

                                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-insight-card pa-4">
                                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">Technical &amp; logistics</MudText>
                                        <MudGrid Spacing="3">
                                            <MudItem xs="12" md="4">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Quantity breakpoints</MudText>
                                                <MudSimpleTable Dense="true">
                                                    <tbody>
                                                        <tr><td>1k</td><td class="text-end cockpit-num">@context.Item.Supplier.PriceAt1k.ToString("N2", Da)</td></tr>
                                                        <tr><td>5k</td><td class="text-end cockpit-num">@context.Item.Supplier.PriceAt5k.ToString("N2", Da)</td></tr>
                                                        <tr><td>10k</td><td class="text-end cockpit-num">@context.Item.Supplier.PriceAt10k.ToString("N2", Da)</td></tr>
                                                    </tbody>
                                                </MudSimpleTable>
                                            </MudItem>

                                            <MudItem xs="12" md="4">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Technical summary</MudText>
                                                @{
                                                    var r = GetTcoDto(context.Item.Supplier.SupplierId);
                                                    var technicalSummary = r is null
                                                        ? "No technical deviations reported."
                                                        : r.TechnicalSummary;
                                                }
                                                <MudText Typo="Typo.body2" Class="cockpit-muted mt-1">@technicalSummary</MudText>
                                            </MudItem>

                                            <MudItem xs="12" md="4">
                                                <MudText Typo="Typo.caption" Class="cockpit-muted">Logistics</MudText>
                                                <MudText Typo="Typo.body2" Class="cockpit-muted mt-1">@context.Item.Supplier.LogisticsConstraints</MudText>
                                            </MudItem>
                                        </MudGrid>
                                    </MudPaper>
                                </MudStack>
                            </ChildRowContent>
                        </MudDataGrid>
                    </MudPaper>
            </MudCollapse>
        }
    }

                @if (_activeTab == "audit")
                {
                    <MudPaper Elevation="0" Outlined="true" Class="cockpit-audit-shell pa-5 mt-4">
                        <MudText Typo="Typo.h6" Class="cockpit-section-title mb-1">Audit Board</MudText>
                        <MudText Typo="Typo.body2" Class="cockpit-muted mb-4">Active clarifications flagged by the Digital Auditor.</MudText>

                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">Negotiation summary</MudText>
                        @if (!NegotiationSummary.Any())
                        {
                            <MudText Typo="Typo.body2" Class="cockpit-muted mb-4">No clarifications pending.</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="1" Class="mb-4">
                                @foreach (var group in NegotiationSummary)
                                {
                                    <MudPaper @key="group.SupplierName" Elevation="0" Outlined="true" Class="pa-3 cockpit-negotiation-card">
                                        <MudText Typo="Typo.body1" Style="font-weight:700;">@group.SupplierName</MudText>
                                        <MudList T="string" Dense="true">
                                            @foreach (var item in group.Items)
                                            {
                                                <MudListItem @key="item.Field" T="string">
                                                    <MudText Typo="Typo.body2">@item.Field — @item.Message</MudText>
                                                </MudListItem>
                                            }
                                        </MudList>
                                    </MudPaper>
                                }
                            </MudStack>
                        }

                        <MudTable T="AuditItem" Dense="true" Hover="true" Items="@AuditItems" Class="cockpit-audit-table">
                            <HeaderContent>
                                <MudTh>Supplier</MudTh>
                                <MudTh>Field</MudTh>
                                <MudTh>Flag</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>AI reasoning</MudTh>
                                <MudTh>Note</MudTh>
                                <MudTh class="text-end">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Supplier">@context.SupplierName</MudTd>
                                <MudTd DataLabel="Field">@context.Field</MudTd>
                                <MudTd DataLabel="Flag">
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Potential Unit Error</MudChip>
                                </MudTd>
                                <MudTd DataLabel="Status">
                                    <MudChip T="string"
                                             Color="@(context.Status is AnomalyStatus.Clarification ? Color.Warning : Color.Default)"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @context.Status.ToString()
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="AI reasoning" Style="min-width: 20rem;">
                                    <MudTextField T="string"
                                                  Value="@GetAuditReasoning(context.Key)"
                                                  ValueChanged="@( (string v) => SetAuditReasoning(context.Key, v) )"
                                                  Variant="Variant.Outlined"
                                                  dense="true"
                                                  Lines="2"
                                                  Class="cockpit-ai-reasoning"
                                                  Placeholder="AI reasoning…" />
                                </MudTd>
                                <MudTd DataLabel="Note" Style="min-width: 18rem;">
                                    <MudTextField T="string"
                                                  Value="@GetAuditNote(context.Key)"
                                                  ValueChanged="@( (string v) => SetAuditNote(context.Key, v) )"
                                                  Variant="Variant.Outlined"
                                                  dense="true"
                                                  Placeholder="Clarification note…"
                                                  Disabled="@(context.Status is not AnomalyStatus.Clarification)"
                                                  Lines="1" />
                                </MudTd>
                                <MudTd DataLabel="Actions" Class="text-end">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" dense="true" Class="cockpit-action-btn" OnClick="@(() => AuditAccept(context.Key))">Accept</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" dense="true" Class="ml-2 cockpit-action-btn" OnClick="@(() => AuditReject(context.Key))">Exclude</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" dense="true" Class="ml-2 cockpit-action-btn" OnClick="@(() => AuditClarify(context.Key))">Clarify</MudButton>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>

                        <MudDivider Class="my-4" />

                        <MudText Typo="Typo.subtitle2" Class="cockpit-section-title mb-2">History</MudText>
                        @if (_history.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Class="cockpit-muted">No actions recorded yet.</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="1" Class="cockpit-history">
                                @foreach (var h in _history)
                                {
                                    <MudStack @key="h.Timestamp" Spacing="0" Class="cockpit-history-item">
                                        <MudText Typo="Typo.caption" Class="cockpit-muted">@h.Timestamp.ToString("yyyy-MM-dd HH:mm")</MudText>
                                        <MudText Typo="Typo.body2">@h.Message</MudText>
                                    </MudStack>
                                }
                            </MudStack>
                        }
                    </MudPaper>
                }
                }
    </MudStack>
}

@code
{
    private static readonly CultureInfo Da = CultureInfo.GetCultureInfo("da-DK");

    private const decimal TenderVolumeUnits = 10_000_000m;

    private static readonly string[] _profiles =
        [PackagingProfileSession.ProfileLabels, "Trays", "Flexibles", "Cardboard", "Mixed"];

    private List<SupplierModel> _suppliersAll = [];

    private List<SupplierModel> _suppliersSelected = [];

    private List<SupplierPillarAnalysisRow> _pillarRows = [];

    private List<SupplierPillarAnalysisRow> _tableRows = [];

    private SupplierPillarAnalysisRow? _tableSelectedRow;

    private string _activeTab = "dashboard";

    private string _filterCountry = string.Empty;
    private string _filterSite = string.Empty;
    private string[] _filterCountries = [];
    private string[] _filterSitesForCountry = [];
    private HashSet<string> _activeSites = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _activeCountries = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _activeMaterials = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _activeLabelSizes = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _activeWindings = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _activeColors = new(StringComparer.OrdinalIgnoreCase);
    private string _filterMaterial = string.Empty;
    private string[] _filterMaterials = [];
    private string _filterLabelSize = string.Empty;
    private string[] _filterLabelSizes = [];
    private string _filterWinding = string.Empty;
    private string[] _filterWindings = [];
    private string _filterColors = string.Empty;
    private string[] _filterColorValues = [];
    private bool _synergyToggle;

    private bool _ppwrEffectToggle;

    private readonly List<PackagingTenderTool.Blazor.Models.LabelTender.LabelTenderDashboardDto> _tcoResults = [];

    private TenderDecisionInsight? _decisionInsight;

    private List<LabelLineItem> _importedLineItems = [];

    private IReadOnlyDictionary<string, decimal> _bestBidBaseline =
        new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);

    private IReadOnlyDictionary<string, decimal> _currentContractBaseline =
        new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);

    /// <summary>
    /// Imputed total spend per supplier across full tender package.
    /// Missing lines use CurrentContractPrice. Lines with no price are excluded.
    /// Key = SupplierName (case-insensitive).
    /// </summary>
    private IReadOnlyDictionary<string, ImputedSupplierSpend> _imputedSpend =
        new Dictionary<string, ImputedSupplierSpend>(StringComparer.OrdinalIgnoreCase);

    private string _importStatus = string.Empty;
    private readonly List<ImportUnitMismatchFlag> _importFlags = [];
    private bool _isImporting;

    private SupplierOutlierReport _outliers = new(new Dictionary<string, IReadOnlyList<SupplierOutlierFlag>>(StringComparer.OrdinalIgnoreCase));

    private const string OutlierFieldPrice = "Price";
    private const string OutlierFieldQuantity = "Quantity";

    private string _tableSearch = string.Empty;
    private HashSet<string> _tableSitesSelected = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _tableMaterialsSelected = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _tableSuppliersSelected = new(StringComparer.OrdinalIgnoreCase);
    private string[] _tableSites = [];
    private string[] _tableMaterials = [];
    private SupplierOption[] _tableSupplierOptions = [];
    private int _scoreMin = 0;
    private int _scoreMax = 100;

    private readonly ConcurrentDictionary<string, string> _auditNotes = new(StringComparer.OrdinalIgnoreCase);
    private readonly ConcurrentDictionary<string, string> _auditReasoning = new(StringComparer.OrdinalIgnoreCase);
    private readonly ConcurrentDictionary<string, string> _auditDecisions = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<HistoryEntry> _history = [];

    private readonly ConcurrentDictionary<string, AnomalyState> _anomalies = new(StringComparer.OrdinalIgnoreCase);

    private volatile bool _isCalculating;

    protected override async Task OnInitializedAsync()
    {
        Session.Changed += OnSessionChanged;
        Nav.LocationChanged += OnNavLocationChanged;
        SidebarBridge.ImportExcelAsync = OnExcelSelected;
        SidebarBridge.OnCountryChanged = OnCountryChanged;
        SidebarBridge.OnSiteChanged = OnSiteChanged;
        SidebarBridge.OnMaterialChanged = OnMaterialChanged;
        SidebarBridge.OnSynergyChanged = OnSynergyChanged;
        SidebarBridge.OnPpwrEffectChanged = OnPpwrEffectChanged;
        SidebarBridge.OnTabChanged = OnBridgeTabChanged;

        await Task.Yield();
        RefreshData();
        SyncSidebarBridge();
    }

    protected override void OnParametersSet()
    {
        SyncTabFromUri();
    }

    private void OnNavLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        SyncTabFromUri();
        _ = InvokeAsync(StateHasChanged);
    }

