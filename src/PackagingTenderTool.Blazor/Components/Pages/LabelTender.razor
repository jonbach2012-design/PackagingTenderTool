        var dto = GetTcoDto(row.Supplier.SupplierId);
        if (dto is null)
            return true;

        if (!dto.IsCompliant)
            return true;

        if (dto.FinalCtrScore < 45m)
            return true;

        if (IsOutlier(row.Supplier.SupplierId, OutlierFieldPrice)
            || IsOutlier(row.Supplier.SupplierId, OutlierFieldQuantity))
            return true;

        return IsExtremePrice(row.Supplier.SupplierId);
    }

    private bool ShowConditionalChip(SupplierPillarAnalysisRow row, LabelTenderDashboardDto dto)
    {
        if (IsRecommendedSupplier(row.Supplier.SupplierId))
            return false;

        if (RowNeedsManualReview(row))
            return false;

        return dto.IsCompliant && dto.FinalCtrScore >= 48m && dto.FinalCtrScore < 68m;
    }

    private int RiskReviewRowCount => TableItems.Count(RowNeedsManualReview);
}    