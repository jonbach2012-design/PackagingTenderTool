    private void OnSessionChanged()
    {
        if (_suppressSessionChanged)
            return;

        if (_isCalculating)
            return;

        RecordWeightHistory();
        RefreshData();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnBridgeTabChanged(string tab)
    {
        var t = (tab ?? string.Empty).Trim().ToLowerInvariant();
        _activeTab = t switch
        {
            "dashboard" or "matrix" or "deep-dive" or "audit" or "settings" => t,
            _ => "dashboard"
        };
        Nav.NavigateTo($"/labeltender?tab={_activeTab}", replace: true);
        SyncSidebarBridge();
        _ = InvokeAsync(StateHasChanged);
    }

    private void SyncTabFromUri()
    {
        var uri = Nav.Uri;
        if (uri.Contains("#audit", StringComparison.OrdinalIgnoreCase))
        {
            _activeTab = "audit";
            SyncSidebarBridge();
            return;
        }

        var qIdx = uri.IndexOf('?', StringComparison.Ordinal);
        var query = qIdx >= 0 ? uri[qIdx..] : string.Empty;
        if (!query.Contains("tab=", StringComparison.OrdinalIgnoreCase))
        {
            _activeTab = "dashboard";
            SyncSidebarBridge();
            return;
        }

        foreach (var part in query.TrimStart('?').Split('&'))
        {
            var kv = part.Split('=', 2);
            if (kv.Length != 2 || !kv[0].Equals("tab", StringComparison.OrdinalIgnoreCase))
                continue;

            var raw = Uri.UnescapeDataString(kv[1]);
            var t = raw.ToLowerInvariant();
            _activeTab = t switch
            {
                "dashboard" or "matrix" or "deep-dive" or "audit" or "settings" => t,
                _ => "dashboard"
            };
            SyncSidebarBridge();
            return;
        }
    }

