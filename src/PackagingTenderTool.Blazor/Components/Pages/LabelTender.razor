    private void RebuildAnomalies()
    {
        _anomalies.Clear();

        foreach (var kvp in _outliers.BySupplierId)
        {
            foreach (var f in kvp.Value)
            {
                var key = AnomalyKey(kvp.Key, f.Field);
                _anomalies.TryAdd(key, new AnomalyState(AnomalyStatus.Pending, note: string.Empty));
            }
        }
    }

    private void PruneAuditMaps()
    {
        // Prevent "stacking" of old keys in-memory across recalculations.
        // Keeps only keys that still exist in current outlier set.
        var validKeys = new HashSet<string>(
            _outliers.BySupplierId.SelectMany(kvp => kvp.Value.Select(f => $"{kvp.Key}|{f.Field}")),
            StringComparer.OrdinalIgnoreCase);

        var notesToRemove = _auditNotes.Keys.Where(k => !validKeys.Contains(k)).ToList();
        foreach (var k in notesToRemove)
            _auditNotes.TryRemove(k, out _);

        var reasoningToRemove = _auditReasoning.Keys.Where(k => !validKeys.Contains(k)).ToList();
        foreach (var k in reasoningToRemove)
            _auditReasoning.TryRemove(k, out _);

        var decisionsToRemove = _auditDecisions.Keys.Where(k => !validKeys.Contains(k)).ToList();
        foreach (var k in decisionsToRemove)
            _auditDecisions.TryRemove(k, out _);

        var anomaliesToRemove = _anomalies.Keys.Where(k => !validKeys.Contains(k)).ToList();
        foreach (var k in anomaliesToRemove)
            _anomalies.TryRemove(k, out _);
    }

