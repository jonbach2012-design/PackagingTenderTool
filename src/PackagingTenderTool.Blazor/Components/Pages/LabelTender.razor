    private void SetAnomalyStatus(string key, AnomalyStatus status)
    {
        if (_isCalculating)
            return;

        if (_anomalies.TryGetValue(key, out var state))
            _anomalies[key] = state with { Status = status };
        else
            _anomalies[key] = new AnomalyState(status, note: string.Empty);

        _history.Insert(0, new HistoryEntry(DateTimeOffset.Now, $"Anomaly decision — {key} => {status}"));
        Session.SetPendingClarificationsCount(_anomalies.Values.Count(a => a.Status is AnomalyStatus.Pending or AnomalyStatus.Clarification));
        StateHasChanged();
    }

