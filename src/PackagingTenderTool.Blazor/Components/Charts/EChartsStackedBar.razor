@using System.Text.Json
@using Microsoft.JSInterop
@implements IAsyncDisposable

@inject IJSRuntime Js

<div id="@_id" class="@Class" style="@Style"></div>

@code {
    [Parameter] public string Class { get; set; } = "pt-echart";
    [Parameter] public string Style { get; set; } = "width:100%;height:360px;";
    [Parameter] public object? Option { get; set; }
    [Parameter] public EventCallback<string> OnCategoryClick { get; set; }

    private readonly string _id = $"pt-echart-{Guid.NewGuid():N}";
    private DotNetObjectReference<EChartsStackedBar>? _objRef;
    private string? _lastOptionJson;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("ptEcharts.onClick", _id, _objRef);
        }

        if (Option is null)
            return;

        var json = JsonSerializer.Serialize(Option, new JsonSerializerOptions(JsonSerializerDefaults.Web));
        if (json == _lastOptionJson)
            return;

        _lastOptionJson = json;
        await Js.InvokeVoidAsync("ptEcharts.setOption", _id, Option);
    }

    [JSInvokable]
    public Task HandleClick(string name)
        => OnCategoryClick.InvokeAsync(name ?? string.Empty);

    public async ValueTask DisposeAsync()
    {
        try
        {
            await Js.InvokeVoidAsync("ptEcharts.dispose", _id);
        }
        catch
        {
            // ignore dispose race during hot reload/navigation
        }

        _objRef?.Dispose();
    }
}

