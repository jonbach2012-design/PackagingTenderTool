@implements IDisposable

@using PackagingTenderTool.Blazor.Services
@using PackagingTenderTool.Core.Models

@inject PackagingProfileSession Session
@inject LabelTenderSidebarBridge TenderBridge

@if (Session.SelectedProfile == PackagingProfileSession.ProfileLabels)
{
    <div class="cockpit-drawer-panel cockpit-drawer-panel--sharp pa-0">
        <div class="cockpit-drawer-weights px-2 pt-2">
            <MudText Typo="Typo.h6" Class="cockpit-drawer-section-title mb-2">
                STRATEGIC WEIGHTING
            </MudText>

            <MudStack Spacing="1" Class="cockpit-drawer-stack">
                <MudStack Spacing="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2" Class="cockpit-pillar-label">Commercial</MudText>
                            <MudTooltip Text="Price, Payment Terms, Volume Rebates, Currency Risk"
                                        Placement="Placement.Right"
                                        Delay="120"
                                        Duration="12000">
                                <MudIconButton Icon="@Icons.Material.Outlined.Info"
                                               Size="Size.Small"
                                               Class="cockpit-info-icon-btn"
                                               Color="Color.Inherit" />
                            </MudTooltip>
                        </MudStack>
                        <MudText Typo="Typo.caption" Class="cockpit-pillar-percent">@Session.Commercial%</MudText>
                    </MudStack>
                    <MudSlider T="int"
                               Min="0"
                               Max="100"
                               Step="1"
                               Value="Session.Commercial"
                               ValueChanged="OnCommercialChanged"
                               valueLabelDisplay="ValueLabelDisplay.OnHover"
                               Color="Color.Success"
                               Class="label-tender-slider-accent lt-shell-slider" />
                </MudStack>

                <MudStack Spacing="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2" Class="cockpit-pillar-label">Technical</MudText>
                            <MudTooltip Text="Lead Time, Quality Score, Machine Runability, MOQ"
                                        Placement="Placement.Right"
                                        Delay="120"
                                        Duration="12000">
                                <MudIconButton Icon="@Icons.Material.Outlined.Info"
                                               Size="Size.Small"
                                               Class="cockpit-info-icon-btn"
                                               Color="Color.Inherit" />
                            </MudTooltip>
                        </MudStack>
                        <MudText Typo="Typo.caption" Class="cockpit-pillar-percent">@Session.Technical%</MudText>
                    </MudStack>
                    <MudSlider T="int"
                               Min="0"
                               Max="100"
                               Step="1"
                               Value="Session.Technical"
                               ValueChanged="OnTechnicalChanged"
                               valueLabelDisplay="ValueLabelDisplay.OnHover"
                               Color="Color.Success"
                               Class="label-tender-slider-accent lt-shell-slider" />
                </MudStack>

                <MudStack Spacing="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2" Class="cockpit-pillar-label">Regulatory</MudText>
                            <MudTooltip Text="CO2 Footprint, Recyclability, FSC/PEFC, Compliance"
                                        Placement="Placement.Right"
                                        Delay="120"
                                        Duration="12000">
                                <MudIconButton Icon="@Icons.Material.Outlined.Info"
                                               Size="Size.Small"
                                               Class="cockpit-info-icon-btn"
                                               Color="Color.Inherit" />
                            </MudTooltip>
                        </MudStack>
                        <MudText Typo="Typo.caption" Class="cockpit-pillar-percent">@Session.Regulatory%</MudText>
                    </MudStack>
                    <MudSlider T="int"
                               Min="0"
                               Max="100"
                               Step="1"
                               Value="Session.Regulatory"
                               ValueChanged="OnRegulatoryChanged"
                               valueLabelDisplay="ValueLabelDisplay.OnHover"
                               Color="Color.Success"
                               Class="label-tender-slider-accent lt-shell-slider" />
                </MudStack>

                <MudStack Spacing="1" Class="cockpit-total-weight">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                        <MudText Typo="Typo.caption" Class="label-tender-slider-label">Total Weight</MudText>
                        <MudText Typo="Typo.caption"
                                 Class="@(Session.PillarSum == 100 ? "cockpit-total-weight-text cockpit-total-weight-text--ok" : "cockpit-total-weight-text")">
                            @Session.PillarSum%
                        </MudText>
                    </MudStack>
                    <MudProgressLinear Value="@Session.PillarSum"
                                       Max="100"
                                       Rounded="true"
                                       Class="@(Session.PillarSum == 100 ? "cockpit-total-weight-bar cockpit-total-weight-bar--ok" : "cockpit-total-weight-bar cockpit-total-weight-bar--partial")" />
                </MudStack>
            </MudStack>
        </div>

        <MudDivider Class="my-2" />

        <div class="cockpit-drawer-suppliers px-2">
            <MudText Typo="Typo.h6" Class="cockpit-drawer-section-title mb-2">
                SUPPLIER SELECTION
            </MudText>

            <MudStack Spacing="1" Class="cockpit-drawer-stack cockpit-drawer-supplier-stack">
                @if (Suppliers.Length == 0)
                {
                    <MudText Typo="Typo.body2" Class="cockpit-muted">Use Excel import on this page to load suppliers.</MudText>
                }
                else
                {
                    <MudCheckBox T="bool"
                                 Value="@IsAllSelected"
                                 ValueChanged="OnSelectAllChanged"
                                 Label="Select All"
                                 Dense="true"
                                 Class="cockpit-checkbox" />

                    <MudDivider Class="my-1" />

                    <MudStack Spacing="0">
                        @foreach (var supplier in Suppliers)
                        {
                            var selected = Session.SelectedSuppliers.Contains(supplier.Id);
                            <MudCheckBox T="bool"
                                         @key="supplier.Id"
                                         Dense="true"
                                         Class="cockpit-checkbox"
                                         Value="@selected"
                                         ValueChanged="@(v => OnSupplierToggled(supplier.Id, v))"
                                         Label="@supplier.Name" />
                        }
                    </MudStack>
                }
            </MudStack>
        </div>

        <MudDivider Class="my-2" />

        <div class="px-2">
            <MudCheckBox T="bool"
                         Dense="true"
                         Class="cockpit-checkbox"
                         Value="@Session.ApplyPpwr2030Scenario"
                         ValueChanged="@(v => Session.SetApplyPpwr2030Scenario(v))"
                         Label="Apply 2030 PPWR scenario" />
        </div>

        <MudDivider Class="my-2" />

        <div class="px-2 lt-shell-settings-stack">
            <MudText Typo="Typo.h6" Class="cockpit-drawer-section-title mb-2">SUPPLIER SETTINGS</MudText>

            @if (string.IsNullOrWhiteSpace(Session.ActiveSupplierId))
            {
                <MudText Typo="Typo.body2" Class="cockpit-muted">Select a supplier to configure tender assumptions.</MudText>
            }
            else
            {
                var active = Session.ActiveSupplierId;
                var incumbent = active.Equals(Session.IncumbentSupplierId, StringComparison.OrdinalIgnoreCase);

                <MudNumericField T="decimal"
                                 dense="true"
                                 Margin="Margin.Dense"
                                 Variant="Variant.Outlined"
                                 Immediate="true"
                                 Class="w-100 lt-shell-filter-select"
                                 Value="@Session.GetStartupCost(active)"
                                 ValueChanged="@(v => Session.SetStartupCost(active, v))"
                                 Disabled="@incumbent"
                                 Adornment="Adornment.Start"
                                 AdornmentText="Startup cost (kr.)"
                                 HideSpinButtons="true" />

                <MudNumericField T="decimal"
                                 dense="true"
                                 Margin="Margin.Dense"
                                 Variant="Variant.Outlined"
                                 Immediate="true"
                                 Class="w-100 lt-shell-filter-select"
                                 Value="@Session.GetMonthlySupportCost(active)"
                                 ValueChanged="@(v => Session.SetMonthlySupportCost(active, v))"
                                 Disabled="@incumbent"
                                 Adornment="Adornment.Start"
                                 AdornmentText="Monthly support cost (kr.)"
                                 HideSpinButtons="true" />

                <MudSelect T="RecyclingGrade"
                           Dense="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Label="Recyclability grade"
                           Class="w-100 lt-shell-filter-select"
                           AnchorOrigin="Origin.BottomCenter"
                           PopoverClass="lt-shell-select-popover-paper"
                           Value="@Session.GetSupplierRecyclabilityGrade(active)"
                           ValueChanged="@(v => Session.SetSupplierRecyclabilityGrade(active, v))">
                    <MudSelectItem Value="RecyclingGrade.A">A</MudSelectItem>
                    <MudSelectItem Value="RecyclingGrade.B">B</MudSelectItem>
                    <MudSelectItem Value="RecyclingGrade.C">C</MudSelectItem>
                    <MudSelectItem Value="RecyclingGrade.D">D</MudSelectItem>
                    <MudSelectItem Value="RecyclingGrade.E">E</MudSelectItem>
                </MudSelect>

                <MudNumericField T="decimal"
                                 dense="true"
                                 Margin="Margin.Dense"
                                 Variant="Variant.Outlined"
                                 Immediate="true"
                                 Class="w-100 lt-shell-filter-select"
                                 Value="@Session.GetSupplierMoqPenaltyPct(active)"
                                 ValueChanged="@(v => Session.SetSupplierMoqPenaltyPct(active, v))"
                                 Adornment="Adornment.Start"
                                 AdornmentText="MOQ penalty %"
                                 HideSpinButtons="true" />
            }
        </div>

        <div class="cockpit-drawer-advanced-wrap">
            <MudExpansionPanel Text="Advanced Settings" Dense="true" Class="cockpit-advanced-panel cockpit-advanced-panel--compact">
                <MudStack Spacing="2" Class="pt-2">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Class="label-tender-slider-label">Max CO₂ impact</MudText>
                        <MudSlider T="decimal"
                                   Min="@LabelTenderAdvancedConstraints.Co2SliderMin"
                                   Max="@LabelTenderAdvancedConstraints.Co2SliderMax"
                                   Step="@(0.05m)"
                                   Value="Session.MaxCo2Impact"
                                   ValueChanged="OnMaxCo2Changed"
                                   valueLabelDisplay="ValueLabelDisplay.OnHover"
                                   Color="Color.Success"
                                   Class="label-tender-slider-accent lt-shell-slider" />
                        <MudText Typo="Typo.caption" Class="cockpit-advanced-value">@Session.MaxCo2Impact.ToString("0.00")</MudText>
                    </MudStack>

                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Class="label-tender-slider-label">Max lead time (days)</MudText>
                        <MudSlider T="decimal"
                                   Min="@LabelTenderAdvancedConstraints.LeadSliderMin"
                                   Max="@LabelTenderAdvancedConstraints.LeadSliderMax"
                                   Step="1m"
                                   Value="Session.MaxLeadTimeDays"
                                   ValueChanged="OnMaxLeadChanged"
                                   valueLabelDisplay="ValueLabelDisplay.OnHover"
                                   Color="Color.Success"
                                   Class="label-tender-slider-accent lt-shell-slider" />
                        <MudText Typo="Typo.caption" Class="cockpit-advanced-value">@Session.MaxLeadTimeDays.ToString("0")</MudText>
                    </MudStack>
                </MudStack>
            </MudExpansionPanel>
        </div>
    </div>
}

@code
{
    private SupplierOption[] Suppliers =>
        TenderBridge.DrawerSuppliers
            .Select(r => new SupplierOption(r.Id, r.Name))
            .ToArray();

    private bool IsAllSelected => Suppliers.Length > 0 && Suppliers.All(n => Session.SelectedSuppliers.Contains(n.Id));

    private void OnSelectAllChanged(bool v)
    {
        Session.ReplaceSelectedSuppliers(v ? Suppliers.Select(s => s.Id).ToArray() : []);
    }

    private void OnSupplierToggled(string supplierId, bool v)
    {
        Session.SetSupplierSelected(supplierId, v);
        if (v)
        {
            Session.SetActiveSupplier(supplierId);
        }
        _ = InvokeAsync(StateHasChanged);
    }

    protected override void OnInitialized()
    {
        Session.Changed += OnSessionChanged;
        TenderBridge.Changed += OnBridgeChanged;

        // Default: all suppliers selected once the bridge has rows (avoid clearing selection on first paint).
        if (Session.SelectedSuppliers.Count == 0 && Suppliers.Length > 0)
        {
            Session.ReplaceSelectedSuppliers(Suppliers.Select(s => s.Id).ToArray());
        }
    }

    private sealed record SupplierOption(string Id, string Name);

    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
        TenderBridge.Changed -= OnBridgeChanged;
    }

    private void OnBridgeChanged() => _ = InvokeAsync(StateHasChanged);

    private void OnSessionChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnCommercialChanged(int v) => Session.SetCommercial(v);

    private void OnTechnicalChanged(int v) => Session.SetTechnical(v);

    private void OnRegulatoryChanged(int v) => Session.SetRegulatory(v);

    private void OnMaxCo2Changed(decimal v) => Session.SetMaxCo2Impact(v);

    private void OnMaxLeadChanged(decimal v) => Session.SetMaxLeadTimeDays(v);
}
