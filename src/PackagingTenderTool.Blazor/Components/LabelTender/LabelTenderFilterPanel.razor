@using MudBlazor
@using PackagingTenderTool.Blazor.Services
@inject LabelTenderSidebarBridge Bridge
@implements IDisposable

@if (Bridge.HasImportedData)
{
    <div class="lt-filter-panel-inner">
        <div style="display:flex; align-items:center; padding:12px 12px 8px;">
            <MudText Typo="Typo.h5"
                     Class="cockpit-import-headline lt-filter-panel-page-title"
                     Style="color:white; margin:0;">
                Label profile
            </MudText>
        </div>

        <div style="display:flex; flex-direction:column; gap:12px; padding:0 12px 12px;">
            @foreach (var g in LeftColumnGroups())
            {
                @if (g.Options is { Count: > 0 })
                {
                    <div class="pt-filter-group-box">
                        <div class="pt-filter-group-title">@g.Title</div>
                        <MudStack Spacing="0">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="px-2 py-1">
                                @{
                                    var noneSelected = g.Current().Count == 0;
                                    var toggleLabel = noneSelected ? "Select all" : "Deselect all";
                                }
                                <MudCheckBox T="bool"
                                             Dense="true"
                                             Color="Color.Default"
                                             Class="lt-filter-panel-cb"
                                             Value="@(!noneSelected)"
                                             ValueChanged="@(_ => ApplyGroupToggle(g))"
                                             Label="@toggleLabel"
                                             Style="color:rgba(255,255,255,0.88); font-size:13px;" />
                            </MudStack>
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:2px 12px;">
                                @foreach (var opt in g.Options)
                                {
                                    var captured = opt;
                                    var isChecked = g.Current().Contains(captured);
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="px-2 py-1" @key="@($"{g.Title}-{captured}")">
                                        <MudCheckBox T="bool"
                                                     Dense="true"
                                                     Color="Color.Default"
                                                     Class="lt-filter-panel-cb"
                                                     Value="@isChecked"
                                                     ValueChanged="@(v => ApplyGroupOptionChanged(g, captured, v))"
                                                     Label="@captured" />
                                    </MudStack>
                                }
                            </div>
                        </MudStack>
                    </div>
                }
            }
            @if (Bridge.DrawerSuppliers.Count > 0)
            {
                <div class="pt-filter-group-box">
                    <div class="pt-filter-group-title">Leverandører</div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:2px 12px;">
                        @foreach (var supplier in Bridge.DrawerSuppliers)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="px-2 py-1" @key="supplier.Id">
                                <MudCheckBox T="bool"
                                             Dense="true"
                                             Color="Color.Default"
                                             Class="lt-filter-panel-cb"
                                             Value="@Bridge.SelectedSupplierIds.Contains(supplier.Id)"
                                             ValueChanged="@(v => Bridge.OnSupplierSelectionChanged?.Invoke(supplier.Id, v))"
                                             Label="@supplier.Name" />
                            </MudStack>
                        }
                    </div>
                </div>
            }
            @foreach (var g in RightColumnGroups())
            {
                @if (g.Options is { Count: > 0 })
                {
                    <div class="pt-filter-group-box">
                        <div class="pt-filter-group-title">@g.Title</div>
                        <MudStack Spacing="0">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="px-2 py-1">
                                @{
                                    var noneSelected = g.Current().Count == 0;
                                    var toggleLabel = noneSelected ? "Select all" : "Deselect all";
                                }
                                <MudCheckBox T="bool"
                                             Dense="true"
                                             Color="Color.Default"
                                             Class="lt-filter-panel-cb"
                                             Value="@(!noneSelected)"
                                             ValueChanged="@(_ => ApplyGroupToggle(g))"
                                             Label="@toggleLabel"
                                             Style="color:rgba(255,255,255,0.88); font-size:13px;" />
                            </MudStack>
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:2px 12px;">
                                @foreach (var opt in g.Options)
                                {
                                    var captured = opt;
                                    var isChecked = g.Current().Contains(captured);
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="px-2 py-1" @key="@($"{g.Title}-{captured}")">
                                        <MudCheckBox T="bool"
                                                     Dense="true"
                                                     Color="Color.Default"
                                                     Class="lt-filter-panel-cb"
                                                     Value="@isChecked"
                                                     ValueChanged="@(v => ApplyGroupOptionChanged(g, captured, v))"
                                                     Label="@captured" />
                                    </MudStack>
                                }
                            </div>
                        </MudStack>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    protected override void OnInitialized() => Bridge.Changed += OnBridgeChanged;

    private void OnBridgeChanged() => _ = InvokeAsync(StateHasChanged);

    private static void ApplyGroupToggle(FilterGroupDef g)
    {
        if (g.Current().Count == 0)
            g.Apply(new HashSet<string>(g.Options, StringComparer.OrdinalIgnoreCase));
        else
            g.Apply(new HashSet<string>(StringComparer.OrdinalIgnoreCase));
    }

    private static void ApplyGroupOptionChanged(FilterGroupDef g, string captured, bool v)
    {
        var next = new HashSet<string>(g.Current(), StringComparer.OrdinalIgnoreCase);
        if (v)
            next.Add(captured);
        else
            next.Remove(captured);
        g.Apply(next);
    }

    private static bool FilterMatches(string current, string value) =>
        string.Equals((current ?? string.Empty).Trim(), value, StringComparison.OrdinalIgnoreCase);

    private sealed record FilterGroupDef(string Title, IReadOnlyList<string> Options, Func<IReadOnlySet<string>> Current, Action<HashSet<string>> Apply);

    private IEnumerable<FilterGroupDef> LeftColumnGroups()
    {
        yield return new FilterGroupDef("Lande", Bridge.FilterCountries,
            () => Bridge.ActiveFilterCountries,
            v => Bridge.OnCountriesChanged?.Invoke(v));
        yield return new FilterGroupDef("Sites", Bridge.FilterSitesForCountry,
            () => Bridge.ActiveFilterSites,
            v => Bridge.OnSitesChanged?.Invoke(v));
    }

    private IEnumerable<FilterGroupDef> RightColumnGroups()
    {
        yield return new FilterGroupDef("Materialer", Bridge.FilterMaterials,
            () => Bridge.ActiveFilterMaterials,
            v => Bridge.OnMaterialsChanged?.Invoke(v));
        yield return new FilterGroupDef("Label sizes", Bridge.FilterLabelSizes,
            () => Bridge.ActiveFilterLabelSizes,
            v => Bridge.OnLabelSizesChanged?.Invoke(v));
        yield return new FilterGroupDef("Winding", Bridge.FilterWindings,
            () => Bridge.ActiveFilterWindings,
            v => Bridge.OnWindingsChanged?.Invoke(v));
        yield return new FilterGroupDef("Colors", Bridge.FilterColorValues,
            () => Bridge.ActiveFilterColors,
            v => Bridge.OnColorsSetChanged?.Invoke(v));
    }

    public void Dispose() => Bridge.Changed -= OnBridgeChanged;
}
