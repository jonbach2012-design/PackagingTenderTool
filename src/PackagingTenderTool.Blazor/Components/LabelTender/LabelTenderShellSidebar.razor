@using Microsoft.AspNetCore.Components.Forms
@using System.Linq
@using MudBlazor
@using PackagingTenderTool.Core.Import
@using PackagingTenderTool.Blazor.Services
@inject LabelTenderSidebarBridge Bridge
@inject NavigationManager Nav
@implements IDisposable

<div class="lt-shell-sidebar">
    <MudStack Spacing="3" Class="pa-3">
        <section class="lt-shell-section">
            <MudText Typo="Typo.overline" Class="cockpit-muted">Data intake</MudText>
            <MudText Typo="Typo.h5" Class="cockpit-import-headline">Excel import</MudText>
            @if (Bridge.ImportInProgress)
            {
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                    <MudProgressCircular Size="Size.Small" Color="Color.Default" Indeterminate="true" />
                    <MudText Typo="Typo.caption" Class="cockpit-muted">Importing…</MudText>
                </MudStack>
            }
            else
            {
                <div class="lt-shell-file-import" style="width:100%;">
                    <label class="lt-shell-file-picker">
                        <span class="lt-shell-file-picker-face">Select file</span>
                        <InputFile OnChange="OnExcel"
                                   accept=".xlsx"
                                   class="lt-shell-file-input-native lt-shell-file-input-overlay cockpit-import-input" />
                    </label>
                    @if (!string.IsNullOrWhiteSpace(Bridge.LastImportedFileName))
                    {
                        <MudText Typo="Typo.caption" Class="lt-shell-file-name mt-1">@Bridge.LastImportedFileName</MudText>
                    }
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Bridge.ImportStatus))
            {
                <MudText Typo="Typo.caption" Class="cockpit-import-status">@Bridge.ImportStatus</MudText>
            }
            @if (Bridge.ActiveTab != "settings" &&
                 Bridge.LastImportValidationReport?.Issues.Any(i => i.Severity == ImportValidationSeverity.Error) == true)
            {
                <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="mt-1"
                         OnClick="@(() => Nav.NavigateTo("/labeltender?tab=evidence"))">
                    @Bridge.LastImportValidationReport!.Issues.Count(i => i.Severity == ImportValidationSeverity.Error) fejl — se Evidence table
                </MudChip>
            }
        </section>

        <MudDivider />
    </MudStack>

    <section class="lt-shell-section px-3 pb-2">
        <MudText Typo="Typo.subtitle2" Class="lt-shell-section-title mb-2">Navigation &amp; views</MudText>
        <MudStack Spacing="0" Class="lt-cockpit-nav">
            <MudButton Variant="Variant.Text"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Dashboard"
                       Class="@NavBtnClass("dashboard")"
                       OnClick="@(() => GoTab("dashboard"))">
                Dashboard
            </MudButton>
            <MudButton Variant="Variant.Text"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.GridOn"
                       Class="@NavBtnClass("matrix")"
                       OnClick="@(() => GoTab("matrix"))">
                Price matrix
            </MudButton>
            <MudButton Variant="Variant.Text"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.FactCheck"
                       Class="@NavBtnClass("evidence")"
                       OnClick="@(() => GoTab("evidence"))">
                Evidence table
            </MudButton>
            <MudButton Variant="Variant.Text"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.VerifiedUser"
                       Class="@NavBtnClass("audit")"
                       OnClick="@(() => GoTab("audit"))">
                Audit board
            </MudButton>
            <MudButton FullWidth="true"
                       Variant="Variant.Text"
                       StartIcon="@Icons.Material.Outlined.Settings"
                       Class="@NavBtnClass("settings")"
                       OnClick="@(() => GoTab("settings"))">
                Settings
            </MudButton>
        </MudStack>
    </section>

    <MudDivider Class="my-1" />

    <section class="lt-shell-section px-3 pb-2">
        <MudText Typo="Typo.subtitle2" Class="lt-shell-section-title mb-2">Scenarios</MudText>
        <MudStack Spacing="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="px-2 py-1">
                <MudSwitch T="bool" Color="Color.Success" dense="true"
                           Value="@Bridge.PpwrEffectToggle"
                           ValueChanged="@(v => Bridge.OnPpwrEffectChanged?.Invoke(v))"/>
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.88);">PPWR effect (test)</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="px-2 py-1">
                <MudSwitch T="bool" Disabled="true" dense="true" Value="false" />
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.45);">Supplier synergy (in future)</MudText>
            </MudStack>
        </MudStack>
    </section>

    <MudDivider Class="my-1" />

    @if (Bridge.HasImportedData)
    {
        <button type="button"
                style="position:absolute;right:-18px;top:33%;transform:translateY(-50%);z-index:1000;width:36px;height:36px;background:#485230;border:2px solid white;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:3px 0 10px rgba(0,0,0,0.5);padding:0;margin:0;"
                @onclick="OnFilterPanelToggleClick"
                aria-label="@(Bridge.FilterPanelOpen ? "Hide filters" : "Show filters")">
            <MudIcon Icon="@(Bridge.FilterPanelOpen ? Icons.Material.Filled.ChevronLeft : Icons.Material.Filled.ChevronRight)"
                     Size="Size.Medium"
                     Style="color:white;" />
        </button>
    }

</div>

@code {
    protected override void OnInitialized()
    {
        Bridge.Changed += OnBridgeChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnBridgeChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => InvokeAsync(StateHasChanged);

    private void OnFilterPanelToggleClick()
    {
        Bridge.OnToggleFilterPanel?.Invoke();
        StateHasChanged();
    }

    private async Task OnExcel(InputFileChangeEventArgs e)
    {
        if (Bridge.ImportExcelAsync is null)
            return;
        var file = e.File;
        var buffer = new byte[(int)file.Size];
        await using var stream = file.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024);
        var bytesRead = 0;
        while (bytesRead < buffer.Length)
        {
            var read = await stream.ReadAsync(buffer.AsMemory(bytesRead));
            if (read == 0) break;
            bytesRead += read;
        }
        await Bridge.ImportExcelAsync(file.Name, buffer[..bytesRead]);
    }

    private void GoTab(string tab) => Bridge.OnTabChanged?.Invoke(tab);

    private string NavBtnClass(string tab)
    {
        var uri = Nav.Uri;
        var active = uri.Contains($"tab={tab}", StringComparison.OrdinalIgnoreCase)
            || (tab == "dashboard" && !uri.Contains("tab=", StringComparison.OrdinalIgnoreCase));
        return active ? "lt-nav-btn lt-nav-btn--active" : "lt-nav-btn";
    }

    public void Dispose()
    {
        Bridge.Changed -= OnBridgeChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
