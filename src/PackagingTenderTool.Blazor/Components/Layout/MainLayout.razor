@inherits LayoutComponentBase
@implements IDisposable

@using PackagingTenderTool.Blazor.Components.LabelTender
@using PackagingTenderTool.Blazor.Services

@inject PackagingProfileSession Profile
@inject NavigationManager Nav
@inject LabelTenderSidebarBridge Bridge

<MudThemeProvider Theme="@AppTheme.Scandi" IsDarkMode="false" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="false" Class="pt-app-bar pt-app-bar-cockpit" Style="height: 64px;">
        <img src="/images/scandi-standard-logo.jpg"
             alt="Scandi Standard"
             style="height: 52px; width: auto; display: block;" />
        <MudText Typo="Typo.h6" Style="font-weight: 600; color: #485230; margin-left: 24px;">
            Packaging Tender Decision Support
        </MudText>
        <MudSpacer />
    </MudAppBar>

    @if (Profile.SelectedProfile is not null)
    {
        @if (_labelTenderRoute)
        {
            <div style="position:fixed; top:64px; left:0; width:240px; height:calc(100vh - 64px); z-index:100;">
                <div class="pt-label-drawer-wrap">
                    <MudDrawer Variant="DrawerVariant.Persistent"
                               Open="true"
                               Elevation="0"
                               Width="240px"
                               Class="pt-drawer pt-drawer-cockpit pt-drawer--label-shell"
                               Style="position:relative; flex-shrink:0; overflow:visible; background-color: #485230 !important; background: #485230 !important;">
                        <LabelTenderShellSidebar />
                    </MudDrawer>
                </div>
            </div>
            <div class="pt-filter-panel @(Bridge.HasImportedData ? "" : "pt-filter-panel--hidden")"
                 style="@FilterPanelInlineStyle">
                <LabelTenderFilterPanel />
            </div>
        }
        else
        {
            <MudDrawer Variant="DrawerVariant.Persistent"
                       Open="true"
                       Elevation="0"
                       Width="300px"
                       ClipMode="DrawerClipMode.Always"
                       Class="pt-drawer pt-drawer-cockpit">
                <LabelTenderDrawerPanel />
                <MudDivider Class="mx-2 my-1" />
                <div class="pt-drawer-nav pa-2">
                    <NavMenu />
                </div>
            </MudDrawer>
        }
    }

    <MudMainContent Class="@MainContentClass" Style="@(MainContentStyle ?? string.Empty)">
        @Body
    </MudMainContent>
</MudLayout>

@code
{
    private bool _labelTenderRoute;

    private bool _filterPanelOpen = true;

    private string MainContentClass =>
        Profile.SelectedProfile is null
            ? "pa-0 pt-mud-main-below-appbar"
            : _labelTenderRoute
                ? "cockpit-main cockpit-main--label-tender pt-mud-main-below-appbar"
                : "pa-4 cockpit-main pt-mud-main-below-appbar";

    private string? MainContentStyle =>
        Profile.SelectedProfile is not null && _labelTenderRoute
            ? "margin-left: 240px !important; --mud-drawer-width-left: 240px;"
            : null;

    private string FilterPanelInlineStyle =>
        $"position:fixed;left:240px;top:64px;z-index:101;width:{(_filterPanelOpen && Bridge.HasImportedData ? "480px" : "0px")};min-width:0;overflow:hidden;transition:width 0.25s ease;background:#485230;border-left:1px solid rgba(255,255,255,0.25);height:calc(100vh - 64px);";

    protected override void OnInitialized()
    {
        Profile.Changed += OnProfileChanged;
        Nav.LocationChanged += OnLocationChanged;
        Bridge.Changed += OnBridgeChanged;
        Bridge.FilterPanelOpen = _filterPanelOpen;
        Bridge.OnToggleFilterPanel = HandleToggleFilterPanel;
        RefreshRouteFlag();
    }

    private void OnBridgeChanged() => _ = InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => RefreshRouteFlag();

    private void HandleToggleFilterPanel()
    {
        _filterPanelOpen = !_filterPanelOpen;
        Bridge.FilterPanelOpen = _filterPanelOpen;
        _ = InvokeAsync(StateHasChanged);
    }

    private void RefreshRouteFlag()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri);
        var idx = path.IndexOf('?');
        if (idx >= 0)
            path = path[..idx];
        path = path.TrimEnd('/').ToLowerInvariant();
        _labelTenderRoute = path is "labeltender";
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnProfileChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Profile.Changed -= OnProfileChanged;
        Nav.LocationChanged -= OnLocationChanged;
        Bridge.Changed -= OnBridgeChanged;
        Bridge.OnToggleFilterPanel = null;
    }
}
