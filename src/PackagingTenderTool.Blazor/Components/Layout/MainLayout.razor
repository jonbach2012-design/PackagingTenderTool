@inherits LayoutComponentBase
@implements IDisposable

@using PackagingTenderTool.Blazor.Components.LabelTender

@inject PackagingProfileSession Profile
@inject NavigationManager Nav

<MudThemeProvider Theme="@AppTheme.Scandi" IsDarkMode="false" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="false" Class="pt-app-bar pt-app-bar-cockpit" Style="height: 64px;">
        <img src="/images/scandi-standard-logo.png" 
             alt="Scandi Standard" 
             style="height: 56px; width: auto; display: block;" />
        <MudText Typo="Typo.h6" 
                 Style="font-weight: 600; color: #485230; margin-left: 24px;">
            Packaging Tender Decision Support
        </MudText>
    </MudAppBar>

    @if (Profile.SelectedProfile is not null)
    {
        <MudDrawer Variant="DrawerVariant.Persistent"
                   Open="true"
                   Elevation="0"
                   Width="@(_labelTenderRoute ? "340px" : "300px")"
                   ClipMode="DrawerClipMode.Always"
                   Class="@(_labelTenderRoute ? "pt-drawer pt-drawer-cockpit pt-drawer--label-shell" : "pt-drawer pt-drawer-cockpit")"
                   Style="@(_labelTenderRoute ? "background-color: #485230 !important; background: #485230 !important;" : "")">
            @if (_labelTenderRoute)
            {
                <LabelTenderShellSidebar />
            }
            else
            {
                <LabelTenderDrawerPanel />
                <MudDivider Class="mx-2 my-1" />
                <div class="pt-drawer-nav pa-2">
                    <NavMenu />
                </div>
            }
        </MudDrawer>
    }

    <MudMainContent Class="@MainContentClass">
        @Body
    </MudMainContent>
</MudLayout>

@code
{
    private bool _labelTenderRoute;

    private string MainContentClass =>
        Profile.SelectedProfile is null
            ? "pa-0"
            : _labelTenderRoute
                ? "cockpit-main cockpit-main--label-tender"
                : "pa-4 cockpit-main";

    protected override void OnInitialized()
    {
        Profile.Changed += OnProfileChanged;
        Nav.LocationChanged += OnLocationChanged;
        RefreshRouteFlag();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => RefreshRouteFlag();

    private void RefreshRouteFlag()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri);
        var idx = path.IndexOf('?');
        if (idx >= 0)
            path = path[..idx];
        path = path.TrimEnd('/').ToLowerInvariant();
        _labelTenderRoute = path is "labeltender";
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnProfileChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Profile.Changed -= OnProfileChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
